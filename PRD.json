  "test_suites": {
    "unit_tests": {
      "framework": "xUnit",
      "project": "SecureChat.Tests.Unit",
      "tests": [
        {
          "id": "UT-CRYPTO-1",
          "name": "X25519KeyGenerationTest",
          "method": "Should_Generate_Valid_X25519_KeyPair",
          "code": "[Fact]\npublic void Should_Generate_Valid_X25519_KeyPair()\n{\n    var keyPair = X25519.GenerateKeyPair();\n    Assert.Equal(32, keyPair.PublicKey.Length);\n    Assert.Equal(32, keyPair.PrivateKey.Length);\n}"
        },
        {
          "id": "UT-CRYPTO-2",
          "name": "KyberKeyGenerationTest",
          "method": "Should_Generate_Valid_Kyber768_KeyPair",
          "code": "[Fact]\npublic void Should_Generate_Valid_Kyber768_KeyPair()\n{\n    var keyPair = Kyber768.GenerateKeyPair();\n    Assert.Equal(1184, keyPair.PublicKey.Length);\n    Assert.Equal(2400, keyPair.PrivateKey.Length);\n}"
        },
        {
          "id": "UT-CRYPTO-3",
          "name": "HybridSharedSecretTest",
          "method": "Should_Derive_Same_Shared_Secret",
          "code": "[Fact]\npublic async Task Should_Derive_Same_Shared_Secret()\n{\n    var alice = await _x3dhService.InitiateAsync(bobBundle);\n    var bob = await _x3dhService.RespondAsync(aliceMessage);\n    Assert.Equal(alice.SharedSecret, bob.SharedSecret);\n}"
        },
        {
          "id": "UT-CRYPTO-4",
          "name": "AesGcmEncryptionTest",
          "method": "Should_Encrypt_And_Decrypt",
          "code": "[Fact]\npublic void Should_Encrypt_And_Decrypt()\n{\n    var key = RandomNumberGenerator.GetBytes(32);\n    var plaintext = Encoding.UTF8.GetBytes(\"Hello\");\n    var ciphertext = AesGcm256.Encrypt(plaintext, key);\n    var decrypted = AesGcm256.Decrypt(ciphertext, key);\n    Assert.Equal(plaintext, decrypted);\n}"
        },
        {
          "id": "UT-CRYPTO-5",
          "name": "DoubleRatchetTest",
          "method": "Should_Generate_Unique_Message_Keys",
          "code": "[Fact]\npublic void Should_Generate_Unique_Message_Keys()\n{\n    var ratchet = new SymmetricRatchet(chainKey);\n    var key1 = ratchet.NextMessageKey();\n    var key2 = ratchet.NextMessageKey();\n    Assert.NotEqual(key1, key2);\n}"
        },
        {
          "id": "UT-DB-1",
          "name": "SqlServerConnectionTest",
          "method": "Should_Connect_To_SqlServer",
          "code": "[Fact]\npublic async Task Should_Connect_To_SqlServer()\n{\n    await using var conn = new SqlConnection(_connectionString);\n    await conn.OpenAsync();\n    Assert.Equal(ConnectionState.Open, conn.State);\n}"
        },
        {
          "id": "UT-DB-2",
          "name": "UserCrudTest",
          "method": "Should_Create_And_Retrieve_User",
          "code": "[Fact]\npublic async Task Should_Create_And_Retrieve_User()\n{\n    var user = new User { Username = \"test\" };\n    await _context.Users.AddAsync(user);\n    await _context.SaveChangesAsync();\n    var found = await _context.Users.FindAsync(user.Id);\n    Assert.NotNull(found);\n}"
        }
      ]
    },
