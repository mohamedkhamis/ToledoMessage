@using System.Text
@using System.Text.Json
@inject NavigationManager Navigation
@inject LocalStorageService Storage
@inject HttpClient Http
@inject SignalRService SignalR
@inject IJSRuntime Js
@implements IAsyncDisposable

<div class="sidebar-header">
    <AvatarInitials DisplayName="@_userName" Size="40" />
    <div class="sidebar-user-info">
        <span class="sidebar-user-name">@(string.IsNullOrEmpty(_userName) ? "You" : _userName)</span>
        <span class="sidebar-version">v@(AppVersion.Current)</span>
    </div>
    <div class="sidebar-header-actions">
        <button class="sidebar-icon-btn" @onclick="NavigateToSettings" title="Settings">⚙</button>
        <button class="sidebar-icon-btn" @onclick="NavigateToNewConversation" title="New conversation">✏</button>
        <button class="sidebar-icon-btn" @onclick="HandleLogout" title="Logout">⏻</button>
    </div>
</div>

<div class="sidebar-search">
    <input placeholder="Search conversations..."
           value="@_searchQuery"
           @oninput="OnSearchInput"
           aria-label="Search conversations" />
</div>

<div class="sidebar-list">
    @if (_isLoading)
    {
        <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.ConversationList" />
    }
    else if (FilteredConversations.Count == 0 && string.IsNullOrEmpty(_searchQuery))
    {
        <div style="text-align:center;padding:32px 16px;">
            <p class="centered-text" style="padding:0 0 16px;">No conversations yet</p>
            <button class="btn-outline btn-sm" @onclick="NavigateToNewConversation">
                Start a conversation
            </button>
        </div>
    }
    else if (FilteredConversations.Count == 0)
    {
        <p class="centered-text" style="padding:24px 16px;">No results for "@_searchQuery"</p>
    }
    else
    {
        @foreach (var conv in FilteredConversations)
        {
            var convId = conv.ConversationId;
            <div class="sidebar-item @(IsActiveConversation(conv.ConversationId) ? "active" : "")"
                 role="button" tabindex="0"
                 @onclick="() => SelectConversation(convId)"
                 @onkeydown="(e) => HandleKeyDown(e, convId)"
                 aria-label="@($"Conversation with {conv.DisplayName}")">
                <AvatarInitials DisplayName="@conv.DisplayName" Size="46" />
                <div class="sidebar-item-body">
                    <div class="sidebar-item-top">
                        <span class="sidebar-item-name">@conv.DisplayName</span>
                        @if (conv.LastMessageTime.HasValue)
                        {
                            <span class="sidebar-item-time">@FormatTime(conv.LastMessageTime.Value)</span>
                        }
                    </div>
                    <div class="sidebar-item-preview">
                        @if (conv.UnreadCount > 0)
                        {
                            <span class="conversation-item-badge" style="margin-right:4px;font-size:0.75em;">@conv.UnreadCount</span>
                        }
                        @(conv.LastMessage ?? "No messages yet")
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    private List<ConversationListItemResponse> _conversations = [];
    private string _searchQuery = "";
    private bool _isLoading = true;
    private string? _accessToken;
    private decimal _localDeviceId;
    private string _userName = "";
    private string _currentPath = "";

    private List<ConversationListItemResponse> FilteredConversations =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? _conversations
            : _conversations
                .Where(c => c.DisplayName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        _currentPath = new Uri(Navigation.Uri).AbsolutePath;
        Navigation.LocationChanged += OnLocationChanged;

        try
        {
            var tokenBytes = await Storage.GetAsync("auth.token");
            if (tokenBytes is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            _accessToken = Encoding.UTF8.GetString(tokenBytes);
            _userName = ExtractDisplayNameFromJwt(_accessToken);

            var deviceIdBytes = await Storage.GetAsync("local.deviceId");
            if (deviceIdBytes is not null)
                _localDeviceId = decimal.Parse(Encoding.UTF8.GetString(deviceIdBytes));

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _accessToken);

            await LoadConversations();

            try
            {
                var hubUrl = Navigation.ToAbsoluteUri("/hubs/chat").ToString();
                await SignalR.ConnectAsync(hubUrl, _accessToken);
                if (_localDeviceId != 0)
                    await SignalR.RegisterDeviceAsync(_localDeviceId);
                SignalR.OnMessageReceived += HandleMessageReceived;
            }
            catch (Exception ex) when (ex.Message.Contains("Device not found"))
            {
                await Js.InvokeVoidAsync("toledoStorage.clearAuthData");
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }
            catch
            {
                // Non-critical for sidebar
            }
        }
        catch
        {
            // Swallow initialization errors gracefully
        }
        finally
        {
            _isLoading = false;
        }

        await UpdateMobileLayout();
    }

    private async Task LoadConversations()
    {
        try
        {
            var serverConversations = await Http.GetFromJsonAsync<List<ConversationListItemResponse>>(
                "/api/conversations");

            _conversations = serverConversations?
                .Select(c => c with { LastMessage = c.LastMessageTime.HasValue ? "New message" : null })
                .ToList() ?? [];
        }
        catch
        {
            _conversations = [];
        }
    }

    private bool IsActiveConversation(decimal conversationId)
    {
        return _currentPath.Equals($"/chat/{conversationId}", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsInChatPage()
    {
        var path = _currentPath.TrimEnd('/');
        if (!path.StartsWith("/chat/", StringComparison.OrdinalIgnoreCase))
            return false;
        var segment = path["/chat/".Length..];
        return decimal.TryParse(segment, out _);
    }

    // ReSharper disable  AsyncVoidEventHandlerMethod
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentPath = new Uri(e.Location).AbsolutePath;
        await InvokeAsync(StateHasChanged);
        await UpdateMobileLayout();
    }

    private async Task UpdateMobileLayout()
    {
        try
        {
            var inChat = IsInChatPage();
            await Js.InvokeVoidAsync("eval",
                "(function(){" +
                "var s=document.getElementById('chat-sidebar');" +
                "var p=document.getElementById('chat-panel');" +
                $"if(s)s.classList.{(inChat ? "add" : "remove")}('hide-mobile');" +
                $"if(p)p.classList.{(inChat ? "add" : "remove")}('show-mobile');" +
                "})()");
        }
        catch
        {
            // JS interop may fail during prerender or initial load
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? "";
    }

    private void SelectConversation(decimal conversationId)
    {
        var index = _conversations.FindIndex(c => c.ConversationId == conversationId);
        if (index >= 0 && IsActiveConversation(conversationId))
            _conversations[index] = _conversations[index] with { UnreadCount = 0 };
        Navigation.NavigateTo($"/chat/{conversationId}");
    }

    private void HandleKeyDown(KeyboardEventArgs e, decimal conversationId)
    {
        if (e.Key is "Enter" or " ")
            SelectConversation(conversationId);
    }

    private void NavigateToSettings()
    {
        Navigation.NavigateTo("/settings");
    }

    private void NavigateToNewConversation()
    {
        Navigation.NavigateTo("/new-conversation");
    }

    private void HandleLogout()
    {
        Navigation.NavigateTo("/login?logout=true", forceLoad: true);
    }

    // ReSharper disable once AsyncVoidMethod
    private async void HandleMessageReceived(MessageEnvelope envelope)
    {
        await InvokeAsync(() =>
        {
            var index = _conversations.FindIndex(c => c.ConversationId == envelope.ConversationId);
            var isViewing = IsActiveConversation(envelope.ConversationId);

            if (index >= 0)
            {
                var existing = _conversations[index];
                var updated = existing with
                {
                    UnreadCount = isViewing ? existing.UnreadCount : existing.UnreadCount + 1,
                    LastMessage = "New message",
                    LastMessageTime = envelope.ServerTimestamp
                };
                _conversations.RemoveAt(index);
                _conversations.Insert(0, updated);
            }
            else
            {
                _conversations.Insert(0, new ConversationListItemResponse(
                        envelope.ConversationId,
                        ConversationType.OneToOne,
                        "New conversation",
                        envelope.ServerTimestamp,
                        isViewing ? 0 : 1)
                    { LastMessage = "New message" });
            }

            StateHasChanged();
        });
    }

    private static string FormatTime(DateTimeOffset time)
    {
        var diff = DateTimeOffset.UtcNow - time;
        if (diff.TotalMinutes < 1) return "now";
        if (diff.TotalHours < 24) return time.ToLocalTime().ToString("HH:mm");
        if (diff.TotalDays < 7) return time.ToLocalTime().ToString("ddd");
        return time.ToString("MMM d");
    }

    private static string ExtractDisplayNameFromJwt(string token)
    {
        try
        {
            var parts = token.Split('.');
            if (parts.Length != 3) return "?";
            var payload = parts[1];
            switch (payload.Length % 4)
            {
                case 2: payload += "=="; break;
                case 3: payload += "="; break;
            }
            var json = Encoding.UTF8.GetString(Convert.FromBase64String(payload));
            using var doc = JsonDocument.Parse(json);
            var root = doc.RootElement;
            foreach (var claim in new[]
            {
                "name",
                "unique_name",
                "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name"
            })
            {
                if (root.TryGetProperty(claim, out var prop))
                {
                    var val = prop.GetString();
                    if (!string.IsNullOrEmpty(val)) return val;
                }
            }
            return "?";
        }
        catch { return "?"; }
    }

    public async ValueTask DisposeAsync()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        SignalR.OnMessageReceived -= HandleMessageReceived;
        await Task.CompletedTask;
    }

    }
