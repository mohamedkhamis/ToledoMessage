@switch (Status)
{
    case ToledoMessage.Shared.Enums.DeliveryStatus.Sending:
        <span class="delivery-status delivery-sending" role="img" aria-label="Sending" title="Sending">...</span>
        break;
    case ToledoMessage.Shared.Enums.DeliveryStatus.Sent:
        <span class="delivery-status delivery-sent" role="img" aria-label="Sent" title="Sent">&#x2713;</span>
        break;
    case ToledoMessage.Shared.Enums.DeliveryStatus.Delivered:
        <span class="delivery-status delivery-delivered" role="img" aria-label="Delivered" title="Delivered">&#x2713;&#x2713;</span>
        break;
    case ToledoMessage.Shared.Enums.DeliveryStatus.Read:
        <span class="delivery-status delivery-read" role="img" aria-label="Read" title="Read">&#x2713;&#x2713;</span>
        break;
}

@code {
    [Parameter, EditorRequired]
    public ToledoMessage.Shared.Enums.DeliveryStatus Status { get; set; }
}
