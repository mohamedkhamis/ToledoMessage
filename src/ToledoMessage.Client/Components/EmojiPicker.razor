@inject IJSRuntime Js

<div class="emoji-picker-popup">
    <button class="emoji-picker-close" @onclick="ClosePicker" title="Close">&#10005;</button>
    <div class="emoji-picker-search">
        <input type="text" value="@_searchText" @oninput="OnSearchInput" placeholder="Search emoji..." />
    </div>

    <div class="emoji-category-tabs">
        @if (_recentEmojis.Count > 0)
        {
            <button class="emoji-category-tab @(_activeCategory == "Recent" ? "active" : "")"
                    @onclick="@(() => _activeCategory = "Recent")" title="Recent">&#128338;</button>
        }
        @foreach (var cat in Categories)
        {
            <button class="emoji-category-tab @(_activeCategory == cat.Key ? "active" : "")"
                    @onclick="@(() => _activeCategory = cat.Key)" title="@cat.Key">@cat.Value[0]</button>
        }
    </div>

    <div class="emoji-picker-body">
        @if (!string.IsNullOrEmpty(_searchText))
        {
            <div class="emoji-grid">
                @foreach (var result in _searchResults)
                {
                    <button class="emoji-item" @onclick="() => SelectEmoji(result.Emoji)" title="@result.Name">@result.Emoji</button>
                }
            </div>
            @if (_searchResults.Count == 0)
            {
                <div class="centered-text" style="padding:16px; font-size:0.85em;">No matches</div>
            }
        }
        else if (_activeCategory == "Recent" && _recentEmojis.Count > 0)
        {
            <div class="emoji-category-label">Recently Used</div>
            <div class="emoji-grid">
                @foreach (var emoji in _recentEmojis)
                {
                    <button class="emoji-item" @onclick="() => SelectEmoji(emoji)">@emoji</button>
                }
            </div>
        }
        else
        {
            @foreach (var cat in Categories)
            {
                if (_activeCategory != cat.Key && _activeCategory != "All") continue;
                <div class="emoji-category-label">@cat.Key</div>
                <div class="emoji-grid">
                    @foreach (var emoji in cat.Value)
                    {
                        <button class="emoji-item" @onclick="() => SelectEmoji(emoji)">@emoji</button>
                    }
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<string> OnEmojiSelected { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string _searchText = "";
    private string _activeCategory = "Smileys";
    private List<string> _recentEmojis = [];
    private List<(string Emoji, string Name)> _searchResults = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stored = await Js.InvokeAsync<string?>("localStorage.getItem", "emoji.recent");
            if (!string.IsNullOrEmpty(stored))
                _recentEmojis = stored.Split(',').Where(s => !string.IsNullOrEmpty(s)).Take(30).ToList();
            if (_recentEmojis.Count > 0) _activeCategory = "Recent";
        }
        catch
        {
            // ignored
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? "";
        UpdateSearch();
    }

    private void UpdateSearch()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _searchResults.Clear();
            return;
        }

        var q = _searchText.ToLowerInvariant();
        _searchResults = EmojiNames
            .Where(kv => kv.Value.Contains(q, StringComparison.OrdinalIgnoreCase))
            .Select(kv => (kv.Key, kv.Value))
            .Take(64)
            .ToList();
    }

    private async Task SelectEmoji(string emoji)
    {
        // Update recent
        _recentEmojis.Remove(emoji);
        _recentEmojis.Insert(0, emoji);
        if (_recentEmojis.Count > 30) _recentEmojis.RemoveRange(30, _recentEmojis.Count - 30);
        try { await Js.InvokeVoidAsync("localStorage.setItem", "emoji.recent", string.Join(",", _recentEmojis)); }
        catch
        {
            // ignored
        }

        await OnEmojiSelected.InvokeAsync(emoji);
    }

    private async Task ClosePicker()
