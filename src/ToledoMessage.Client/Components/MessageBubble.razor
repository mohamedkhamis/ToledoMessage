<div class="message-row @(IsMine ? "mine" : "") @GroupingClass @(IsSearchHighlight ? "message-highlight" : "")"
     data-msg-id="@MessageId"
     @oncontextmenu="HandleContextMenu" @oncontextmenu:preventDefault="true">
    <div class="message-bubble @(IsMine ? "mine" : "theirs")">
        @if (IsForwarded)
        {
            <div class="forwarded-label">@Loc["Forwarded"]</div>
        }
        @if (!string.IsNullOrEmpty(ReplyToSenderName))
        {
            <div class="reply-quote-block" @onclick="() => OnReplyQuoteClick.InvokeAsync(ReplyToMessageId ?? 0)">
                <div class="reply-sender-name">@ReplyToSenderName</div>
                @if (ReplyToContentType == ContentType.Image || ReplyToContentType == ContentType.Video)
                {
                    @if (!string.IsNullOrEmpty(ReplyToThumbnailDataUrl))
                    {
                        <img src="@ReplyToThumbnailDataUrl" class="reply-media-thumb" alt="Reply preview" />
                    }
                    else if (!string.IsNullOrEmpty(ReplyToMediaDataUrl))
                    {
                        <img src="@ReplyToMediaDataUrl" class="reply-media-thumb" alt="Reply preview" />
                    }
                    <div class="reply-quote-text">@(ReplyToContentType == ContentType.Image ? "📷 Photo" : "🎬 Video")</div>
                }
                else if (ReplyToContentType == ContentType.Audio)
                {
                    <div class="reply-quote-text">🎤 Voice message</div>
                }
                else if (ReplyToContentType == ContentType.File)
                {
                    <div class="reply-quote-text">@ReplyToText</div>
                }
                else
                {
                    <div class="reply-quote-text">@(!string.IsNullOrEmpty(ReplyToText) ? ReplyToText : "Message")</div>
                }
            </div>
        }
        @if (ContentType == ContentType.Image)
        {
            if (!string.IsNullOrEmpty(MediaDataUrl))
            {
                <div class="message-media message-image-clickable" @onclick="() => OnImageClick.InvokeAsync(MediaDataUrl)">
                    @if (!string.IsNullOrEmpty(ThumbnailDataUrl))
                    {
                        <img src="@ThumbnailDataUrl" alt="Loading..." class="message-image message-image-blur" />
                    }
                    <img src="@MediaDataUrl" alt="@(FileName ?? "Image")" class="message-image" />
                </div>
            }
            else if (!string.IsNullOrEmpty(ThumbnailDataUrl))
            {
                <div class="message-media message-image-clickable" @onclick="() => OnImageClick.InvokeAsync(ThumbnailDataUrl)">
                    <img src="@ThumbnailDataUrl" alt="@(FileName ?? "Image")" class="message-image" />
                </div>
            }
            else
            {
                <div class="message-media-placeholder">&#128247; @(FileName ?? Loc["Image unavailable"])</div>
            }
        }
        else if (ContentType == ContentType.Video)
        {
            if (!string.IsNullOrEmpty(MediaDataUrl))
            {
                <div class="message-media message-video-container" @onclick="() => OnVideoClick.InvokeAsync(MediaDataUrl)">
                    @if (!string.IsNullOrEmpty(ThumbnailDataUrl))
                    {
                        <img src="@ThumbnailDataUrl" alt="Video thumbnail" class="message-video-thumb-img" />
                    }
                    else
                    {
                        <video src="@(MediaDataUrl + "#t=0.5")" class="message-video-thumb-img"
                               preload="auto" muted playsinline aria-hidden="true"></video>
                    }
                    <div class="message-video-play-btn"></div>
                </div>
            }
            else if (!string.IsNullOrEmpty(ThumbnailDataUrl))
            {
                <div class="message-media message-video-container">
                    <img src="@ThumbnailDataUrl" alt="@(FileName ?? "Video")" class="message-video-thumb-img" />
                    <div class="message-video-play-btn"></div>
                </div>
            }
            else
            {
                <div class="message-media-placeholder">&#127909; @(FileName ?? Loc["Video unavailable"])</div>
            }
        }
        else if (ContentType == ContentType.Audio)
        {
            if (!string.IsNullOrEmpty(MediaDataUrl))
            {
                <div class="audio-message" @onclick="ToggleAudioPlayback">
                    <div class="audio-avatar @(IsMine ? "mine" : "")">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="audio-mic-icon">
                            <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
                            <path d="M19 10v2a7 7 0 01-14 0v-2" fill="none" stroke="currentColor" stroke-width="2"/>
                        </svg>
                    </div>
                    <button class="audio-play-btn" @onclick="ToggleAudioPlayback" @onclick:stopPropagation="true">
                        @if (_isAudioPlaying)
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <rect x="6" y="4" width="4" height="16" rx="1"/>
                                <rect x="14" y="4" width="4" height="16" rx="1"/>
                            </svg>
                        }
                        else
                        {
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M8 5v14l11-7z"/>
                            </svg>
                        }
                    </button>
                    <div class="audio-wave-track">
                        @for (var i = 0; i < 30; i++)
                        {
                            var h = AudioWaveHeights[i % AudioWaveHeights.Length];
                            var pct = i / 30.0;
                            var played = _audioDuration > 0 && pct <= (_audioCurrentTime / _audioDuration);
                            <span class="aw-bar @(played ? "played" : "")" style="height:@(h)px"></span>
                        }
                    </div>
                    <span class="audio-duration">@FormatAudioTime(_audioDuration > 0 ? _audioCurrentTime : 0)</span>
                    <audio @ref="_audioElementRef" src="@MediaDataUrl" preload="metadata"
                           @onended="OnAudioEnded" @ontimeupdate="OnAudioTimeUpdate"
                           @onloadedmetadata="OnAudioMetadata" style="display:none"></audio>
                </div>
            }
            else
            {
                <div class="message-media-placeholder">&#127911; @(FileName ?? Loc["Audio unavailable"])</div>
            }
        }
        else if (ContentType == ContentType.File)
        {
            if (!string.IsNullOrEmpty(MediaDataUrl))
            {
                @if (IsPdf)
                {
                    <div class="message-pdf-preview">
                        <div class="pdf-preview-frame-wrapper">
                            <iframe src="@(MediaDataUrl + "#toolbar=0&navpanes=0&scrollbar=0&view=FitH")"
                                    class="pdf-preview-frame"
                                    title="@(FileName ?? "PDF preview")"
                                    loading="lazy">
                            </iframe>
                            <div class="pdf-preview-overlay" @onclick="() => OnPdfClick.InvokeAsync(MediaDataUrl)"></div>
                        </div>
                        <div class="message-file-card pdf-card">
                            <div class="message-file-icon">📄</div>
                            <div class="message-file-info">
                                <span class="message-file-name">@(FileName ?? "Document.pdf")</span>
                            </div>
                            <a href="@MediaDataUrl" download="@(FileName ?? "document.pdf")"
                               class="message-file-download-btn" aria-label="Download @(FileName ?? "file")"
                               @onclick:stopPropagation="true">
                                &#8595;
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="message-file-card">
                        <div class="message-file-icon">@GetFileIconForMimeType(MimeType)</div>
                        <div class="message-file-info">
                            <span class="message-file-name">@(FileName ?? "File")</span>
                            <a href="@MediaDataUrl" download="@(FileName ?? "file")"
                               class="message-file-download" aria-label="Download @(FileName ?? "file")">
                                &#8595; @Loc["Download"]
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="message-media-placeholder">@GetFileIconForMimeType(MimeType) @(FileName ?? Loc["File unavailable"])</div>
            }
        }
        @if (!string.IsNullOrEmpty(Text))
        {
            <div class="message-text@(IsEmojiOnly(Text) ? " emoji-only" : "")">@Text</div>
            var firstUrl = ExtractFirstUrl(Text);
            if (firstUrl is not null)
            {
                <LinkPreview Url="@firstUrl" />
            }
        }
        @if (ReactionBadges.Count > 0)
        {
            <div class="reaction-badges">
                @foreach (var badge in ReactionBadges)
                {
                    <button class="reaction-badge @(badge.IncludesMine ? "mine" : "")"
                            @onclick="() => OnReactionToggle.InvokeAsync(badge.Emoji)">
                        <span class="reaction-badge-emoji">@badge.Emoji</span>
                        <span class="reaction-badge-count">@badge.Count</span>
                    </button>
                }
            </div>
        }
        <div class="message-meta">
            <span>@Timestamp.ToLocalTime().ToString("HH:mm")</span>
            @if (IsMine)
            {
                <DeliveryStatus Status="Status" />
            }
        </div>
        <button class="msg-quick-reply" @onclick="() => OnReply.InvokeAsync()" @onclick:stopPropagation="true" title="Reply" aria-label="Reply">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 17 4 12 9 7"/>
                <path d="M20 18v-2a4 4 0 0 0-4-4H4"/>
            </svg>
        </button>
    </div>
</div>

@inject IJSRuntime Js
@inject IStringLocalizer<SharedResource> Loc

@* ReSharper disable once NotAccessedField.Local *@
@code {
    // Check if text contains only 1-3 emoji (for big emoji rendering)
    private static bool IsEmojiOnly(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return false;

        var trimmed = text.Trim();
        if (trimmed.Length > 14) // Safety cap for compound emoji
            return false;

        // Match 1-3 emoji characters (including compound emoji like flags, skin tones)
        // Emoji patterns: single emoji, ZWJ sequences, variation selectors, keycap, etc.
        return System.Text.RegularExpressions.Regex.IsMatch(
            trimmed,
            @"^(\p{So}|\p{Cs}{2}|\u200D|\uFE0F|\u20E3|[\u2600-\u27BF]|[\uD83C-\uD83F][\uD800-\uDFFF]){1,3}$");
    }

    // Audio playback state
    private bool _isAudioPlaying;
    private double _audioCurrentTime;
    private double _audioDuration;
    private ElementReference _audioElementRef;
    private static readonly int[] AudioWaveHeights = [4, 8, 14, 10, 18, 6, 12, 20, 8, 16, 10, 22, 6, 14, 18, 8, 12, 20, 10, 16, 6, 14, 22, 8, 18, 12];

    private async Task ToggleAudioPlayback()
    {
        try
        {
            if (_isAudioPlaying)
            {
                await Js.InvokeVoidAsync("mediaHelpers.pauseAudio", MessageId);
                _isAudioPlaying = false;
            }
            else
            {
                await Js.InvokeVoidAsync("mediaHelpers.playAudio", MessageId);
                _isAudioPlaying = true;
            }
        }
        catch { /* ignored */ }
    }

    private void OnAudioEnded() { _isAudioPlaying = false; _audioCurrentTime = 0; }
    private void OnAudioTimeUpdate()
    {
        _ = UpdateAudioTimeAsync();
    }

    private async Task UpdateAudioTimeAsync()
    {
        try
        {
            var time = await Js.InvokeAsync<double>("mediaHelpers.getAudioCurrentTime", MessageId);
            _audioCurrentTime = time;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignored */ }
    }

    private void OnAudioMetadata()
    {
        _ = LoadAudioDurationAsync();
    }

    private async Task LoadAudioDurationAsync()
    {
        try
        {
            var dur = await Js.InvokeAsync<double>("mediaHelpers.getAudioDuration", MessageId);
            _audioDuration = dur;
            await InvokeAsync(StateHasChanged);
        }
        catch { /* ignored */ }
    }

    private static string FormatAudioTime(double seconds)
    {
        var m = (int)seconds / 60;
        var s = (int)seconds % 60;
        return $"{m}:{s:D2}";
    }

    private static string GetFileIconForMimeType(string? mimeType)
    {
        if (string.IsNullOrEmpty(mimeType))
            return "📎";

        return mimeType.ToLowerInvariant() switch
        {
            var m when m.StartsWith("application/pdf") => "📄",
            var m when m.StartsWith("application/msword") ||
                        m.StartsWith("application/vnd.openxmlformats-officedocument.wordprocessingml") => "📝",
            var m when m.StartsWith("application/vnd.ms-excel") ||
                        m.StartsWith("application/vnd.openxmlformats-officedocument.spreadsheetml") => "📊",
            var m when m.StartsWith("application/vnd.ms-powerpoint") ||
                        m.StartsWith("application/vnd.openxmlformats-officedocument.presentationml") => "📑",
            var m when m.StartsWith("application/zip") ||
                        m.StartsWith("application/x-rar") ||
                        m.StartsWith("application/x-7z-compressed") ||
                        m.StartsWith("application/x-tar") ||
                        m.StartsWith("application/gzip") => "📦",
            var m when m.StartsWith("text/") => "📃",
            _ => "📎"
        };
    }

    [Parameter]
    public long MessageId { get; set; }

    [Parameter, EditorRequired]
    public string Text { get; set; } = "";

    [Parameter, EditorRequired]
    public DateTimeOffset Timestamp { get; set; }

    [Parameter]
    public bool IsMine { get; set; }

    [Parameter]
    public ToledoMessage.Shared.Enums.DeliveryStatus Status { get; set; }

    [Parameter]
    public ContentType ContentType { get; set; } = ContentType.Text;

    [Parameter]
    public string? MediaDataUrl { get; set; }

    [Parameter]
    public string? ThumbnailDataUrl { get; set; }

    [Parameter]
    public string? MimeType { get; set; }

    [Parameter]
    public string? FileName { get; set; }

    [Parameter]
    public bool IsFirstInGroup { get; set; } = true;

    [Parameter]
    public bool IsLastInGroup { get; set; } = true;

    [Parameter]
    public EventCallback<string> OnImageClick { get; set; }

    [Parameter]
    public EventCallback<string> OnVideoClick { get; set; }

    [Parameter]
    public EventCallback OnReply { get; set; }

    [Parameter]
    public EventCallback<(double X, double Y)> OnContextMenu { get; set; }

    [Parameter]
    public long? ReplyToMessageId { get; set; }

    [Parameter]
    public string? ReplyToSenderName { get; set; }

    [Parameter]
    public string? ReplyToText { get; set; }

    [Parameter]
    public string? ReplyToMediaDataUrl { get; set; }

    [Parameter]
    public string? ReplyToThumbnailDataUrl { get; set; }

    [Parameter]
    public ContentType ReplyToContentType { get; set; } = ContentType.Text;

    [Parameter]
    public EventCallback<long> OnReplyQuoteClick { get; set; }

    [Parameter]
    public List<ReactionBadgeModel> ReactionBadges { get; set; } = [];

    [Parameter]
    public EventCallback<string> OnReactionToggle { get; set; }

    [Parameter]
    public bool IsForwarded { get; set; }

    [Parameter]
    public bool IsSearchHighlight { get; set; }

    [Parameter]
    public EventCallback<string> OnPdfClick { get; set; }

    private bool IsPdf => MimeType?.StartsWith("application/pdf", StringComparison.OrdinalIgnoreCase) == true
                          || FileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true;

    private async Task HandleContextMenu(MouseEventArgs e)
    {
        await OnContextMenu.InvokeAsync((e.ClientX, e.ClientY));
    }

    private string GroupingClass
    {
        get
        {
            if (IsFirstInGroup && IsLastInGroup) return "";
            if (IsFirstInGroup) return "group-first";
            if (IsLastInGroup) return "group-last";
            return "group-middle";
        }
    }

    private static string? ExtractFirstUrl(string text)
    {
        var match = System.Text.RegularExpressions.Regex.Match(text, @"https?://[^\s<>""]+");
        return match.Success ? match.Value : null;
    }

    public sealed class ReactionBadgeModel
    {
        public string Emoji { get; set; } = "";
        public int Count { get; set; }
        public bool IncludesMine { get; set; }
    }
}
