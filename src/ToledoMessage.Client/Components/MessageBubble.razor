@using ToledoMessage.Shared.Enums

<div class="message-row @(IsMine ? "mine" : "") @(IsMine ? "msg-slide-in-right" : "msg-slide-in-left")">
    <div class="message-bubble @(IsMine ? "mine" : "theirs")">
        @if (ContentType == ContentType.Image && !string.IsNullOrEmpty(MediaDataUrl))
        {
            <div class="message-media">
                <img src="@MediaDataUrl" alt="@(FileName ?? "Image")" class="message-image"
                     style="max-width:100%;max-height:300px;border-radius:8px;object-fit:contain;" />
            </div>
        }
        else if (ContentType == ContentType.Audio && !string.IsNullOrEmpty(MediaDataUrl))
        {
            <div class="message-media">
                <audio controls src="@MediaDataUrl" class="message-audio" style="max-width:100%;">
                    Your browser does not support audio playback.
                </audio>
            </div>
        }
        @if (!string.IsNullOrEmpty(Text))
        {
            <div class="message-text">@Text</div>
        }
        @if (!string.IsNullOrEmpty(FileName) && ContentType != ContentType.Text)
        {
            <div class="message-filename">@FileName</div>
        }
        <div class="message-meta">
            <span>@Timestamp.ToLocalTime().ToString("HH:mm")</span>
            @if (IsMine)
            {
                <DeliveryStatus Status="Status" />
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public string Text { get; set; } = "";

    [Parameter, EditorRequired]
    public DateTimeOffset Timestamp { get; set; }

    [Parameter]
    public bool IsMine { get; set; }

    [Parameter]
    public ToledoMessage.Shared.Enums.DeliveryStatus Status { get; set; }

    [Parameter]
    public ContentType ContentType { get; set; } = ContentType.Text;

    [Parameter]
    public string? MediaDataUrl { get; set; }

    [Parameter]
    public string? FileName { get; set; }
}
