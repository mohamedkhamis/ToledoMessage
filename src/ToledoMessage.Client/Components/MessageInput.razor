<div class="chat-input-area" style="display:flex; gap:8px;">
    <textarea @bind="messageText"
              @bind:event="oninput"
              @bind:after="HandleTyping"
              @onkeydown="HandleKeyDown"
              placeholder="Type a message..."
              rows="1"
              style="flex:1; padding:10px 14px; border:1px solid var(--gray-300); border-radius:20px;
                     resize:none; font-size:0.95em; outline:none; font-family:var(--font-family);" />
    <button @onclick="SendMessage"
            disabled="@string.IsNullOrWhiteSpace(messageText)"
            class="btn-primary"
            style="border-radius:50%; width:42px; height:42px; padding:0; display:flex; align-items:center; justify-content:center;"
            title="Send">
        &#10148;
    </button>
</div>

@code {
    private string messageText = "";

    [Parameter]
    public EventCallback<string> OnSend { get; set; }

    [Parameter]
    public EventCallback OnTyping { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        var text = messageText?.Trim();
        if (string.IsNullOrEmpty(text))
            return;

        messageText = "";
        await OnSend.InvokeAsync(text);
    }

    private async Task HandleTyping()
    {
        await OnTyping.InvokeAsync();
    }
}
