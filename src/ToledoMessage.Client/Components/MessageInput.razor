@inject IJSRuntime Js
@inject ThemeService Theme
@implements IAsyncDisposable

<div class="chat-input-area">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="input-error">@_errorMessage</div>
    }
    @if (ReplyContext is not null)
    {
        <div class="reply-preview-bar">
            <div class="reply-preview-content">
                <div class="reply-sender-name">@ReplyContext.SenderName</div>
                <div class="reply-quote-text">@(!string.IsNullOrEmpty(ReplyContext.Text) ? ReplyContext.Text : "Message")</div>
            </div>
            <button class="reply-preview-close" @onclick="() => OnCancelReply.InvokeAsync()" aria-label="Cancel reply">&times;</button>
        </div>
    }
    @if (_selectedFile is not null)
    {
        <div class="file-preview-bar">
            @if (_previewDataUrl is not null)
            {
                <img src="@_previewDataUrl" class="file-preview-thumb" alt="Preview" />
            }
            else
            {
                <div class="file-preview-icon">@GetFileIcon(_selectedContentType)</div>
            }
            <div class="file-preview-info">
                <span class="file-preview-name">@_selectedFile.Name</span>
                <span class="file-preview-size">@FormatFileSize(_selectedFile.Size)</span>
                @if (_selectedContentType == ContentType.Image)
                {
                    <label class="send-as-doc-toggle">
                        <input type="checkbox" checked="@_sendAsDocument" @onchange="OnSendAsDocumentChanged" />
                        <span>Send as document</span>
                    </label>
                }
            </div>
            <button class="file-preview-remove" @onclick="ClearSelectedFile" aria-label="Remove attachment">&times;</button>
        </div>
    }
    <div class="chat-input-row">
        @if (!_isRecording)
        {
            <div class="attach-menu-wrapper">
                @if (_showAttachMenu)
                {
                    <div class="attach-menu-backdrop" @onclick="CloseAttachMenu"></div>
                    <div class="attach-menu-popup" role="menu">
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#128247;</span>
                            <span>@Theme.Labels.PhotoOrVideo</span>
                            <InputFile accept="image/*,video/*" OnChange="OnMediaSelected" style="display:none" />
                        </label>
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#127908;</span>
                            <span>@Theme.Labels.Audio</span>
                            <InputFile accept="audio/*" OnChange="OnAudioSelected" style="display:none" />
                        </label>
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#128196;</span>
                            <span>@Theme.Labels.Document</span>
                            <InputFile OnChange="OnDocumentSelected" style="display:none" />
                        </label>
                    </div>
                }
                <button class="attach-btn" @onclick="ToggleAttachMenu"
                        aria-label="Attach file" title="Attach file"
                        aria-expanded="@_showAttachMenu">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" />
                    </svg>
                </button>
            </div>

            <div class="attach-menu-wrapper">
                @if (_showEmojiPicker)
                {
                    <div class="attach-menu-backdrop" @onclick="() => _showEmojiPicker = false"></div>
                    <EmojiPicker OnEmojiSelected="InsertEmoji" OnClose="() => _showEmojiPicker = false" />
                }
                <button class="emoji-btn" @onclick="() => _showEmojiPicker = !_showEmojiPicker"
                        aria-label="Emoji" title="Emoji">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                        <line x1="9" y1="9" x2="9.01" y2="9"/>
                        <line x1="15" y1="9" x2="15.01" y2="9"/>
                    </svg>
                </button>
            </div>

            <textarea @ref="_textareaRef"
                      @bind="_messageText"
                      @bind:event="oninput"
                      @bind:after="OnTextInput"
                      @onkeydown="HandleKeyDown"
                      placeholder="@Theme.Labels.TypeMessage"
                      rows="1"
                      class="msg-textarea"
                      aria-label="Message input"></textarea>

            @if (CanSend)
            {
                <button @onclick="SendMessage"
                        class="send-btn send-btn-active"
                        aria-label="Send message"
                        title="Send">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                    </svg>
                </button>
            }
            else
            {
                <button class="mic-btn" @onclick="StartRecording"
                        aria-label="Record voice message" title="Record voice message">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
                        <path d="M19 10v2a7 7 0 01-14 0v-2"/>
                        <line x1="12" y1="19" x2="12" y2="23"/>
                        <line x1="8" y1="23" x2="16" y2="23"/>
                    </svg>
                </button>
            }
        }
        else
        {
            <VoiceRecorder OnRecorded="HandleVoiceRecorded" OnCancelled="() => _isRecording = false" />
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Theme.OnThemeChanged -= OnThemeChanged;
    }

    private string _messageText = "";
    private IBrowserFile? _selectedFile;
    private byte[]? _selectedFileBytes;
    private ContentType _selectedContentType = ContentType.Text;
    private string? _previewDataUrl;
    private string? _errorMessage;
    private bool _showAttachMenu;
    private bool _showEmojiPicker;
    private bool _isRecording;
    private bool _sendAsDocument;
    private ElementReference _textareaRef;

    private bool CanSend => !string.IsNullOrWhiteSpace(_messageText) || _selectedFile is not null;

    [Parameter]
    public EventCallback<ChatInputMessage> OnSend { get; set; }

    [Parameter]
    public EventCallback OnTyping { get; set; }

    [Parameter]
    public ReplyContextModel? ReplyContext { get; set; }

    [Parameter]
    public EventCallback OnCancelReply { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.preventEnterNewline", _textareaRef); }
            catch { /* ignored */ }
        }
    }

    private void ToggleAttachMenu()
    {
        _showAttachMenu = !_showAttachMenu;
    }

    private void CloseAttachMenu()
    {
        _showAttachMenu = false;
    }

    private async Task InsertEmoji(string emoji)
    {
        _showEmojiPicker = false;
        try
        {
            await Js.InvokeVoidAsync("mediaHelpers.insertTextAtCursor", _textareaRef, emoji);
            _messageText = await Js.InvokeAsync<string>("mediaHelpers.getTextareaValue", ".msg-textarea");
        }
        catch
        {
            // ignored
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
            await SendMessage();
    }

    private async Task OnTextInput()
    {
        await ResizeTextarea();
        await OnTyping.InvokeAsync();
    }

    private async Task ResizeTextarea()
    {
        try { await Js.InvokeVoidAsync("mediaHelpers.autoResize", _textareaRef); }
        catch
        {
            // ignored
        }
    }

    private async Task SendMessage()
    {
        if (!CanSend)
            return;

        var text = _messageText.Trim();
        byte[]? mediaBytes = null;
        string? fileName = null;
        string? mimeType = null;
        var contentType = ContentType.Text;

        if (_selectedFile is not null)
        {
            if (_selectedFileBytes is null)
            {
                _errorMessage = "Could not read the selected file. Please try again.";
                return;
            }

            mediaBytes = _selectedFileBytes;
            fileName = _selectedFile.Name;
            // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
            mimeType = _selectedFile.ContentType ?? "image/jpeg";
            contentType = _selectedContentType;
            System.Diagnostics.Debug.WriteLine($"[DEBUG] SendMessage: fileName={fileName}, mimeType={mimeType}, contentType={contentType}");
        }

        if (string.IsNullOrEmpty(text) && mediaBytes is null)
            return;

        var msg = new ChatInputMessage
        {
            Text = text,
            MediaBytes = mediaBytes,
            FileName = fileName,
            MimeType = mimeType,
            ContentType = contentType,
            SendAsDocument = _sendAsDocument,
            ReplyToMessageId = ReplyContext?.MessageId
        };

        _messageText = "";
        ClearSelectedFile();
        try { await Js.InvokeVoidAsync("mediaHelpers.resetHeight", _textareaRef); }
        catch
        {
            // ignored
        }

        await OnSend.InvokeAsync(msg);
    }

    private async Task OnMediaSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        var file = e.File;
        // Debug: Log the content type
        System.Diagnostics.Debug.WriteLine($"[DEBUG] OnMediaSelected: {file.Name}, ContentType: '{file.ContentType}', Size: {file.Size}");
        // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
        var contentType = file.ContentType ?? "image/jpeg"; // Fallback to JPEG if browser doesn't provide
        _selectedContentType = contentType.StartsWith("video/") ? ContentType.Video : ContentType.Image;
        System.Diagnostics.Debug.WriteLine($"[DEBUG] _selectedContentType set to: {_selectedContentType}");

        // For videos, we need to generate a preview thumbnail
        if (_selectedContentType == ContentType.Video)
        {
            await SetSelectedFile(file, createPreview: false);
            // Generate video thumbnail after file is loaded
            if (_selectedFileBytes is not null)
            {
                try
                {
                    var thumbnailBase64 = await Js.InvokeAsync<string>("mediaHelpers.captureVideoFrame",
                        _selectedFileBytes, file.ContentType ?? "video/mp4");
                    if (!string.IsNullOrEmpty(thumbnailBase64))
                    {
                        var thumbnailBytes = Convert.FromBase64String(thumbnailBase64);
                        _previewDataUrl = await Js.InvokeAsync<string>(
                            "mediaHelpers.createObjectUrl", thumbnailBytes, "image/jpeg");
                    }
                }
                catch (Exception ex)
                {
                    System.Diagnostics.Debug.WriteLine($"[DEBUG] Video thumbnail failed: {ex.Message}");
                }
            }
        }
        else
        {
            await SetSelectedFile(file, createPreview: _selectedContentType == ContentType.Image);
        }
    }

    private async Task OnAudioSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        _selectedContentType = ContentType.Audio;
        await SetSelectedFile(e.File, createPreview: false);
    }

    private async Task OnDocumentSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        _selectedContentType = ContentType.File;
        await SetSelectedFile(e.File, createPreview: false);
    }

    private async Task SetSelectedFile(IBrowserFile file, bool createPreview)
    {
        ClearSelectedFile();
        _errorMessage = null;
        _sendAsDocument = false;

        var maxSize = ProtocolConstants.MaxMediaCiphertextSizeBytes;
        if (file.Size > maxSize)
        {
            _errorMessage = $"File too large. Maximum is {FormatFileSize(maxSize)}.";
            return;
        }

        // Read bytes eagerly — avoids double-read on send and enables preview
        await using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
        _selectedFileBytes = new byte[file.Size];
        await stream.ReadExactlyAsync(_selectedFileBytes);

        // Trust browser's content type - no validation needed
        // The browser already validated the file when the user selected it

        _selectedFile = file;

        // Compress images if not sending as document
        if (createPreview && _selectedContentType == ContentType.Image && !_sendAsDocument)
        {
            try
            {
                // ReSharper disable NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
                var mimeType = file.ContentType ?? "image/jpeg";
                var compressed = await Js.InvokeAsync<CompressedImageResult>(
                    "mediaHelpers.compressImage", _selectedFileBytes, mimeType, 1600, 0.8);

                if (compressed.Bytes is not null && compressed.Bytes.Length > 0)
                {
                    _selectedFileBytes = compressed.Bytes;

                    // Update preview with compressed image
                    if (_previewDataUrl is not null)
                    {
                        await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
                    }
                    _previewDataUrl = await Js.InvokeAsync<string>(
                        "mediaHelpers.createObjectUrl", _selectedFileBytes, "image/jpeg");
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[DEBUG] Image compression failed: {ex.Message}");
                // Continue without compression - original bytes will be used
            }
        }

        if (createPreview && _selectedFileBytes is not null)
        {
            try
            {
                // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
                var mimeType = file.ContentType ?? "image/jpeg";
                _previewDataUrl ??= await Js.InvokeAsync<string>(
                    "mediaHelpers.createObjectUrl", _selectedFileBytes, mimeType);
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"[DEBUG] Preview failed: {ex.Message}");
                // ignored - preview is optional
            }
        }
    }

    private sealed class CompressedImageResult
    {
        // ReSharper disable  PropertyCanBeMadeInitOnly.Local
        public byte[]? Bytes { get; set; }
        public int Width { get; set; }
        public int Height { get; set; }
    }

    private async Task OnSendAsDocumentChanged(ChangeEventArgs e)
    {
        if (_selectedFile is null || _selectedContentType != ContentType.Image) return;

        _sendAsDocument = e.Value is true;

        if (_sendAsDocument)
        {
            // Re-read original file bytes (skip compression)
            if (_selectedFileBytes is not null && _previewDataUrl is not null)
            {
                await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
                _previewDataUrl = null;
            }

            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: ProtocolConstants.MaxMediaCiphertextSizeBytes);
            _selectedFileBytes = new byte[_selectedFile.Size];
            await stream.ReadExactlyAsync(_selectedFileBytes);

            // Show original preview (not compressed)
            try
            {
                var mimeType = _selectedFile.ContentType ?? "image/jpeg";
                _previewDataUrl = await Js.InvokeAsync<string>(
                    "mediaHelpers.createObjectUrl", _selectedFileBytes, mimeType);
            }
            catch { /* ignore preview errors */ }
        }
        else
        {
            // Re-compress the image
            if (_selectedFileBytes is not null && _previewDataUrl is not null)
            {
                await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
                _previewDataUrl = null;
            }

            try
            {
                var mimeType = _selectedFile.ContentType ?? "image/jpeg";
                var compressed = await Js.InvokeAsync<CompressedImageResult>(
                    "mediaHelpers.compressImage", _selectedFileBytes, mimeType, 1600, 0.8);

                if (compressed.Bytes is not null && compressed.Bytes.Length > 0)
                {
                    _selectedFileBytes = compressed.Bytes;
                }
            }
            catch { /* ignore compression errors - use original */ }

            // Show compressed preview
            if (_selectedFileBytes is not null)
            {
                try
                {
                    _previewDataUrl = await Js.InvokeAsync<string>(
                        "mediaHelpers.createObjectUrl", _selectedFileBytes, "image/jpeg");
                }
                catch { /* ignore preview errors */ }
            }
        }
    }

    private void ClearSelectedFile()
    {
        if (_previewDataUrl is not null)
        {
            _ = Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
            _previewDataUrl = null;
        }
        _selectedFile = null;
        _selectedFileBytes = null;
        _selectedContentType = ContentType.Text;
        _sendAsDocument = false;
        _errorMessage = null;
    }

    private void StartRecording()
    {
        _isRecording = true;
    }

    private async Task HandleVoiceRecorded(byte[] audioData)
    {
        _isRecording = false;

        var msg = new ChatInputMessage
        {
            Text = "",
            MediaBytes = audioData,
            FileName = $"voice_{DateTimeOffset.UtcNow:yyyyMMdd_HHmmss}.webm",
            MimeType = "audio/webm",
            ContentType = ContentType.Audio,
            ReplyToMessageId = ReplyContext?.MessageId
        };

        await OnSend.InvokeAsync(msg);
    }

    private static string GetFileIcon(ContentType type)
    {
        return type switch
        {
            ContentType.Audio => "🎵",
            ContentType.Video => "🎬",
            ContentType.Image => "🖼️",
            _ => "📄"
        };
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    public sealed class ChatInputMessage
    {
        public string Text { get; set; } = "";
        public byte[]? MediaBytes { get; set; }
        public string? FileName { get; set; }
        public string? MimeType { get; set; }
        public ContentType ContentType { get; set; } = ContentType.Text;
        public bool SendAsDocument { get; set; }
        public bool HasMedia => MediaBytes is not null;
        public decimal? ReplyToMessageId { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_previewDataUrl is not null)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl); }
            catch { /* ignored */ }
        }
    }

    public sealed class ReplyContextModel
    {
        public decimal MessageId { get; set; }
        public string SenderName { get; set; } = "";
        public string Text { get; set; } = "";
    }
}
