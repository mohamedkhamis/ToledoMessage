<div class="chat-input-area">
    <textarea @bind="messageText"
              @bind:event="oninput"
              @bind:after="HandleTyping"
              @onkeydown="HandleKeyDown"
              placeholder="Type a message..."
              rows="1"
              class="msg-textarea" />
    <button @onclick="SendMessage"
            disabled="@string.IsNullOrWhiteSpace(messageText)"
            class="btn-primary send-btn"
            aria-label="Send message"
            title="Send">
        &#10148;
    </button>
</div>

@code {
    private string messageText = "";

    [Parameter]
    public EventCallback<string> OnSend { get; set; }

    [Parameter]
    public EventCallback OnTyping { get; set; }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        var text = messageText?.Trim();
        if (string.IsNullOrEmpty(text))
            return;

        messageText = "";
        await OnSend.InvokeAsync(text);
    }

    private async Task HandleTyping()
    {
        await OnTyping.InvokeAsync();
    }
}
