    private async Task HandleTyping()
    {
        try
        {
            if (SignalR.IsConnected)
            {
                await SignalR.SendTypingIndicatorAsync(ConversationId);
            }
        }
        catch
        {
            // Typing indicator failures are non-critical
        }
    }

    /// <summary>
    /// Extracts the user ID from a JWT token by decoding the payload.
    /// </summary>
    private static decimal ExtractUserIdFromJwt(string token)
    {
        var parts = token.Split('.');
        if (parts.Length != 3)
            throw new InvalidOperationException("Invalid JWT token format.");

        var payload = parts[1];
        // Fix base64 padding
        switch (payload.Length % 4)
        {
            case 2: payload += "=="; break;
            case 3: payload += "="; break;
        }

        var jsonBytes = Convert.FromBase64String(payload);
        using var doc = JsonDocument.Parse(jsonBytes);
        var root = doc.RootElement;

        // Try "sub" claim first, then "nameid"
        if (root.TryGetProperty("sub", out var subProp))
            return decimal.Parse(subProp.GetString()!);

        if (root.TryGetProperty("nameid", out var nameidProp))
            return decimal.Parse(nameidProp.GetString()!);

        if (root.TryGetProperty("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier", out var fullProp))
            return decimal.Parse(fullProp.GetString()!);

        throw new InvalidOperationException("JWT token does not contain a user ID claim.");
    }

    private MessageInput.ReplyContextModel? replyContext;

    // Reaction state: messageId -> list of (userId, emoji)
    private readonly Dictionary<decimal, List<(decimal UserId, string Emoji, string DisplayName)>> messageReactions = [];

    private void SetReplyTo(ChatMessage msg)
    {
        replyingTo = msg;
        replyContext = new MessageInput.ReplyContextModel
        {
            MessageId = msg.MessageId,
            SenderName = msg.IsMine ? "You" : GetSenderDisplayName(msg),
            Text = msg.ContentType != ContentType.Text ? $"[{msg.ContentType}]" : (msg.Text.Length > 80 ? msg.Text[..80] + "..." : msg.Text)
        };
        showContextMenu = false;
    }

    private void CancelReply()
    {
        replyingTo = null;
        replyContext = null;
    }

    private static string GetSenderDisplayName(ChatMessage msg)
    {
        return msg.ReplyToSenderName ?? "User";
    }

    private void ShowContextMenu(double x, double y, ChatMessage msg)
    {
        contextMenuX = x;
        contextMenuY = y;
        contextMenuMessage = msg;
        showContextMenu = true;
    }

    private void CloseContextMenu()
    {
        showContextMenu = false;
        contextMenuMessage = null;
    }

    private async Task CopyMessageText()
    {
        if (contextMenuMessage is not null)
        {
            try { await Js.InvokeAsync<bool>("mediaHelpers.copyToClipboard", contextMenuMessage.Text); } catch { }
        }
        CloseContextMenu();
    }

    private void ReplyFromContextMenu()
    {
        if (contextMenuMessage is not null)
            SetReplyTo(contextMenuMessage);
        CloseContextMenu();
    }

    private async Task DeleteMessage()
    {
        if (contextMenuMessage is not null && contextMenuMessage.IsMine)
        {
            messages.Remove(contextMenuMessage);
            try { await MessageStore.UpdateMessageStatusAsync(contextMenuMessage.MessageId.ToString(), -1); } catch { }
        }
        CloseContextMenu();
    }

    private async Task ScrollToMessage(decimal messageId)
    {
        try
        {
            await Js.InvokeVoidAsync("eval",
                $"document.querySelector('[data-msg-id=\"{messageId}\"]')?.scrollIntoView({{behavior:'smooth',block:'center'}})");
        }
        catch { }
    }

    private List<MessageBubble.ReactionBadgeModel> GetReactionBadges(decimal messageId)
    {
        if (!messageReactions.TryGetValue(messageId, out var reactions) || reactions.Count == 0)
            return [];

        return reactions
            .GroupBy(r => r.Emoji)
            .Select(g => new MessageBubble.ReactionBadgeModel
            {
                Emoji = g.Key,
                Count = g.Count(),
                IncludesMine = g.Any(r => r.UserId == localUserId)
            })
            .ToList();
    }

    private async Task ToggleReaction(decimal messageId, string emoji)
    {
        try
        {
            if (SignalR.IsConnected)
            {
                // Check if we already reacted with this emoji
                if (messageReactions.TryGetValue(messageId, out var reactions) &&
                    reactions.Any(r => r.UserId == localUserId && r.Emoji == emoji))
                {
                    await SignalR.RemoveReactionAsync(messageId, emoji);
                }
                else
                {
                    await SignalR.AddReactionAsync(messageId, emoji);
                }
            }
        }
        catch { }
    }

    private void HandleImageClick(string imageUrl)
    {
        lightboxImageUrls = messages
            .Where(m => m.ContentType == ContentType.Image && !string.IsNullOrEmpty(m.MediaDataUrl))
            .Select(m => m.MediaDataUrl!)
            .ToList();
        lightboxIndex = lightboxImageUrls.IndexOf(imageUrl);
        if (lightboxIndex < 0) lightboxIndex = 0;
        lightboxVisible = true;
    }

    private void CloseLightbox()
    {
        lightboxVisible = false;
    }

    private void SetLightboxIndex(int index)
    {
        lightboxIndex = index;
    }

    public async ValueTask DisposeAsync()
    {
        // Unsubscribe from events
        SignalR.OnMessageReceived -= HandleMessageReceived;
        SignalR.OnMessageDelivered -= HandleMessageDelivered;
        SignalR.OnMessageRead -= HandleMessageRead;
        SignalR.OnTypingIndicator -= HandleTypingIndicator;
        SignalR.OnParticipantAdded -= HandleParticipantAdded;
        SignalR.OnParticipantRemoved -= HandleParticipantRemoved;
        SignalR.OnUserOnline -= HandleUserOnline;
        SignalR.OnUserOffline -= HandleUserOffline;
        SignalR.OnReactionAdded -= HandleReactionAdded;
        SignalR.OnReactionRemoved -= HandleReactionRemoved;

        typingTimer?.Stop();
        typingTimer?.Dispose();

        // Revoke blob URLs to free browser memory
        await RevokeBlobUrls();

        await SignalR.DisposeAsync();
    }

    /// <summary>
    /// Local view model for a chat message displayed in the UI.
    /// </summary>
    private sealed class ChatMessage
    {
        public decimal MessageId { get; set; }
        public string Text { get; set; } = "";
        public DateTimeOffset Timestamp { get; set; }
        public bool IsMine { get; set; }
        public ToledoMessage.Shared.Enums.DeliveryStatus Status { get; set; }
        public ContentType ContentType { get; set; } = ContentType.Text;
        public string? MediaDataUrl { get; set; }
        public string? FileName { get; set; }
        public decimal? ReplyToMessageId { get; set; }
        public string? ReplyToText { get; set; }
        public string? ReplyToSenderName { get; set; }
    }
}
