@page "/chat/{ConversationId:decimal}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@using System.Text
@using System.Text.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@inject CryptoService Crypto
@inject SignalRService SignalR
@inject LocalStorageService Storage
@inject PreKeyReplenishmentService PreKeyReplenishment
@inject IJSRuntime Js
@inject MessageStoreService MessageStore
@implements IAsyncDisposable

<div class="chat-container">
    <div class="chat-header">
        <a href="/chat" class="back-link back-link-desktop-hidden" aria-label="Back to conversations">&larr;</a>
        @{
            var headerName = conversationDetail?.Type == ConversationType.Group
                ? (conversationDetail.GroupName ?? "Group")
                : (participants.FirstOrDefault(p => p.UserId != localUserId)?.DisplayName ?? "Conversation");
        }
        <AvatarInitials DisplayName="@headerName" Size="38" />
        <div>
            <h3 class="chat-header-title">@headerName</h3>
            @if (conversationDetail is not null && conversationDetail.Type == ConversationType.Group)
            {
                <span class="chat-header-subtitle">@participants.Count members</span>
            }
            else if (peerIsOnline)
            {
                <span class="chat-header-subtitle presence-online">online</span>
            }
            else if (peerLastSeen.HasValue)
            {
                <span class="chat-header-subtitle presence-text">last seen @peerLastSeen.Value.ToLocalTime().ToString("MMM d, HH:mm")</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(typingIndicator))
        {
            <span class="chat-typing-indicator">@typingIndicator</span>
        }
    </div>

    @if (conversationDetail is not null && conversationDetail.Type == ConversationType.Group && showParticipants)
    {
        <div class="participants-panel">
            <div class="participants-list">
                @foreach (var p in participants)
                {
                    <span class="participant-tag">
                        @p.DisplayName
                        @if (p.Role == ParticipantRole.Admin)
                        {
                            <span class="participant-admin">Admin</span>
                        }
                    </span>
                }
            </div>
        </div>
    }

    @if (conversationDetail is not null && conversationDetail.Type == ConversationType.Group)
    {
        <div class="toggle-participants-row">
            <button class="toggle-participants-btn"
                    @onclick="() => showParticipants = !showParticipants">
                @(showParticipants ? "Hide participants" : "Show participants")
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error mx-chat" role="alert">@errorMessage</div>
    }

    <div class="chat-messages" @ref="messageContainer" role="log" aria-live="polite">
        @if (isLoading)
        {
            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.ChatMessages" />
        }
        else if (messages.Count == 0)
        {
            <div class="empty-state">
                <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                </svg>
                <h3>No messages yet</h3>
                <p>Send the first message to start the conversation.</p>
            </div>
        }
        else
        {
            @for (int i = 0; i < messages.Count; i++)
            {
                var msg = messages[i];
                var prevMsg = i > 0 ? messages[i - 1] : null;
                var nextMsg = i < messages.Count - 1 ? messages[i + 1] : null;

                bool showDateSeparator = prevMsg is null ||
                    msg.Timestamp.LocalDateTime.Date != prevMsg.Timestamp.LocalDateTime.Date;

                if (showDateSeparator)
                {
                    <DateSeparator Date="msg.Timestamp" />
                }

                @if (firstUnreadMessageId.HasValue && msg.MessageId == firstUnreadMessageId.Value)
                {
                    var unreadCount = messages.Count - i;
                    <div class="unread-divider">
                        <span>@unreadCount new message@(unreadCount == 1 ? "" : "s")</span>
                    </div>
                }

                bool isFirstInGroup = prevMsg is null || prevMsg.IsMine != msg.IsMine || showDateSeparator;
                bool isLastInGroup = nextMsg is null || nextMsg.IsMine != msg.IsMine ||
                    nextMsg.Timestamp.LocalDateTime.Date != msg.Timestamp.LocalDateTime.Date;

                <MessageBubble Text="@msg.Text"
                               Timestamp="msg.Timestamp"
                               IsMine="msg.IsMine"
                               Status="msg.Status"
                               ContentType="msg.ContentType"
                               MediaDataUrl="@msg.MediaDataUrl"
                               FileName="@msg.FileName"
                               IsFirstInGroup="isFirstInGroup"
                               IsLastInGroup="isLastInGroup"
                               OnImageClick="HandleImageClick"
                               OnReply="() => SetReplyTo(msg)"
                               OnContextMenu="(pos) => ShowContextMenu(pos.X, pos.Y, msg)"
                               ReplyToMessageId="msg.ReplyToMessageId"
                               ReplyToSenderName="@msg.ReplyToSenderName"
                               ReplyToText="@msg.ReplyToText"
                               OnReplyQuoteClick="ScrollToMessage"
                               ReactionBadges="GetReactionBadges(msg.MessageId)"
                               OnReactionToggle="(emoji) => ToggleReaction(msg.MessageId, emoji)" />
            }
        }
    </div>

    <ScrollToBottom Visible="showScrollButton" OnClick="ScrollToBottom" />
    <MessageInput OnSend="HandleSend" OnTyping="HandleTyping"
                  ReplyContext="@replyContext" OnCancelReply="CancelReply" />
</div>

<ImageLightbox IsVisible="lightboxVisible"
               ImageUrls="lightboxImageUrls"
               CurrentIndex="lightboxIndex"
               OnClose="CloseLightbox"
               OnIndexChanged="SetLightboxIndex" />

@if (showContextMenu && contextMenuMessage is not null)
{
    <div class="context-menu-backdrop" @onclick="CloseContextMenu"></div>
    <div class="context-menu" style="left: @(contextMenuX)px; top: @(contextMenuY)px;">
        <button class="context-menu-item" @onclick="CopyMessageText">
            <span class="context-menu-icon">&#128203;</span> Copy
        </button>
        <button class="context-menu-item" @onclick="ReplyFromContextMenu">
            <span class="context-menu-icon">&#8617;</span> Reply
        </button>
        @if (contextMenuMessage.IsMine)
        {
            <button class="context-menu-item danger" @onclick="DeleteMessage">
                <span class="context-menu-icon">&#128465;</span> Delete
            </button>
        }
    </div>
}

@code {
    [Parameter]
    public decimal ConversationId { get; set; }

    private readonly List<ChatMessage> messages = [];
    private ElementReference messageContainer;
    private string? errorMessage;
    private bool isLoading = true;
    private string? typingIndicator;
    private decimal localDeviceId;
    private decimal localUserId;
    private string? accessToken;
    private System.Timers.Timer? typingTimer;
    private ConversationDetailResponse? conversationDetail;
    private List<ParticipantResponse> participants = [];
    private bool showParticipants;
    private bool showScrollButton;
    private decimal? firstUnreadMessageId;
    private bool lightboxVisible;
    private List<string> lightboxImageUrls = [];
    private int lightboxIndex;
    private ChatMessage? replyingTo;

    // Context menu state
    private bool showContextMenu;
    private double contextMenuX;
    private double contextMenuY;
    private ChatMessage? contextMenuMessage;

    // Presence state
    private bool peerIsOnline;
    private DateTimeOffset? peerLastSeen;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Retrieve local deviceId and token from storage
            var deviceIdBytes = await Storage.GetAsync("local.deviceId");
            var tokenBytes = await Storage.GetAsync("auth.token");

            if (deviceIdBytes is null || tokenBytes is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            localDeviceId = decimal.Parse(Encoding.UTF8.GetString(deviceIdBytes));
            accessToken = Encoding.UTF8.GetString(tokenBytes);

            // Extract userId from JWT token
            localUserId = ExtractUserIdFromJwt(accessToken);

            // Set auth header for HTTP requests
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);

            // Initialize message store
            await MessageStore.InitializeAsync();

            // Load conversation details and participants
            await LoadConversationDetails();
            await LoadParticipants();

            // Load cached messages from IndexedDB (instant display)
            await LoadCachedMessages();

            // Load new pending messages from the server
            await LoadPendingMessages();

            // Connect to SignalR hub
            var hubUrl = Navigation.ToAbsoluteUri("/hubs/chat").ToString();
            await SignalR.ConnectAsync(hubUrl, accessToken);
            await SignalR.RegisterDeviceAsync(localDeviceId);

            // Subscribe to real-time events
            SignalR.OnMessageReceived += HandleMessageReceived;
            SignalR.OnMessageDelivered += HandleMessageDelivered;
            SignalR.OnMessageRead += HandleMessageRead;
            SignalR.OnTypingIndicator += HandleTypingIndicator;
            SignalR.OnParticipantAdded += HandleParticipantAdded;
            SignalR.OnParticipantRemoved += HandleParticipantRemoved;
            SignalR.OnUserOnline += HandleUserOnline;
            SignalR.OnUserOffline += HandleUserOffline;
            SignalR.OnReactionAdded += HandleReactionAdded;
            SignalR.OnReactionRemoved += HandleReactionRemoved;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to initialize chat: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadConversationDetails()
    {
        try
        {
            conversationDetail = await Http.GetFromJsonAsync<ConversationDetailResponse>(
                $"/api/conversations/{ConversationId}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load conversation details: {ex.Message}";
        }
    }

    private async Task LoadParticipants()
    {
        try
        {
            participants = await Http.GetFromJsonAsync<List<ParticipantResponse>>(
                $"/api/conversations/{ConversationId}/participants") ?? [];
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load participants: {ex.Message}";
        }
    }

    private async Task LoadCachedMessages()
    {
        try
        {
            var conversationKey = ConversationId.ToString();
            var cached = await MessageStore.GetMessagesAsync(conversationKey);

            foreach (var stored in cached)
            {
                // Skip if already in messages list (shouldn't happen, but guard against duplicates)
                if (messages.Any(m => m.MessageId.ToString() == stored.MessageId))
                    continue;

                messages.Add(new ChatMessage
                {
                    MessageId = decimal.TryParse(stored.MessageId, out var mid) ? mid : 0,
                    Text = stored.Text,
                    Timestamp = DateTimeOffset.TryParse(stored.Timestamp, out var ts) ? ts : DateTimeOffset.UtcNow,
                    IsMine = stored.IsMine,
                    ContentType = (ContentType)stored.ContentType,
                    FileName = stored.FileName,
                    MediaDataUrl = stored.MediaDataBase64 is not null
                        ? await CreateMediaBlobUrlFromBase64(stored.MediaDataBase64, stored.FileName)
                        : null,
                    Status = (ToledoMessage.Shared.Enums.DeliveryStatus)stored.Status,
                    ReplyToMessageId = decimal.TryParse(stored.ReplyToMessageId, out var rid) ? rid : null,
                    ReplyToText = stored.ReplyToText,
                    ReplyToSenderName = stored.ReplyToSenderName
                });
            }
        }
        catch
        {
            // Non-critical: will still load from server
        }
    }

    private async Task<string?> CreateMediaBlobUrlFromBase64(string base64Data, string? fileName)
    {
        try
        {
            var bytes = Convert.FromBase64String(base64Data);
            var mimeType = fileName is not null ? GetMimeTypeFromFileName(fileName) : "application/octet-stream";
            return await CreateMediaBlobUrl(mimeType, bytes);
        }
        catch
        {
            return null;
        }
    }

    private static string GetMimeTypeFromFileName(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName)?.ToLowerInvariant();
        return ext switch
        {
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".webp" => "image/webp",
            ".mp4" => "video/mp4",
            ".webm" => "video/webm",
            ".mp3" => "audio/mpeg",
            ".ogg" => "audio/ogg",
            ".wav" => "audio/wav",
            ".pdf" => "application/pdf",
            _ => "application/octet-stream"
        };
    }

    private async Task LoadPendingMessages()
    {
        try
        {
            var envelopes = await Http.GetFromJsonAsync<List<MessageEnvelope>>(
                $"/api/messages/pending?deviceId={localDeviceId}");

            if (envelopes is null)
                return;

            foreach (var envelope in envelopes.Where(e => e.ConversationId == ConversationId))
            {
                // Skip if already loaded from cache
                if (messages.Any(m => m.MessageId == envelope.MessageId))
                {
                    // Still acknowledge
                    try { await Http.PostAsync($"/api/messages/{envelope.MessageId}/acknowledge", null); } catch { }
                    continue;
                }

                ChatMessage chatMsg;
                try
                {
                    chatMsg = await DecryptEnvelopeToChatMessage(envelope, isMine: false);
                }
                catch (Exception)
                {
                    chatMsg = new ChatMessage
                    {
                        MessageId = envelope.MessageId,
                        Text = "[Unable to decrypt message]",
                        Timestamp = envelope.ServerTimestamp,
                        IsMine = false,
                        ContentType = ContentType.Text,
                        Status = ToledoMessage.Shared.Enums.DeliveryStatus.Delivered
                    };
                }

                messages.Add(chatMsg);

                // Track the first new unread message for the divider
                if (!chatMsg.IsMine && !firstUnreadMessageId.HasValue)
                {
                    firstUnreadMessageId = chatMsg.MessageId;
                }

                // Persist to IndexedDB
                await PersistMessageAsync(chatMsg);

                // Always acknowledge
                try
                {
                    await Http.PostAsync(
                        $"/api/messages/{envelope.MessageId}/acknowledge", null);
                }
                catch
                {
                    // Best-effort; will retry on next load
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load messages: {ex.Message}";
        }
    }

    private async Task PersistMessageAsync(ChatMessage chatMsg)
    {
        try
        {
            await MessageStore.StoreMessageAsync(new StoredMessage
            {
                MessageId = chatMsg.MessageId.ToString(),
                ConversationId = ConversationId.ToString(),
                Text = chatMsg.Text,
                Timestamp = chatMsg.Timestamp.ToString("O"),
                IsMine = chatMsg.IsMine,
                ContentType = (int)chatMsg.ContentType,
                FileName = chatMsg.FileName,
                Status = (int)chatMsg.Status,
                ReplyToMessageId = chatMsg.ReplyToMessageId?.ToString(),
                ReplyToText = chatMsg.ReplyToText,
                ReplyToSenderName = chatMsg.ReplyToSenderName
            });
        }
        catch
        {
            // Non-critical: message is still in memory
        }
    }

    private async void HandleMessageReceived(MessageEnvelope envelope)
    {
        if (envelope.ConversationId != ConversationId)
            return;

        try
        {
            await InvokeAsync(async () =>
            {
                // Skip duplicates
                if (messages.Any(m => m.MessageId == envelope.MessageId))
                    return;

                ChatMessage chatMsg;
                try
                {
                    chatMsg = await DecryptEnvelopeToChatMessage(envelope, isMine: false);
                }
                catch
                {
                    chatMsg = new ChatMessage
                    {
                        MessageId = envelope.MessageId,
                        Text = "[Unable to decrypt message]",
                        Timestamp = envelope.ServerTimestamp,
                        IsMine = false,
                        ContentType = ContentType.Text,
                        Status = ToledoMessage.Shared.Enums.DeliveryStatus.Delivered
                    };
                }

                messages.Add(chatMsg);
                await PersistMessageAsync(chatMsg);
                StateHasChanged();
            });

            // Always acknowledge — even if decryption failed.
            // Lost ratchet keys can never be recovered.
            await SignalR.AcknowledgeDeliveryAsync(envelope.MessageId);
        }
        catch
        {
            // Prevent async void from crashing the WASM runtime
        }
    }

    private async void HandleMessageDelivered(decimal messageId)
    {
        await InvokeAsync(async () =>
        {
            var msg = messages.FirstOrDefault(m => m.MessageId == messageId);
            if (msg is not null)
            {
                msg.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Delivered;
                try { await MessageStore.UpdateMessageStatusAsync(messageId.ToString(), (int)msg.Status); } catch { }
                StateHasChanged();
            }
        });
    }

    private async void HandleMessageRead(decimal messageId)
    {
        await InvokeAsync(async () =>
        {
            var msg = messages.FirstOrDefault(m => m.MessageId == messageId);
            if (msg is not null)
            {
                msg.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Read;
                try { await MessageStore.UpdateMessageStatusAsync(messageId.ToString(), (int)msg.Status); } catch { }
                StateHasChanged();
            }
        });
    }

    private async void HandleTypingIndicator(decimal conversationId, string displayName)
    {
        if (conversationId != ConversationId)
            return;

        await InvokeAsync(() =>
        {
            typingIndicator = $"{displayName} is typing...";
            StateHasChanged();
        });

        // Clear typing indicator after 3 seconds
        typingTimer?.Stop();
        typingTimer?.Dispose();
        typingTimer = new System.Timers.Timer(3000);
        typingTimer.AutoReset = false;
        typingTimer.Elapsed += async (_, _) =>
        {
            await InvokeAsync(() =>
            {
                typingIndicator = null;
                StateHasChanged();
            });
        };
        typingTimer.Start();
    }

    private async void HandleParticipantAdded(decimal conversationId, decimal userId, string displayName)
    {
        if (conversationId != ConversationId)
            return;

        await InvokeAsync(() =>
        {
            // Add to the local participant list if not already present
            if (!participants.Any(p => p.UserId == userId))
            {
                participants.Add(new ParticipantResponse(userId, displayName, ParticipantRole.Member));
            }
            StateHasChanged();
        });
    }

    private async void HandleParticipantRemoved(decimal conversationId, decimal userId)
    {
        if (conversationId != ConversationId)
            return;

        await InvokeAsync(() =>
        {
            participants.RemoveAll(p => p.UserId == userId);
            StateHasChanged();
        });
    }

    private async void HandleUserOnline(decimal userId)
    {
        var peer = participants.FirstOrDefault(p => p.UserId != localUserId);
        if (peer is not null && peer.UserId == userId)
        {
            await InvokeAsync(() =>
            {
                peerIsOnline = true;
                StateHasChanged();
            });
        }
    }

    private async void HandleUserOffline(decimal userId, DateTimeOffset lastSeen)
    {
        var peer = participants.FirstOrDefault(p => p.UserId != localUserId);
        if (peer is not null && peer.UserId == userId)
        {
            await InvokeAsync(() =>
            {
                peerIsOnline = false;
                peerLastSeen = lastSeen;
                StateHasChanged();
            });
        }
    }

    private async void HandleReactionAdded(decimal messageId, decimal userId, string displayName, string emoji)
    {
        await InvokeAsync(() =>
        {
            if (!messageReactions.TryGetValue(messageId, out var reactions))
            {
                reactions = [];
                messageReactions[messageId] = reactions;
            }

            if (!reactions.Any(r => r.UserId == userId && r.Emoji == emoji))
            {
                reactions.Add((userId, emoji, displayName));
            }

            StateHasChanged();
        });
    }

    private async void HandleReactionRemoved(decimal messageId, decimal userId, string emoji)
    {
        await InvokeAsync(() =>
        {
            if (messageReactions.TryGetValue(messageId, out var reactions))
            {
                reactions.RemoveAll(r => r.UserId == userId && r.Emoji == emoji);
            }

            StateHasChanged();
        });
    }

    private async Task HandleSend(MessageInput.ChatInputMessage input)
    {
        var hasMedia = input.HasMedia;
        var tempMessage = new ChatMessage
        {
            MessageId = 0,
            Text = input.Text,
            Timestamp = DateTimeOffset.UtcNow,
            IsMine = true,
            ContentType = input.ContentType,
            FileName = input.FileName,
            MediaDataUrl = hasMedia ? await CreateMediaBlobUrl(input.MimeType!, input.MediaBytes!) : null,
            Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sending,
            ReplyToMessageId = replyingTo?.MessageId,
            ReplyToSenderName = replyingTo is not null ? (replyingTo.IsMine ? "You" : GetSenderDisplayName(replyingTo)) : null,
            ReplyToText = replyingTo is not null ? (replyingTo.ContentType != ContentType.Text ? $"[{replyingTo.ContentType}]" : (replyingTo.Text.Length > 80 ? replyingTo.Text[..80] + "..." : replyingTo.Text)) : null
        };
        CancelReply();
        messages.Add(tempMessage);
        StateHasChanged();

        try
        {
            // When there's media, we send the media as the encrypted payload.
            // The text caption is sent alongside as plain metadata (not encrypted separately).
            // When there's text only, we send a normal text message.
            if (hasMedia)
            {
                await SendMediaToRecipients(input, tempMessage);
            }
            else
            {
                await SendTextToRecipients(input.Text, tempMessage, input.ReplyToMessageId);
            }

            // Persist sent message to IndexedDB
            await PersistMessageAsync(tempMessage);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to send message: {ex.Message}";
        }

        StateHasChanged();
    }

    private async Task SendTextToRecipients(string text, ChatMessage tempMessage, decimal? replyToMessageId = null)
    {
        if (conversationDetail is not null && conversationDetail.Type == ConversationType.Group)
        {
            var requests = await Crypto.EncryptGroupMessageAsync(ConversationId, localUserId, localDeviceId, text);

            SendMessageResult? lastResult = null;
            foreach (var request in requests)
            {
                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sent;
            }
        }
        else
        {
            var recipient = participants.FirstOrDefault(p => p.UserId != localUserId);
            if (recipient is null)
            {
                errorMessage = "Could not determine the recipient.";
                return;
            }

            var deviceCiphertexts = await Crypto.EncryptMessageForAllDevicesAsync(recipient.UserId, text);

            SendMessageResult? lastResult = null;
            foreach (var (deviceId, ciphertextBase64, messageType) in deviceCiphertexts)
            {
                var request = new SendMessageRequest(
                    ConversationId,
                    localDeviceId,
                    deviceId,
                    ciphertextBase64,
                    messageType,
                    ContentType.Text,
                    ReplyToMessageId: replyToMessageId);

                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sent;
            }
        }
    }

    private async Task SendMediaToRecipients(MessageInput.ChatInputMessage input, ChatMessage tempMessage)
    {
        if (conversationDetail is not null && conversationDetail.Type == ConversationType.Group)
        {
            var requests = await Crypto.EncryptGroupBytesAsync(
                ConversationId, localUserId, localDeviceId,
                input.MediaBytes!, input.ContentType, input.FileName, input.MimeType);

            SendMessageResult? lastResult = null;
            foreach (var request in requests)
            {
                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sent;
            }
        }
        else
        {
            var recipient = participants.FirstOrDefault(p => p.UserId != localUserId);
            if (recipient is null)
            {
                errorMessage = "Could not determine the recipient.";
                return;
            }

            var deviceCiphertexts = await Crypto.EncryptBytesForAllDevicesAsync(recipient.UserId, input.MediaBytes!);

            SendMessageResult? lastResult = null;
            foreach (var (deviceId, ciphertextBase64, messageType) in deviceCiphertexts)
            {
                var request = new SendMessageRequest(
                    ConversationId,
                    localDeviceId,
                    deviceId,
                    ciphertextBase64,
                    messageType,
                    input.ContentType,
                    input.FileName,
                    input.MimeType,
                    input.ReplyToMessageId);

                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sent;
            }
        }

        // If there's also a text caption, send it as a separate text message right after
        if (!string.IsNullOrEmpty(input.Text))
        {
            var captionMessage = new ChatMessage
            {
                MessageId = 0,
                Text = input.Text,
                Timestamp = DateTimeOffset.UtcNow,
                IsMine = true,
                ContentType = ContentType.Text,
                Status = ToledoMessage.Shared.Enums.DeliveryStatus.Sending
            };
            messages.Add(captionMessage);
            StateHasChanged();

            await SendTextToRecipients(input.Text, captionMessage);
        }
    }

    private async Task<ChatMessage> DecryptEnvelopeToChatMessage(MessageEnvelope envelope, bool isMine)
    {
        // Resolve reply info from local messages
        string? replyToText = null;
        string? replyToSenderName = null;
        if (envelope.ReplyToMessageId.HasValue)
        {
            var replyMsg = messages.FirstOrDefault(m => m.MessageId == envelope.ReplyToMessageId.Value);
            if (replyMsg is not null)
            {
                replyToSenderName = replyMsg.IsMine ? "You" : GetSenderDisplayName(replyMsg);
                replyToText = replyMsg.ContentType != ContentType.Text ? $"[{replyMsg.ContentType}]" : (replyMsg.Text.Length > 80 ? replyMsg.Text[..80] + "..." : replyMsg.Text);
            }
            else
            {
                replyToSenderName = "...";
                replyToText = "...";
            }
        }

        if (envelope.ContentType is ContentType.Image or ContentType.Audio or ContentType.Video or ContentType.File)
        {
            var bytes = await Crypto.DecryptToBytesAsync(
                envelope.SenderDeviceId, envelope.Ciphertext, envelope.MessageType);
            var mimeType = envelope.MimeType ?? GetDefaultMimeType(envelope.ContentType);
            var blobUrl = await CreateMediaBlobUrl(mimeType, bytes);
            return new ChatMessage
            {
                MessageId = envelope.MessageId,
                Text = "",
                Timestamp = envelope.ServerTimestamp,
                IsMine = isMine,
                ContentType = envelope.ContentType,
                FileName = envelope.FileName,
                MediaDataUrl = blobUrl,
                Status = ToledoMessage.Shared.Enums.DeliveryStatus.Delivered,
                ReplyToMessageId = envelope.ReplyToMessageId,
                ReplyToText = replyToText,
                ReplyToSenderName = replyToSenderName
            };
        }
        else
        {
            var plaintext = await Crypto.DecryptMessageAsync(
                envelope.SenderDeviceId, envelope.Ciphertext, envelope.MessageType);
            return new ChatMessage
            {
                MessageId = envelope.MessageId,
                Text = plaintext,
                Timestamp = envelope.ServerTimestamp,
                IsMine = isMine,
                ContentType = ContentType.Text,
                Status = ToledoMessage.Shared.Enums.DeliveryStatus.Delivered,
                ReplyToMessageId = envelope.ReplyToMessageId,
                ReplyToText = replyToText,
                ReplyToSenderName = replyToSenderName
            };
        }
    }

    private static string GetDefaultMimeType(ContentType contentType)
    {
        return contentType switch
        {
            ContentType.Image => "image/png",
            ContentType.Audio => "audio/mpeg",
            ContentType.Video => "video/mp4",
            ContentType.File => "application/octet-stream",
            _ => "application/octet-stream"
        };
    }

    private readonly List<string> blobUrls = [];

    private async Task<string> CreateMediaBlobUrl(string mimeType, byte[] data)
    {
        var url = await Js.InvokeAsync<string>("mediaHelpers.createObjectUrl", data, mimeType);
        blobUrls.Add(url);
        return url;
    }

    private async Task RevokeBlobUrls()
    {
        foreach (var url in blobUrls)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", url); } catch { }
        }
        blobUrls.Clear();
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Js.InvokeVoidAsync("eval",
                "document.querySelector('.chat-messages')?.scrollTo({top: document.querySelector('.chat-messages').scrollHeight, behavior: 'smooth'})");
            showScrollButton = false;
        }
        catch { }
    }

    [JSInvokable]
    public void OnScrollPositionChanged(bool isNearBottom)
    {
