    private async Task ClearChat(TimeSpan span)
    {
        _showClearChatDialog = false;
        // For "all messages" (TimeSpan.Zero), use far future cutoff to delete everything
        // For time-bounded, cutoff = now so server deletes up to now
        var cutoff = DateTimeOffset.UtcNow.AddYears(1);
        var threshold = DateTimeOffset.MinValue;

        if (span != TimeSpan.Zero)
        {
            threshold = DateTimeOffset.UtcNow - span;
            cutoff = DateTimeOffset.UtcNow;
        }

        // Revoke blob URLs for messages being removed
        foreach (var msg in _messages.Where(m => m.Timestamp >= threshold && !string.IsNullOrEmpty(m.MediaDataUrl)))
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", msg.MediaDataUrl); }
            catch
            {
                // ignored
            }
        }

        // Remove from local UI
        _messages.RemoveAll(m => m.Timestamp >= threshold);
        _messageReactions.Clear();

        // Clear from IndexedDB (delete messages within the time range)
        try { await MessageStore.DeleteConversationMessagesAsync(ConversationId.ToString(CultureInfo.InvariantCulture), threshold); }
        catch
        {
            // ignored
        }

        // Clear from server
        try { await SignalR.ClearMessagesAsync(ConversationId, threshold, cutoff); }
        catch
        {
            // ignored
        }

        StateHasChanged();
    }

