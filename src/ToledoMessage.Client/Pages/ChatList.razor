@page "/chat"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using ToledoMessage.Client.Components
@inject NavigationManager Navigation

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
    <h2 style="margin:0;">Conversations</h2>
    <button class="btn-primary" @onclick="NavigateToNewConversation">
        + New Conversation
    </button>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    @if (conversations is not null && conversations.Count > 0)
    {
        <div class="conversation-list">
            @foreach (var conversation in conversations)
            {
                <ConversationListItem ConversationId="conversation.ConversationId"
                                      DisplayName="@conversation.DisplayName"
                                      LastMessage="@conversation.LastMessage"
                                      UnreadCount="conversation.UnreadCount"
                                      LastMessageTime="conversation.LastMessageTime" />
            }
        </div>
    }
    else
    {
        <div style="padding:48px 24px; text-align:center;">
            <p style="color:var(--gray-500); margin-bottom:16px;">No conversations yet</p>
            <button class="btn-outline" @onclick="NavigateToNewConversation">
                Start your first conversation
            </button>
        </div>
    }
</div>

@code {
    private List<ConversationSummary>? conversations;

    protected override void OnInitialized()
    {
        conversations = [];
    }

    private void NavigateToNewConversation()
    {
        Navigation.NavigateTo("/new-conversation");
    }

    private sealed class ConversationSummary
    {
        public decimal ConversationId { get; init; }
        public string DisplayName { get; init; } = "";
        public string? LastMessage { get; init; }
        public int UnreadCount { get; init; }
        public DateTimeOffset? LastMessageTime { get; init; }
    }
}
