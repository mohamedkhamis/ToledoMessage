@page "/login"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Globalization
@using System.Text
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LocalStorageService Storage
@inject KeyGenerationService KeyGenService
@inject IJSRuntime Js
@inject ThemeService Theme
@inject PreferencesService Preferences
@inject KeyBackupService KeyBackup

<div class="auth-page fade-in">
    <h2>Sign In</h2>

    <div class="card">
        <div class="auth-status-area" style="min-height:48px;">
            <div class="alert alert-error @(string.IsNullOrEmpty(_errorMessage) ? "alert-hidden" : "")" role="alert">
                @(_errorMessage ?? "\u00A0")
            </div>
            <div class="alert alert-info @(string.IsNullOrEmpty(_statusMessage) ? "alert-hidden" : "")" role="status">
                @(_statusMessage ?? "\u00A0")
            </div>
        </div>

        <form @onsubmit="HandleLogin">
            <div class="form-group">
                <label for="displayName">Display Name</label>
                <input id="displayName" @bind="_displayName" placeholder="Enter your display name"
                       autocomplete="username" required aria-required="true" />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input id="password" type="password" @bind="_password" placeholder="Enter your password"
                       autocomplete="current-password" required aria-required="true" />
            </div>
            <button type="submit" class="btn-primary btn-full" disabled="@_isLoading"
                    aria-busy="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner spinner-sm"></span>
                    <text> Signing in...</text>
                }
                else
                {
                    <text>Sign In</text>
                }
            </button>
        </form>
    </div>

    <p class="auth-footer">Don't have an account? <a href="/register">Create one</a></p>

    <div class="app-version-footer">Toledo Message v@(AppVersion.Current)</div>
</div>

@code {
    private string _displayName = "";
    private string _password = "";
    private string? _errorMessage;
    private string? _statusMessage;
    private bool _isLoading;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        if (uri.Query.Contains("logout", StringComparison.OrdinalIgnoreCase))
        {
            // Clear auth and crypto data but preserve UI preferences (theme, fontSize)
            await Js.InvokeVoidAsync("toledoStorage.clearAuthData");
            Http.DefaultRequestHeaders.Authorization = null;
        }
    }

    private async Task HandleLogin()
    {
        _isLoading = true;
        _errorMessage = null;
        _statusMessage = null;

        try
        {
            // 1. Authenticate
            var request = new LoginRequest(_displayName, _password);
            var response = await Http.PostAsJsonAsync("/api/auth/login", request);

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Invalid credentials.";
                return;
            }

            var authResponse = await response.Content.ReadFromJsonAsync<AuthResponse>();
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", authResponse!.Token);

            // 2. Store auth token
            await Storage.StoreAsync("auth.token", Encoding.UTF8.GetBytes(authResponse.Token));

            // 3. Sync user preferences from server
            try
            {
                var prefs = await Preferences.GetPreferencesAsync();
                await Theme.SetThemeAsync(prefs.Theme);
                await Theme.SetFontSizeAsync(prefs.FontSize);
            }
            catch
            {
                // Non-critical: preferences will use local defaults
            }

            // 4. Check if we already have a deviceId stored (returning to same browser)
            var existingDeviceId = await Storage.GetAsync("local.deviceId");
            if (existingDeviceId is not null)
            {
                // Validate the stored device still exists on the server
                var storedId = Encoding.UTF8.GetString(existingDeviceId);
                var devicesResponse = await Http.GetAsync("/api/devices");
                if (devicesResponse.IsSuccessStatusCode)
                {
                    var devices = await devicesResponse.Content.ReadFromJsonAsync<List<DeviceInfoResponse>>();
                    var stillValid = devices?.Any(d =>
                        d.DeviceId.ToString(CultureInfo.InvariantCulture) == storedId) == true;

                    if (stillValid)
                    {
                        Navigation.NavigateTo("/chat");
                        return;
                    }
                }
                else
                {
                    // Can't verify — assume valid to avoid blocking login
                    Navigation.NavigateTo("/chat");
                    return;
                }

                // Device no longer exists on server — clear stale data and re-register below
                await Js.InvokeVoidAsync("toledoStorage.clearAuthData");
                await Storage.StoreAsync("auth.token", Encoding.UTF8.GetBytes(authResponse.Token));
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", authResponse.Token);
            }

            // 5. New device: check shared keys preference and try restore
            _statusMessage = "Setting up encryption keys...";
            StateHasChanged();

            DeviceRegistrationRequest deviceRequest;
            var prefs2 = await Preferences.GetPreferencesAsync();

            if (prefs2.SharedKeysEnabled)
            {
                // Try to restore keys from server backup
                try
                {
                    var restored = await KeyBackup.TryRestoreBackupAsync(_password);
                    if (restored is not null)
                    {
                        // Keys restored from backup — generate fresh pre-keys with shared identity
                        _statusMessage = "Restoring encryption keys...";
                        StateHasChanged();
                        deviceRequest = await KeyGenService.RestoreKeysAndBuildRequest(restored, "Web Browser");
                    }
                    else
                    {
                        // No backup exists (first device) — generate new keys and upload backup
                        _statusMessage = "Generating encryption keys...";
                        StateHasChanged();
                        deviceRequest = await KeyGenService.GenerateAndStoreKeys("Web Browser");
                    }
                }
                catch
                {
                    // Backup restore failed — fall back to fresh keys
                    _statusMessage = "Generating encryption keys...";
                    StateHasChanged();
                    deviceRequest = await KeyGenService.GenerateAndStoreKeys("Web Browser");
                }
            }
            else
            {
                // Shared keys disabled — generate fresh keys (original behavior)
                _statusMessage = "Generating encryption keys...";
                StateHasChanged();
                deviceRequest = await KeyGenService.GenerateAndStoreKeys("Web Browser");
            }

            var deviceResponse = await Http.PostAsJsonAsync("/api/devices", deviceRequest);

            if (!deviceResponse.IsSuccessStatusCode)
            {
                var errorBody = await deviceResponse.Content.ReadAsStringAsync();
                _errorMessage = $"Device registration failed: {errorBody}";
                return;
            }

            var deviceResult = await deviceResponse.Content.ReadFromJsonAsync<DeviceRegistrationResult>();
            if (deviceResult is not null)
            {
                await Storage.StoreAsync("local.deviceId", Encoding.UTF8.GetBytes(deviceResult.DeviceId.ToString(CultureInfo.InvariantCulture)));
            }

            // 6. Upload backup if shared keys enabled and this is the first device (no backup existed)
            if (prefs2.SharedKeysEnabled)
            {
                try
                {
                    await KeyBackup.UploadBackupAsync(_password);
                }
                catch
                {
                    // Non-critical: backup upload failure doesn't block login
                }
            }

            // 7. Navigate to chat
            Navigation.NavigateTo("/chat");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed record DeviceRegistrationResult(decimal DeviceId);
}
