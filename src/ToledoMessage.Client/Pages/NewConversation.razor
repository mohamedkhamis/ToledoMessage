@page "/new-conversation"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@implements IDisposable
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LocalStorageService Storage
@using ToledoMessage.Shared.Helpers
@inject IStringLocalizer<SharedResource> Loc

<div class="panel-content-scroll">

@if (!_isAuthenticated)
{
    <p class="centered-text"><span class="spinner"></span> @Loc["Loading..."]</p>
}
else
{
<div class="page-header">
    <button class="back-link back-link-desktop-hidden" @onclick="GoBackToChat" aria-label="Back to conversations">&larr;</button>
    <h2>@Loc["NewConversationTitle"]</h2>
</div>

<div class="card mb-md">
    <div class="form-group mb-0">
        <input placeholder="@Loc["Search by name or @username..."]"
               @bind="_searchQuery"
               @bind:event="oninput"
               @bind:after="OnSearchInputChanged"
               aria-label="Search users" />
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-error">@_errorMessage</div>
}

@if (_isSearching)
{
    <p class="centered-text"><span class="spinner"></span> @Loc["Searching..."]</p>
}
else if (_searchResults is not null && _searchResults.Count > 0)
{
    <div class="card card-flush">
        @foreach (var user in _searchResults)
        {
            <div class="search-result-item">
                <div>
                    <span class="search-result-name">@DisplayNameHelper.Resolve(user.DisplayName, user.DisplayNameSecondary)</span>
                    <span class="search-result-meta">@@@user.Username · @string.Format(Loc["{0} device(s)"], user.DeviceCount)</span>
                </div>
                <button class="btn-primary btn-sm"
                        @onclick="() => StartConversation(user)"
                        disabled="@_isCreating">
                    @(_isCreating && _creatingUserId == user.UserId ? Loc["Creating..."] : Loc["Message"])
                </button>
            </div>
        }
    </div>
}
else if (_searchResults is not null && _searchResults.Count == 0 && !string.IsNullOrWhiteSpace(_searchQuery))
{
    <p class="centered-text">@Loc["No users found."]</p>
}
}

</div>

@code {
    private bool _isAuthenticated;
    private string _searchQuery = "";
    private string? _errorMessage;
    private bool _isSearching;

    private void GoBackToChat()
    {
        Navigation.NavigateTo("/chat");
    }

    private bool _isCreating;
    private long? _creatingUserId;
    private List<UserSearchResult>? _searchResults;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync()
    {
        var tokenBytes = await Storage.GetAsync("auth.token");
        if (tokenBytes is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }
        _isAuthenticated = true;
    }

    private async Task OnSearchInputChanged()
    {
        // Safely cancel previous search
        if (_debounceCts is { } oldCts)
        {
            try { await oldCts.CancelAsync(); }
            catch
            {
                // ignored
            }

            try { oldCts.Dispose(); }
            catch
            {
                // ignored
            }
        }
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        // Strip @ prefix if present (Telegram-style search)
        var searchQuery = (_searchQuery).TrimStart('@');

        if (string.IsNullOrWhiteSpace(searchQuery) || searchQuery.Length < 2)
        {
            _searchResults = null;
            return;
        }

        try
        {
            await Task.Delay(300, token);

            if (token.IsCancellationRequested)
                return;

            _isSearching = true;
            _errorMessage = null;
            StateHasChanged();

            var response = await Http.GetFromJsonAsync<UserSearchResponse>(
                $"/api/users/search?q={Uri.EscapeDataString(searchQuery)}", token);

            if (!token.IsCancellationRequested)
            {
                _searchResults = response?.Users ?? [];
            }
        }
        catch (OperationCanceledException)
        {
            // Debounce cancelled
        }
        catch (Exception ex)
        {
            if (!token.IsCancellationRequested)
            {
                _errorMessage = string.Format(Loc["SearchFailed"], ex.Message);
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isSearching = false;
                StateHasChanged();
            }
        }
    }

    private async Task StartConversation(UserSearchResult user)
    {
        _isCreating = true;
        _creatingUserId = user.UserId;
        _errorMessage = null;

        try
        {
            var request = new CreateConversationRequest(user.UserId);
            var response = await Http.PostAsJsonAsync("/api/conversations", request);

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = Loc["Failed to create conversation."];
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ConversationResponse>();
            if (result is not null)
            {
                Navigation.NavigateTo($"/chat/{result.ConversationId}");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(Loc["Error: {0}"], ex.Message);
        }
        finally
        {
            _isCreating = false;
            _creatingUserId = null;
        }
    }

    public void Dispose()
    {
        // BUG-CR-009 FIX: Cancel and dispose the debounce CTS
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}
