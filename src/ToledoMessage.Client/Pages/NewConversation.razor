@page "/new-conversation"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@inject HttpClient Http
@inject NavigationManager Navigation
@inject LocalStorageService Storage

<div class="panel-content-scroll">

@if (!_isAuthenticated)
{
    <p class="centered-text"><span class="spinner"></span> Loading...</p>
}
else
{
<div class="page-header">
    <button class="back-link back-link-desktop-hidden" @onclick="GoBackToChat" aria-label="Back to conversations">&larr;</button>
    <h2>New Conversation</h2>
</div>

<div class="card mb-md">
    <div class="form-group mb-0">
        <input placeholder="Search users by name..."
               @bind="_searchQuery"
               @bind:event="oninput"
               @bind:after="OnSearchInputChanged"
               aria-label="Search users" />
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-error">@_errorMessage</div>
}

@if (_isSearching)
{
    <p class="centered-text"><span class="spinner"></span> Searching...</p>
}
else if (_searchResults is not null && _searchResults.Count > 0)
{
    <div class="card card-flush">
        @foreach (var user in _searchResults)
        {
            <div class="search-result-item">
                <div>
                    <span class="search-result-name">@user.DisplayName</span>
                    <span class="search-result-meta">@user.DeviceCount device(s)</span>
                </div>
                <button class="btn-primary btn-sm"
                        @onclick="() => StartConversation(user)"
                        disabled="@_isCreating">
                    @(_isCreating && _creatingUserId == user.UserId ? "Creating..." : "Message")
                </button>
            </div>
        }
    </div>
}
else if (_searchResults is not null && _searchResults.Count == 0 && !string.IsNullOrWhiteSpace(_searchQuery))
{
    <p class="centered-text">No users found.</p>
}
}

</div>

@code {
    private bool _isAuthenticated;
    private string _searchQuery = "";
    private string? _errorMessage;
    private bool _isSearching;

    private void GoBackToChat()
    {
        Navigation.NavigateTo("/chat");
    }

    private bool _isCreating;
    private decimal? _creatingUserId;
    private List<UserSearchResult>? _searchResults;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync()
    {
        var tokenBytes = await Storage.GetAsync("auth.token");
        if (tokenBytes is null)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }
        _isAuthenticated = true;
    }

    private async Task OnSearchInputChanged()
    {
        await _debounceCts?.CancelAsync()!;
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        if (string.IsNullOrWhiteSpace(_searchQuery) || _searchQuery.Length < 2)
        {
            _searchResults = null;
            return;
        }

        try
        {
            await Task.Delay(300, token);

            if (token.IsCancellationRequested)
                return;

            _isSearching = true;
            _errorMessage = null;
            StateHasChanged();

            var response = await Http.GetFromJsonAsync<UserSearchResponse>(
                $"/api/users/search?q={Uri.EscapeDataString(_searchQuery)}", token);

            if (!token.IsCancellationRequested)
            {
                _searchResults = response?.Users ?? [];
            }
        }
        catch (OperationCanceledException)
        {
            // Debounce cancelled
        }
        catch (Exception ex)
        {
            if (!token.IsCancellationRequested)
            {
                _errorMessage = $"Search failed: {ex.Message}";
            }
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isSearching = false;
                StateHasChanged();
            }
        }
    }

    private async Task StartConversation(UserSearchResult user)
    {
        _isCreating = true;
        _creatingUserId = user.UserId;
        _errorMessage = null;

        try
        {
            var request = new CreateConversationRequest(user.UserId);
            var response = await Http.PostAsJsonAsync("/api/conversations", request);

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to create conversation.";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ConversationResponse>();
            if (result is not null)
            {
                Navigation.NavigateTo($"/chat/{result.ConversationId}");
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isCreating = false;
            _creatingUserId = null;
        }
    }
}
