@page "/register"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Globalization
@using System.Text
@inject HttpClient Http
@inject NavigationManager Navigation
@inject KeyGenerationService KeyGenService
@inject LocalStorageService Storage

<div class="auth-page fade-in">
    <h2>Create Account</h2>

    <div class="card">
        <div class="auth-status-area" style="min-height:48px;">
            <div class="alert alert-error @(string.IsNullOrEmpty(_errorMessage) ? "alert-hidden" : "")" role="alert">
                @(_errorMessage ?? "\u00A0")
            </div>
        </div>

        <form @onsubmit="HandleRegister">
            <div class="form-group">
                <label for="displayName">Display Name</label>
                <input id="displayName" @bind="_displayName" placeholder="Choose a display name"
                       autocomplete="username" required aria-required="true" />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <div class="password-wrapper">
                    <input id="password" type="password" @bind="_password" @bind:event="oninput"
                           @bind:after="OnPasswordChanged"
                           placeholder="Minimum 8 characters"
                           autocomplete="new-password" required aria-required="true" />
                </div>
                <div class="strength-bar">
                    <div class="strength-bar-fill @_passwordStrengthClass"></div>
                </div>
                @if (!string.IsNullOrEmpty(_passwordStrengthText))
                {
                    <div class="strength-text" style="color: @_passwordStrengthColor">@_passwordStrengthText</div>
                }
            </div>
            <button type="submit" class="btn-primary btn-full" disabled="@_isLoading"
                    aria-busy="@_isLoading">
                @if (_isLoading)
                {
                    <span class="spinner spinner-sm"></span>
                    <text> Creating account...</text>
                }
                else
                {
                    <text>Create Account</text>
                }
            </button>
        </form>
    </div>

    <p class="auth-footer">Already have an account? <a href="/login">Sign in</a></p>

    <div class="app-version-footer">Toledo Message v@(AppVersion.Current)</div>
</div>

@code {
    private string _displayName = "";
    private string _password = "";
    private string? _errorMessage;
    private bool _isLoading;
    private string _passwordStrengthClass = "";
    private string _passwordStrengthText = "";
    private string _passwordStrengthColor = "";

    private void OnPasswordChanged()
    {
        if (string.IsNullOrEmpty(_password))
        {
            _passwordStrengthClass = "";
            _passwordStrengthText = "";
            _passwordStrengthColor = "";
            return;
        }

        var score = 0;
        if (_password.Length >= 8) score++;
        if (_password.Length >= 12) score++;
        if (_password.Any(char.IsUpper) && _password.Any(char.IsLower)) score++;
        if (_password.Any(char.IsDigit)) score++;
        if (_password.Any(c => !char.IsLetterOrDigit(c))) score++;

        if (score <= 2)
        {
            _passwordStrengthClass = "weak";
            _passwordStrengthText = "Weak";
            _passwordStrengthColor = "var(--danger)";
        }
        else if (score <= 3)
        {
            _passwordStrengthClass = "medium";
            _passwordStrengthText = "Fair";
            _passwordStrengthColor = "var(--warning)";
        }
        else
        {
            _passwordStrengthClass = "strong";
            _passwordStrengthText = "Strong";
            _passwordStrengthColor = "var(--success)";
        }
    }

    private async Task HandleRegister()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            // 1. Register account
            var registerRequest = new RegisterRequest(_displayName, _password);
            var response = await Http.PostAsJsonAsync("/api/auth/register", registerRequest);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _errorMessage = response.StatusCode == System.Net.HttpStatusCode.Conflict
                    ? "Display name already taken."
                    : $"Registration failed: {body}";
                return;
            }

            var authResponse = await response.Content.ReadFromJsonAsync<AuthResponse>();

            // 2. Generate crypto keys
            var deviceRequest = await KeyGenService.GenerateAndStoreKeys("Web Browser");

            // 3. Register device with pre-key bundle
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", authResponse!.Token);
            var deviceResponse = await Http.PostAsJsonAsync("/api/devices", deviceRequest);

            if (!deviceResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Device registration failed.";
                return;
            }

            // 4. Extract deviceId from response
            var deviceResult = await deviceResponse.Content.ReadFromJsonAsync<DeviceRegistrationResult>();

            // 5. Store auth token and deviceId for later use
            await Storage.StoreAsync("auth.token", Encoding.UTF8.GetBytes(authResponse.Token));
            if (deviceResult is not null)
            {
                await Storage.StoreAsync("local.deviceId", Encoding.UTF8.GetBytes(deviceResult.DeviceId.ToString(CultureInfo.InvariantCulture)));
            }

            // 6. Navigate to chat
            Navigation.NavigateTo("/chat");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private sealed record DeviceRegistrationResult(decimal DeviceId);
}
