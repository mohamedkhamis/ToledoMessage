@page "/security/{DeviceId:decimal}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject FingerprintService Fingerprint
@inject NavigationManager Navigation

<div style="max-width:480px; margin:0 auto; padding:24px;">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:24px;">
        <a href="javascript:void(0)" @onclick="GoBack" style="text-decoration:none; font-size:1.2em;">&larr;</a>
        <h3 style="margin:0;">Security Verification</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="padding:12px 16px; background:#f8d7da; color:#721c24; border-radius:8px; margin-bottom:16px;">
            @errorMessage
        </div>
    }
    else if (isLoading)
    {
        <p style="text-align:center; color:#999;">Computing safety number...</p>
    }
    else
    {
        <div style="background:#f8f9fa; border-radius:12px; padding:24px; text-align:center; margin-bottom:24px;">
            <p style="font-size:0.9em; color:#6c757d; margin:0 0 16px 0;">Safety Number</p>
            <div style="font-family:monospace; font-size:1.4em; letter-spacing:2px; line-height:1.8; word-spacing:8px;">
                @safetyNumber
            </div>
        </div>

        <div style="text-align:center; margin-bottom:24px;">
            @if (isVerified)
            {
                <div style="display:inline-flex; align-items:center; gap:8px; padding:8px 16px;
                            background:#d4edda; color:#155724; border-radius:20px; font-weight:500;">
                    <span>Verified</span>
                </div>
            }
            else
            {
                <div style="display:inline-flex; align-items:center; gap:8px; padding:8px 16px;
                            background:#fff3cd; color:#856404; border-radius:20px; font-weight:500;">
                    <span>Not Verified</span>
                </div>
            }
        </div>

        <div style="text-align:center; margin-bottom:24px;">
            @if (isVerified)
            {
                <button @onclick="HandleMarkUnverified"
                        style="padding:10px 24px; border:1px solid #dc3545; background:white;
                               color:#dc3545; border-radius:8px; cursor:pointer; font-size:1em;">
                    Mark as Unverified
                </button>
            }
            else
            {
                <button @onclick="HandleMarkVerified"
                        style="padding:10px 24px; border:none; background:#28a745;
                               color:white; border-radius:8px; cursor:pointer; font-size:1em;">
                    Mark as Verified
                </button>
            }
        </div>

        <div style="background:#e9ecef; border-radius:8px; padding:16px; color:#495057; font-size:0.9em; line-height:1.5;">
            <p style="margin:0;">
                Compare this safety number with your contact. If the numbers match,
                your communication is secure. You can compare in person or via a trusted
                channel such as a phone call.
            </p>
        </div>
    }
</div>

@code {
    [Parameter]
    public decimal DeviceId { get; set; }

    /// <summary>
    /// Optional conversation ID used for tracking verification state and for the back link.
    /// Passed as a query parameter: /security/{DeviceId}?conversationId=123
    /// </summary>
    [SupplyParameterFromQuery]
    public decimal? ConversationId { get; set; }

    private string? safetyNumber;
    private bool isVerified;
    private bool isLoading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            safetyNumber = await Fingerprint.ComputeSafetyNumberAsync(DeviceId);

            if (ConversationId.HasValue)
            {
                isVerified = await Fingerprint.IsVerifiedAsync(ConversationId.Value);
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleMarkVerified()
    {
        if (ConversationId.HasValue)
        {
            await Fingerprint.MarkVerifiedAsync(ConversationId.Value);
            isVerified = true;
        }
    }

    private async Task HandleMarkUnverified()
    {
        if (ConversationId.HasValue)
        {
            await Fingerprint.MarkUnverifiedAsync(ConversationId.Value);
            isVerified = false;
        }
    }

    private void GoBack()
    {
        if (ConversationId.HasValue)
        {
            Navigation.NavigateTo($"/chat/{ConversationId.Value}");
        }
        else
        {
            Navigation.NavigateTo("/chat");
        }
    }
}
