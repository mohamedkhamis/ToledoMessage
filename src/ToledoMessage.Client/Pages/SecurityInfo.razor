@page "/security/{DeviceId:long}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@inject FingerprintService Fingerprint
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject IStringLocalizer<SharedResource> Loc

<div class="panel-content-scroll">
<div class="security-page fade-in">
    <div class="security-header">
        <button @onclick="GoBack" class="back-link" aria-label="@Loc["Back to conversations"]">&larr;</button>
        <h3>@Loc["Security Verification"]</h3>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error" role="alert">@_errorMessage</div>
    }
    else if (_isLoading)
    {
        <p class="centered-text"><span class="spinner"></span> @Loc["Computing safety number..."]</p>
    }
    else
    {
        <div class="safety-number-card">
            <p class="safety-number-label">@Loc["Safety Number"]</p>
            <div class="safety-number-value">
                @_safetyNumber
            </div>
            <button class="btn-copy @(_copied ? "copied" : "")" @onclick="CopySafetyNumber"
                    aria-label="@Loc["Copy"]">
                @(_copied ? Loc["Copied!"] : Loc["Copy"])
            </button>
        </div>

        <div class="verify-actions">
            @if (_isVerified)
            {
                <div class="verification-badge verified">
                    <span>@Loc["Verified"]</span>
                </div>
            }
            else
            {
                <div class="verification-badge unverified">
                    <span>@Loc["Not Verified"]</span>
                </div>
            }
        </div>

        <div class="verify-actions">
            @if (_isVerified)
            {
                <button class="btn-unverify" @onclick="HandleMarkUnverified">
                    @Loc["Mark as Unverified"]
                </button>
            }
            else
            {
                <button class="btn-verify" @onclick="HandleMarkVerified">
                    @Loc["Mark as Verified"]
                </button>
            }
        </div>

        <div class="security-info-box">
            <p>
                @Loc["SecurityInfoDesc"]
            </p>
        </div>
    }
</div>
</div>

@code {
    [Parameter]
    public long DeviceId { get; set; }

    /// <summary>
    /// Optional conversation ID used for tracking verification state and for the back link.
    /// Passed as a query parameter: /security/{DeviceId}?conversationId=123
    /// </summary>
    [SupplyParameterFromQuery]
    public long? ConversationId { get; set; }

    private string? _safetyNumber;
    private bool _isVerified;
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool _copied;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _safetyNumber = await Fingerprint.ComputeSafetyNumberAsync(DeviceId);

            if (ConversationId.HasValue)
            {
                _isVerified = await Fingerprint.IsVerifiedAsync(ConversationId.Value);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleMarkVerified()
    {
        if (ConversationId.HasValue)
        {
            await Fingerprint.MarkVerifiedAsync(ConversationId.Value);
            _isVerified = true;
        }
    }

    private async Task HandleMarkUnverified()
    {
        if (ConversationId.HasValue)
        {
            await Fingerprint.MarkUnverifiedAsync(ConversationId.Value);
            _isVerified = false;
        }
    }

    private async Task CopySafetyNumber()
    {
        if (!string.IsNullOrEmpty(_safetyNumber))
        {
            await Js.InvokeVoidAsync("navigator.clipboard.writeText", _safetyNumber);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
        }
    }

    private void GoBack()
    {
        if (ConversationId.HasValue)
        {
            Navigation.NavigateTo($"/chat/{ConversationId.Value}");
        }
        else
        {
            Navigation.NavigateTo("/chat");
        }
    }
}
