@page "/settings"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@using System.Text
@inject HttpClient Http
@inject LocalStorageService Storage
@inject NavigationManager Navigation
@inject ThemeService Theme
@inject PreferencesService Preferences
@inject IJSRuntime Js
@inject MessageStoreService MessageStore
@inject KeyBackupService KeyBackup

<div class="panel-content-scroll">
<div class="settings-page">
    <div class="settings-header">
        <h2>@Theme.Labels.SettingsLabel</h2>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error" role="alert">@_errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success" role="status">@_successMessage</div>
    }

    <h3 class="section-title">@Theme.Labels.Appearance</h3>

    <div class="theme-grid">
        @foreach (var theme in ThemeService.GetAvailableThemes())
        {
            <div class="theme-card @(_currentTheme == theme.Id ? "active" : "")"
                 @onclick="() => SelectTheme(theme.Id)">
                <div class="theme-swatch" style="background:@theme.SwatchColor;"></div>
                <div class="theme-name">@theme.DisplayName</div>
            </div>
        }
    </div>

    <h4 class="subsection-title mt-md">@Theme.Labels.FontSize</h4>
    <div class="font-size-selector">
        @foreach (var size in FontSizes)
        {
            <button class="font-size-btn @(_currentFontSize == size.Id ? "active" : "")"
                    @onclick="() => SelectFontSize(size.Id)">
                <span style="font-size:@size.Preview">A</span>
                <span class="font-size-label">@size.Label</span>
            </button>
        }
    </div>

    <h3 class="section-title mt-lg">@Theme.Labels.Privacy</h3>

    <div class="settings-toggles">
        <div class="toggle-row">
            <div class="toggle-info">
                <span class="toggle-label">@Theme.Labels.ReadReceipts</span>
                <span class="toggle-desc">Let others know when you've read their messages</span>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" checked="@_readReceiptsEnabled"
                       @onchange="e => ToggleReadReceipts((bool)e.Value!)" />
                <span class="toggle-slider"></span>
            </label>
        </div>

        <div class="toggle-row">
            <div class="toggle-info">
                <span class="toggle-label">@Theme.Labels.TypingIndicators</span>
                <span class="toggle-desc">Show when you're typing a message</span>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" checked="@_typingIndicatorsEnabled"
                       @onchange="e => ToggleTypingIndicators((bool)e.Value!)" />
                <span class="toggle-slider"></span>
            </label>
        </div>
    </div>

    <h3 class="section-title mt-lg">@Theme.Labels.Security</h3>

    <div class="settings-toggles">
        <div class="toggle-row">
            <div class="toggle-info">
                <span class="toggle-label">@Theme.Labels.ShareKeysAcrossDevices</span>
                <span class="toggle-desc">@Theme.Labels.ShareKeysDescription</span>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" checked="@_sharedKeysEnabled"
                       @onchange="e => ToggleSharedKeys((bool)e.Value!)" />
                <span class="toggle-slider"></span>
            </label>
        </div>
    </div>

    <h3 class="section-title mt-lg">@Theme.Labels.Notifications</h3>

    <div class="settings-toggles">
        <div class="toggle-row">
            <div class="toggle-info">
                <span class="toggle-label">@Theme.Labels.DesktopNotifications</span>
                <span class="toggle-desc">@Theme.Labels.DesktopNotificationsDescription</span>
            </div>
            <label class="toggle-switch">
                <input type="checkbox" checked="@_notificationsEnabled"
                       @onchange="e => ToggleNotifications((bool)e.Value!)" />
                <span class="toggle-slider"></span>
            </label>
        </div>
    </div>

    <h3 class="section-title mt-lg">@Theme.Labels.LinkedDevices</h3>

    @if (_isLoading)
    {
        <p class="loading-text"><span class="spinner"></span> @Theme.Labels.LoadingDevices</p>
    }
    else if (_devices.Count == 0)
    {
        <p class="loading-text">@Theme.Labels.NoDevicesFound</p>
    }
    else
    {
        <div class="device-list">
            @foreach (var device in _devices)
            {
                <div class="device-card">
                    <div>
                        <div class="device-name">
                            @device.DeviceName
                            @if (device.DeviceId == _currentDeviceId)
                            {
                                <span class="device-current">(this device)</span>
                            }
                        </div>
                        <div class="device-date">
                            Linked @device.CreatedAt.ToString("MMM dd, yyyy")
                        </div>
                        <div class="device-lastseen">
                            Last seen @device.LastSeenAt.ToString("MMM dd, yyyy HH:mm")
                        </div>
                    </div>

                    @if (device.DeviceId != _currentDeviceId)
                    {
                        <button class="btn-unlink"
                                @onclick="() => UnlinkDevice(device.DeviceId)"
                                disabled="@_unlinkingDeviceId.HasValue">
                            @if (_unlinkingDeviceId == device.DeviceId)
                            {
                                <span>Unlinking...</span>
                            }
                            else
                            {
                                <span>Unlink</span>
                            }
                        </button>
                    }
                </div>
            }
        </div>
    }

    <div class="link-device-box">
        <p>Link New Device</p>
        <p class="link-device-sub">
            QR code scanning will be available in a future update.
        </p>
    </div>

    <h3 class="section-title mt-lg danger-text">@Theme.Labels.AccountDeletion</h3>

    @if (_deletionPending)
    {
        <div class="alert alert-warning" role="status">
            <p>Account deletion is scheduled. Your account will be permanently deactivated
               on <strong>@_deletionEndsAt?.ToString("MMM dd, yyyy HH:mm") UTC</strong>.</p>
            <p>Log in again to cancel the deletion.</p>
        </div>
    }
    else
    {
        <div class="danger-zone">
            @if (!_showDeleteConfirmation)
            {
                <p class="danger-description">
                    Permanently delete your account and all associated data.
                    You will have a 7-day grace period to cancel by logging in.
                </p>
                <button class="btn-danger" @onclick="() => _showDeleteConfirmation = true">
                    Delete Account
                </button>
            }
            else
            {
                <p class="danger-description">
                    Are you sure? This action will begin a 7-day deletion countdown.
                    All your devices, keys, and messages will be permanently removed.
                </p>
                <div class="danger-actions">
                    <button class="btn-danger" @onclick="DeleteAccount" disabled="@_isDeletingAccount">
                        @(_isDeletingAccount ? "Deleting..." : "Yes, Delete My Account")
                    </button>
                    <button class="btn-secondary" @onclick="() => _showDeleteConfirmation = false"
                            disabled="@_isDeletingAccount">
                        Cancel
                    </button>
                </div>
            }
        </div>
    }

    <div class="app-version-footer">Toledo Message v@(AppVersion.Current)</div>
</div>
</div>

@code {
    private List<DeviceInfoResponse> _devices = [];
    private decimal _currentDeviceId;
    private bool _isLoading = true;
    private string? _errorMessage;
    private string? _successMessage;
    private decimal? _unlinkingDeviceId;
    private string _currentTheme = "default";
    private string _currentFontSize = "medium";
    private bool _notificationsEnabled = true;
    private bool _readReceiptsEnabled = true;
    private bool _typingIndicatorsEnabled = true;
    private bool _sharedKeysEnabled = true;
    private bool _showDeleteConfirmation;
    private bool _isDeletingAccount;
    private bool _deletionPending;
    private DateTimeOffset? _deletionEndsAt;

    private static readonly FontSizeOption[] FontSizes =
    [
        new("small", "Small", "12px"),
        new("medium", "Medium", "15px"),
        new("large", "Large", "18px"),
    ];

    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += OnThemeChanged;
    }

    private void OnThemeChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Theme.OnThemeChanged -= OnThemeChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _currentTheme = await Theme.GetThemeAsync();
            _currentFontSize = await Theme.GetFontSizeAsync();

            var deviceIdBytes = await Storage.GetAsync("local.deviceId");
            var tokenBytes = await Storage.GetAsync("auth.token");

            if (deviceIdBytes is null || tokenBytes is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            _currentDeviceId = decimal.Parse(Encoding.UTF8.GetString(deviceIdBytes));
            var accessToken = Encoding.UTF8.GetString(tokenBytes);

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);

            // Load preferences from server
            var prefs = await Preferences.GetPreferencesAsync();
            _notificationsEnabled = prefs.NotificationsEnabled;
            _readReceiptsEnabled = prefs.ReadReceiptsEnabled;
            _typingIndicatorsEnabled = prefs.TypingIndicatorsEnabled;
            _sharedKeysEnabled = prefs.SharedKeysEnabled;

            // Sync local theme TO server if different (local is source of truth)
            if (prefs.Theme != _currentTheme)
            {
                try { await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(Theme: _currentTheme)); }
                catch { /* best effort */ }
            }

            if (prefs.FontSize != _currentFontSize)
            {
                _currentFontSize = prefs.FontSize;
                await Theme.SetFontSizeAsync(prefs.FontSize);
            }

            await LoadDevices();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SelectTheme(string themeId)
    {
        _currentTheme = themeId;
        await Theme.SetThemeAsync(themeId);
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(Theme: themeId));
            _successMessage = "Theme saved.";
        }
        catch
        {
            // Local theme still applied even if server sync fails
        }
    }

    private async Task SelectFontSize(string size)
    {
        _currentFontSize = size;
        await Theme.SetFontSizeAsync(size);
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(FontSize: size));
            _successMessage = "Font size saved.";
        }
        catch
        {
            // Local change still applied
        }
    }

    private async Task ToggleNotifications(bool enabled)
    {
        _notificationsEnabled = enabled;
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(NotificationsEnabled: enabled));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save: {ex.Message}";
        }
    }

    private async Task ToggleReadReceipts(bool enabled)
    {
        _readReceiptsEnabled = enabled;
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(ReadReceiptsEnabled: enabled));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save: {ex.Message}";
        }
    }

    private async Task ToggleTypingIndicators(bool enabled)
    {
        _typingIndicatorsEnabled = enabled;
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(TypingIndicatorsEnabled: enabled));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save: {ex.Message}";
        }
    }

    private async Task ToggleSharedKeys(bool enabled)
    {
        _sharedKeysEnabled = enabled;
        try
        {
            await Preferences.UpdatePreferencesAsync(new UpdatePreferencesRequest(SharedKeysEnabled: enabled));

            if (!enabled)
            {
                // Delete the server-side backup when disabling
                try
                {
                    await KeyBackup.DeleteBackupAsync();
                    _successMessage = "Key sharing disabled. Server backup deleted.";
                }
                catch
                {
                    _successMessage = "Key sharing disabled.";
                }
            }
            else
            {
                _successMessage = "Key sharing enabled. Backup will be created on next login.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save: {ex.Message}";
        }
    }

    private async Task LoadDevices()
    {
        _devices = await Http.GetFromJsonAsync<List<DeviceInfoResponse>>("/api/devices") ?? [];
    }

    private async Task DeleteAccount()
    {
        _errorMessage = null;
        _successMessage = null;
        _isDeletingAccount = true;

        try
        {
            var response = await Http.DeleteAsync("/api/auth/account");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content
                    .ReadFromJsonAsync<AccountDeletionResponse>();
                if (result is not null)
                {
                    // Full wipe: clear all local data (device, keys, sessions, messages)
                    try
                    {
                        await Js.InvokeVoidAsync("toledoStorage.clearAllData");
                        await MessageStore.ClearAllAsync();
                    }
                    catch { /* best effort */ }

                    _deletionPending = true;
                    _deletionEndsAt = result.GracePeriodEndsAt;
                    _showDeleteConfirmation = false;
                    _successMessage = "Account deletion scheduled. Log in again within 7 days to cancel.";
                }
            }
            else
            {
                _errorMessage = "Failed to initiate account deletion.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error deleting account: {ex.Message}";
        }
        finally
        {
            _isDeletingAccount = false;
        }
    }

    private async Task UnlinkDevice(decimal deviceId)
    {
        _errorMessage = null;
        _successMessage = null;
        _unlinkingDeviceId = deviceId;

        try
        {
            var response = await Http.DeleteAsync($"/api/devices/{deviceId}");

            if (response.IsSuccessStatusCode)
            {
                _successMessage = "Device unlinked successfully.";
                await LoadDevices();
            }
            else
            {
                _errorMessage = "Failed to unlink device.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error unlinking device: {ex.Message}";
        }
        finally
        {
            _unlinkingDeviceId = null;
        }
    }

    private sealed record FontSizeOption(string Id, string Label, string Preview);
}
