@page "/settings"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using System.Text
@inject HttpClient Http
@inject LocalStorageService Storage
@inject NavigationManager Navigation
@inject ThemeService Theme

<div class="settings-page">
    <div class="settings-header">
        <a href="/chat" class="back-link">&larr;</a>
        <h2>Settings</h2>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error" role="alert">@errorMessage</div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success" role="status">@successMessage</div>
    }

    <h3 class="section-title">Appearance</h3>

    <div class="theme-grid">
        @foreach (var theme in ThemeService.GetAvailableThemes())
        {
            <div class="theme-card @(currentTheme == theme.Id ? "active" : "")"
                 @onclick="() => SelectTheme(theme.Id)">
                <div class="theme-swatch" style="background:@theme.SwatchColor;"></div>
                <div class="theme-name">@theme.DisplayName</div>
            </div>
        }
    </div>

    <h3 class="section-title mt-lg">Linked Devices</h3>

    @if (isLoading)
    {
        <p class="loading-text"><span class="spinner"></span> Loading devices...</p>
    }
    else if (devices.Count == 0)
    {
        <p class="loading-text">No active devices found.</p>
    }
    else
    {
        <div class="device-list">
            @foreach (var device in devices)
            {
                <div class="device-card">
                    <div>
                        <div class="device-name">
                            @device.DeviceName
                            @if (device.DeviceId == currentDeviceId)
                            {
                                <span class="device-current">(this device)</span>
                            }
                        </div>
                        <div class="device-date">
                            Linked @device.CreatedAt.ToString("MMM dd, yyyy")
                        </div>
                        <div class="device-lastseen">
                            Last seen @device.LastSeenAt.ToString("MMM dd, yyyy HH:mm")
                        </div>
                    </div>

                    @if (device.DeviceId != currentDeviceId)
                    {
                        <button class="btn-unlink"
                                @onclick="() => UnlinkDevice(device.DeviceId)"
                                disabled="@unlinkingDeviceId.HasValue">
                            @if (unlinkingDeviceId == device.DeviceId)
                            {
                                <span>Unlinking...</span>
                            }
                            else
                            {
                                <span>Unlink</span>
                            }
                        </button>
                    }
                </div>
            }
        </div>
    }

    <div class="link-device-box">
        <p>Link New Device</p>
        <p class="link-device-sub">
            QR code scanning will be available in a future update.
        </p>
    </div>
</div>

@code {
    private List<DeviceInfoResponse> devices = [];
    private decimal currentDeviceId;
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private decimal? unlinkingDeviceId;
    private string currentTheme = "default";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            currentTheme = await Theme.GetThemeAsync();

            var deviceIdBytes = await Storage.GetAsync("local.deviceId");
            var tokenBytes = await Storage.GetAsync("auth.token");

            if (deviceIdBytes is null || tokenBytes is null)
            {
                errorMessage = "Not authenticated. Please log in.";
                isLoading = false;
                return;
            }

            currentDeviceId = decimal.Parse(Encoding.UTF8.GetString(deviceIdBytes));
            var accessToken = Encoding.UTF8.GetString(tokenBytes);

            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", accessToken);

            await LoadDevices();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SelectTheme(string themeId)
    {
        currentTheme = themeId;
        await Theme.SetThemeAsync(themeId);
    }

    private async Task LoadDevices()
    {
        devices = await Http.GetFromJsonAsync<List<DeviceInfoResponse>>("/api/devices") ?? [];
    }

    private async Task UnlinkDevice(decimal deviceId)
    {
        errorMessage = null;
        successMessage = null;
        unlinkingDeviceId = deviceId;

        try
        {
            var response = await Http.DeleteAsync($"/api/devices/{deviceId}");

            if (response.IsSuccessStatusCode)
            {
                successMessage = "Device unlinked successfully.";
                await LoadDevices();
            }
            else
            {
                errorMessage = "Failed to unlink device.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error unlinking device: {ex.Message}";
        }
        finally
        {
            unlinkingDeviceId = null;
        }
    }
}
