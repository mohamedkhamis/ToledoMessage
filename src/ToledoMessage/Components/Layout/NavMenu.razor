<nav class="app-nav">
    <a href="/" class="brand">ToledoMessage</a>
    <button class="nav-toggle" @onclick="ToggleNav" aria-label="Toggle navigation">
        &#9776;
    </button>
    <div class="nav-links @(isOpen ? "open" : "")">
        <a href="/chat" @onclick="CloseNav">Chats</a>
        <a href="/settings" @onclick="CloseNav">Settings</a>
    </div>
</nav>

@code {
    private bool isOpen;

    private void ToggleNav() => isOpen = !isOpen;

    private void CloseNav() => isOpen = false;
}
