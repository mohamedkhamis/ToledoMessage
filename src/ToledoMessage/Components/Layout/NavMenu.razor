@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResource> Loc
@implements IDisposable

<nav class="app-nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="brand">ToledoMessage</a>

    @if (IsPublicPage())
    {
        <div class="nav-links">
            <button type="button" class="lang-switcher" onclick="window.__toggleLang()" title="@(IsCulture("ar") ? "Switch to English" : "التبديل إلى العربية")">
                <span class="lang-label @(IsCulture("en") ? "lang-active" : "")">EN</span>
                <span class="lang-label @(IsCulture("ar") ? "lang-active" : "")">عربي</span>
            </button>
            @* ReSharper disable  Html.PathError *@
            <a href="/login" class="@ActiveClass("/login")">@Loc["Sign In"]</a>
            <a href="/register" class="@ActiveClass("/register")">@Loc["Register"]</a>
        </div>
    }
    else
    {
        <button class="nav-toggle" @onclick="ToggleNav" aria-label="Toggle navigation"
                aria-expanded="@_isOpen">
            &#9776;
        </button>
        <div class="nav-links @(_isOpen ? "open" : "")">
            <button type="button" class="lang-switcher" onclick="window.__toggleLang()" title="@(IsCulture("ar") ? "Switch to English" : "التبديل إلى العربية")">
                <span class="lang-label @(IsCulture("en") ? "lang-active" : "")">EN</span>
                <span class="lang-label @(IsCulture("ar") ? "lang-active" : "")">عربي</span>
            </button>
            <a href="/chat" class="@ActiveClass("/chat")" @onclick="CloseNav"
               aria-current="@(IsActive("/chat") ? "page" : null)">@Loc["Chats"]</a>
            <a href="/settings" class="@ActiveClass("/settings")" @onclick="CloseNav"
               aria-current="@(IsActive("/settings") ? "page" : null)">@Loc["Settings"]</a>
            <button class="btn-logout" @onclick="HandleLogout">@Loc["Logout"]</button>
        </div>
    }
</nav>

@if (_isOpen)
{
    <div class="nav-backdrop open" @onclick="CloseNav"></div>
}

@code {
    private static readonly string[] PublicPaths = ["/", "/login", "/register"];
    private bool _isOpen;
    private string _currentUri = "";

    protected override void OnInitialized()
    {
        _currentUri = Navigation.Uri;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentUri = e.Location;
        _isOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private bool IsPublicPage()
    {
        var path = new Uri(_currentUri).AbsolutePath.TrimEnd('/');
        if (string.IsNullOrEmpty(path)) path = "/";
        return Array.Exists(PublicPaths, p =>
            string.Equals(p, path, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsActive(string path)
    {
        var relative = new Uri(_currentUri).AbsolutePath;
        return relative.StartsWith(path, StringComparison.OrdinalIgnoreCase);
    }

    private string ActiveClass(string path)
    {
        return IsActive(path) ? "active" : "";
    }

    private void ToggleNav()
    {
        _isOpen = !_isOpen;
    }

    private void CloseNav()
    {
        _isOpen = false;
    }

    private void HandleLogout()
    {
        CloseNav();
        Navigation.NavigateTo("/login?logout=true", forceLoad: true);
    }

    private bool IsCulture(string culture)
    {
        return System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith(culture, StringComparison.OrdinalIgnoreCase);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
