@page "/"

<div class="landing-page">
    <header class="landing-header">
        <div class="header-content">
            <div class="brand">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                    <path d="M8 10h8M8 14h4" />
                </svg>
                <span>ToledoMessage</span>
            </div>
            <nav class="header-nav">
                <a href="/login" data-enhance-nav="false" class="btn-nav-outline">Sign In</a>
                <a href="/register" data-enhance-nav="false" class="btn-nav">Get Started</a>
            </nav>
        </div>
    </header>

    <main class="hero-section">
        <div class="hero-badge">
            <span class="badge-dot"></span>
            <span>Ultra-Secure Messaging</span>
        </div>
        <h1 class="hero-title">
            Simple, Secure Messaging for <br />
            <span class="gradient-text">Everyone</span>
        </h1>
        <p class="hero-description">
            Your conversations are completely private. We use state-of-the-art security so only you and your friends can
            read your messages.
        </p>
        <div class="hero-actions">
            <a href="/register" data-enhance-nav="false" class="btn-primary-lg">
                <span>Start Messaging</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
            </a>
            <a href="/login" data-enhance-nav="false" class="btn-secondary-lg">Sign In</a>
        </div>

        <div class="hero-stats">
            <div class="stat-item">
                <span class="stat-value">100%</span>
                <span class="stat-label">Private</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">Always</span>
                <span class="stat-label">Encrypted</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <span class="stat-value">Zero</span>
                <span class="stat-label">Data Collected</span>
            </div>
        </div>
    </main>

    <section class="features-section">
        <h2 class="section-title">Why ToledoMessage?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon pq">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2L2 7l10 5 10-5-10-5z" />
                        <path d="M2 17l10 5 10-5" />
                        <path d="M2 12l10 5 10-5" />
                    </svg>
                </div>
                <h3>Future-Proof Security</h3>
                <p>Advanced protection keeps your messages safe from any outside threats, now and in the future.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon e2e">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                </div>
                <h3>End-to-End Encrypted</h3>
                <p>Your messages are locked the moment you send them. Only the person you're chatting with can read
                    them.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon trust">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                    </svg>
                </div>
                <h3>Your Data is Yours</h3>
                <p>We don't read your messages, we don't track who you talk to, and we never share your data.</p>
            </div>
        </div>
    </section>

    <footer class="landing-footer">
        <div class="footer-content">
            <span class="footer-brand">ToledoMessage</span>
            <span class="footer-version">v@(AppVersion.Current)</span>
        </div>
    </footer>
</div>

<style>
    .landing-page {
        min-height: 100vh;
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
        color: #f8fafc;
        overflow-x: hidden;
    }

    /* ---- Header ---- */
    .landing-header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(15, 23, 42, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .header-content {
        max-width: 1200px;
        margin: 0 auto;
        padding: 14px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.15rem;
        font-weight: 700;
        color: #f8fafc;
        white-space: nowrap;
    }

    .brand svg {
        color: #38bdf8;
        flex-shrink: 0;
    }

    .header-nav {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .btn-nav {
        display: inline-block;
        background: #38bdf8;
        color: #0f172a !important;
        padding: 8px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.88rem;
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.2s;
    }

    .btn-nav:hover {
        background: #7dd3fc !important;
        text-decoration: none;
    }

    .btn-nav-outline {
        display: inline-block;
        color: #cbd5e1 !important;
        padding: 8px 18px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.88rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        text-decoration: none;
        white-space: nowrap;
        transition: background 0.2s, color 0.2s;
    }

    .btn-nav-outline:hover {
        background: rgba(255, 255, 255, 0.1) !important;
        color: #f8fafc !important;
        text-decoration: none;
    }

    /* ---- Hero ---- */
    .hero-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 32px 20px 24px;
        max-width: 800px;
        margin: 0 auto;
        width: 100%;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(56, 189, 248, 0.1);
        border: 1px solid rgba(56, 189, 248, 0.3);
        padding: 6px 14px;
        border-radius: 100px;
        font-size: 0.8rem;
        color: #38bdf8;
        margin-bottom: 20px;
    }

    .badge-dot {
        width: 7px;
        height: 7px;
        background: #38bdf8;
        border-radius: 50%;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {

        0%,
        100% {
            opacity: 1;
        }

        50% {
            opacity: 0.4;
        }
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 14px;
        letter-spacing: -0.02em;
    }

    .gradient-text {
        background: linear-gradient(135deg, #38bdf8 0%, #818cf8 50%, #c084fc 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-description {
        font-size: 1rem;
        color: #94a3b8;
        max-width: 560px;
        margin-bottom: 24px;
        line-height: 1.5;
    }

    .hero-actions {
        display: flex;
        gap: 12px;
        margin-bottom: 28px;
    }

    .btn-primary-lg {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, #38bdf8 0%, #818cf8 100%);
        color: #0f172a;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .btn-primary-lg:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(56, 189, 248, 0.3);
        text-decoration: none;
    }

    .btn-secondary-lg {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.08);
        color: #f8fafc;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-secondary-lg:hover {
        background: rgba(255, 255, 255, 0.15);
        text-decoration: none;
    }

    /* ---- Stats ---- */
    .hero-stats {
        display: flex;
        align-items: center;
        gap: 20px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        padding: 14px 20px;
        border-radius: 12px;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2px;
    }

    .stat-value {
        font-size: 0.9rem;
        font-weight: 700;
        color: #38bdf8;
        white-space: nowrap;
    }

    .stat-label {
        font-size: 0.7rem;
        color: #64748b;
        white-space: nowrap;
    }

    .stat-divider {
        width: 1px;
        height: 28px;
        background: rgba(255, 255, 255, 0.1);
        flex-shrink: 0;
    }

    /* ---- Features ---- */
    .features-section {
        padding: 16px 20px 20px;
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
    }

    .section-title {
        text-align: center;
        font-size: 1.15rem;
        font-weight: 700;
        margin-bottom: 14px;
        color: #f8fafc;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .feature-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 10px;
        padding: 14px;
    }

    .feature-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 10px;
    }

    .feature-icon.pq {
        background: rgba(56, 189, 248, 0.15);
        color: #38bdf8;
    }

    .feature-icon.e2e {
        background: rgba(129, 140, 248, 0.15);
        color: #818cf8;
    }

    .feature-icon.trust {
        background: rgba(192, 132, 252, 0.15);
        color: #c084fc;
    }

    .feature-card h3 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 4px;
        color: #f8fafc;
    }

    .feature-card p {
        color: #64748b;
        font-size: 0.78rem;
        line-height: 1.4;
    }

    /* ---- Footer ---- */
    .landing-footer {
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        padding: 16px 20px;
    }

    .footer-content {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .footer-brand {
        font-weight: 600;
        font-size: 0.9rem;
        color: #94a3b8;
    }

    .footer-version {
        font-size: 0.8rem;
        color: #38bdf8;
        font-weight: 600;
        font-family: monospace;
    }

    /* ============ Mobile ============ */
    @@media (max-width: 768px) {
        .header-content {
            padding: 12px 16px;
        }

        .brand {
            font-size: 1rem;
            gap: 8px;
        }

        .brand svg {
            width: 22px;
            height: 22px;
        }

        .header-nav {
            gap: 8px;
        }

        .btn-nav-outline,
        .btn-nav {
            padding: 7px 12px;
            font-size: 0.82rem;
        }

        .hero-section {
            padding: 20px 16px 16px;
            justify-content: flex-start;
        }

        .hero-badge {
            margin-bottom: 16px;
            font-size: 0.72rem;
            padding: 5px 12px;
        }

        .hero-title {
            font-size: 1.6rem;
            margin-bottom: 10px;
        }

        .hero-description {
            font-size: 0.85rem;
            margin-bottom: 20px;
        }

        .hero-actions {
            width: 100%;
            max-width: 260px;
            gap: 10px;
            margin-bottom: 20px;
        }

        .btn-primary-lg,
        .btn-secondary-lg {
            justify-content: center;
            width: 100%;
            padding: 11px 16px;
            font-size: 0.9rem;
        }

        .hero-stats {
            gap: 12px;
            padding: 12px 16px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .stat-divider {
            display: none;
        }

        .stat-item {
            min-width: 80px;
        }

        .features-section {
            padding: 12px 16px 16px;
        }

        .section-title {
            font-size: 1rem;
            margin-bottom: 10px;
        }

        .features-grid {
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .feature-card {
            padding: 12px;
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .feature-icon {
            margin-bottom: 0;
            flex-shrink: 0;
        }

        .feature-card h3 {
            font-size: 0.85rem;
        }

        .feature-card p {
            font-size: 0.75rem;
        }

        .landing-footer {
            padding: 12px 16px;
        }

        .footer-content {
            font-size: 0.8rem;
        }
    }

    @@media (max-width: 380px) {
        .brand span {
            display: none;
        }

        .hero-title {
            font-size: 1.4rem;
        }

        .btn-nav-outline,
        .btn-nav {
            padding: 6px 10px;
            font-size: 0.78rem;
        }
    }
</style>
