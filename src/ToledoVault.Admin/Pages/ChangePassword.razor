@page "/admin/change-password"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject AdminAuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http
@inject IStringLocalizer<AdminResource> Loc

<div class="admin-login-page">
    <div class="admin-login-card">
        <h1>@Loc["ChangePassword_Title"]</h1>
        <p class="subtitle">@Loc["ChangePassword_MustChange"]</p>

        @if (error is not null)
        {
            <div class="alert alert-error">@error</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleChangePassword" FormName="ChangePassword">
            <div class="form-group">
                <label>Current Password</label>
                <input type="password" @bind="model.CurrentPassword" required />
            </div>
            <div class="form-group">
                <label>New Password (min 12 characters)</label>
                <input type="password" @bind="model.NewPassword" required minlength="12" />
            </div>
            <div class="form-group">
                <label>Confirm New Password</label>
                <input type="password" @bind="model.ConfirmPassword" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%" disabled="@loading">
                @(loading ? "Changing..." : "Change Password")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private ChangePasswordModel model = new();
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (!Auth.IsAuthenticated)
            Nav.NavigateTo("/admin/login");
    }

    private async Task HandleChangePassword()
    {
        error = null;

        if (model.NewPassword.Length < 12)
        {
            error = "Password must be at least 12 characters.";
            return;
        }

        if (model.NewPassword != model.ConfirmPassword)
        {
            error = "Passwords do not match.";
            return;
        }

        loading = true;
        try
        {
            var response = await Auth.ChangePasswordAsync(Http, model.CurrentPassword, model.NewPassword);
            if (response.IsSuccessStatusCode)
            {
                Auth.MustChangePassword = false;
                Nav.NavigateTo("/admin");
            }
            else
            {
                error = "Current password is incorrect.";
            }
        }
        catch
        {
            error = "Connection error. Please try again.";
        }
        finally
        {
            loading = false;
        }
    }

    private class ChangePasswordModel
    {
        public string CurrentPassword { get; set; } = "";
        public string NewPassword { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
