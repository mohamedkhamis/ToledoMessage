@page "/admin/login"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject AdminAuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http
@inject IStringLocalizer<AdminResource> Loc

<div class="admin-login-page">
    <div class="admin-login-card">
        <h1>@Loc["Login_AppTitle"]</h1>
        <p class="subtitle">@Loc["Login_Subtitle"]</p>

        @if (error is not null)
        {
            <div class="alert alert-error">@error</div>
        }

        <EditForm Model="model" OnValidSubmit="HandleLogin" FormName="AdminLogin">
            <div class="form-group">
                <label>Username</label>
                <input type="text" @bind="model.Username" required />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" @bind="model.Password" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%" disabled="@loading">
                @(loading ? "Logging in..." : "Login")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private LoginModel model = new();
    private string? error;
    private bool loading;

    protected override void OnInitialized()
    {
        if (Auth.IsAuthenticated && !Auth.MustChangePassword)
            Nav.NavigateTo("/admin");
    }

    private async Task HandleLogin()
    {
        error = null;
        loading = true;

        try
        {
            var response = await Auth.LoginAsync(Http, model.Username, model.Password);
            if (response.IsSuccessStatusCode)
            {
                if (Auth.MustChangePassword)
                    Nav.NavigateTo("/admin/change-password");
                else
                    Nav.NavigateTo("/admin");
            }
            else
            {
                error = "Invalid credentials.";
            }
        }
        catch
        {
            error = "Connection error. Please try again.";
        }
        finally
        {
            loading = false;
        }
    }

    private class LoginModel
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
