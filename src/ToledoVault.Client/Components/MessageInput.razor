@inject IJSRuntime Js
@inject IStringLocalizer<SharedResource> Loc
@inject SignalRService SignalR
@inject PreferencesService Preferences
@implements IAsyncDisposable

<div class="chat-input-area">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="input-error">@_errorMessage</div>
    }
    @if (_rateLimitRemaining > 0)
    {
        <div class="rate-limit-warning">
            @string.Format(Loc["Wait {0} seconds before sending more messages"], _rateLimitRemaining)
        </div>
    }
    @if (ReplyContext is not null)
    {
        <div class="reply-preview-bar">
            <div class="reply-preview-content">
                <div class="reply-sender-name">@ReplyContext.SenderName</div>
                <div class="reply-quote-text">@(!string.IsNullOrEmpty(ReplyContext.Text) ? ReplyContext.Text : "Message")</div>
            </div>
            @if (!string.IsNullOrEmpty(ReplyContext.ThumbnailDataUrl))
            {
                <img src="@ReplyContext.ThumbnailDataUrl" class="reply-media-thumb" alt="Reply preview" />
            }
            <button class="reply-preview-close" @onclick="() => OnCancelReply.InvokeAsync()" aria-label="Cancel reply">&times;</button>
        </div>
    }
    @if (_selectedFile is not null)
    {
        @if (_selectedContentType == ContentType.Image)
        {
            @* WhatsApp-style large image preview *@
            <div class="media-preview-panel">
                <div class="media-preview-header">
                    <button class="media-preview-close" @onclick="ClearSelectedFile" aria-label="Remove attachment">&times;</button>
                    <span class="media-preview-filename">@_selectedFile.Name</span>
                    <div class="media-preview-actions">
                        <button class="hd-toggle-btn @(_sendAsHd ? "hd-active" : "")"
                                @onclick="ToggleHdQuality"
                                title="@(_sendAsHd ? "HD quality enabled" : "Standard quality")"
                                aria-label="Toggle HD quality">
                            <span class="hd-label">HD</span>
                        </button>
                    </div>
                </div>
                <div class="media-preview-image-wrap">
                    @if (_previewDataUrl is not null)
                    {
                        <img src="@_previewDataUrl" alt="Preview" class="media-preview-image" />
                    }
                    else
                    {
                        <div class="media-preview-placeholder">&#128247; Loading preview...</div>
                    }
                </div>
                <div class="media-preview-footer">
                    <span class="media-preview-size">
                        @if (_sendAsHd)
                        {
                            <span>@FormatFileSize(_originalFileSize) (Original)</span>
                        }
                        else
                        {
                            <span>@FormatFileSize(_selectedFileBytes?.Length ?? 0)</span>
                            @if (_originalFileSize > 0 && _selectedFileBytes is not null && _selectedFileBytes.Length < _originalFileSize)
                            {
                                <span class="media-preview-savings"> (saved @(Math.Round((1 - (double)_selectedFileBytes.Length / _originalFileSize) * 100))%)</span>
                            }
                        }
                    </span>
                </div>
            </div>
        }
        else if (_selectedContentType == ContentType.Video)
        {
            @* Video preview — playable video with controls *@
            <div class="media-preview-panel">
                <div class="media-preview-header">
                    <button class="media-preview-close" @onclick="ClearSelectedFile" aria-label="Remove attachment">&times;</button>
                    <span class="media-preview-filename">@_selectedFile.Name</span>
                </div>
                <div class="media-preview-image-wrap">
                    @if (_videoPreviewBlobUrl is not null)
                    {
                        <video src="@_videoPreviewBlobUrl" class="media-preview-video"
                               controls playsinline muted preload="auto"></video>
                    }
                    else if (_previewDataUrl is not null)
                    {
                        <img src="@_previewDataUrl" alt="Video preview" class="media-preview-image" />
                        <div class="media-preview-video-badge">&#9658; Video</div>
                    }
                    else
                    {
                        <div class="media-preview-placeholder">&#127909; Loading video...</div>
                    }
                </div>
                <div class="media-preview-footer">
                    <span class="media-preview-size">@FormatFileSize(_selectedFile.Size)</span>
                </div>
            </div>
        }
        else
        {
            @* File/audio — compact bar *@
            <div class="file-preview-bar">
                <div class="file-preview-icon">@GetFileIcon(_selectedContentType)</div>
                <div class="file-preview-info">
                    <span class="file-preview-name">@_selectedFile.Name</span>
                    <span class="file-preview-size">@FormatFileSize(_selectedFile.Size)</span>
                </div>
                <button class="file-preview-remove" @onclick="ClearSelectedFile" aria-label="Remove attachment">&times;</button>
            </div>
        }
    }
    <div class="chat-input-row">
        @if (!_isRecording)
        {
            <div class="attach-menu-wrapper">
                @if (_showAttachMenu)
                {
                    <div class="attach-menu-backdrop" @onclick="CloseAttachMenu"></div>
                    <div class="attach-menu-popup" role="menu">
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#128247;</span>
                            <span>@Loc["Photo or Video"]</span>
                            <InputFile accept="image/*,video/*" OnChange="OnMediaSelected" style="display:none" />
                        </label>
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#127908;</span>
                            <span>@Loc["Audio"]</span>
                            <InputFile accept="audio/*" OnChange="OnAudioSelected" style="display:none" />
                        </label>
                        <label class="attach-menu-item" role="menuitem" tabindex="0">
                            <span class="attach-menu-icon">&#128196;</span>
                            <span>@Loc["Document"]</span>
                            <InputFile OnChange="OnDocumentSelected" style="display:none" />
                        </label>
                    </div>
                }
                <button class="attach-btn" @onclick="ToggleAttachMenu"
                        aria-label="Attach file" title="Attach file"
                        aria-expanded="@_showAttachMenu">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" />
                    </svg>
                </button>
            </div>

            <div class="attach-menu-wrapper">
                @if (_showEmojiPicker)
                {
                    <div class="attach-menu-backdrop" @onclick="() => _showEmojiPicker = false"></div>
                    <EmojiPicker OnEmojiSelected="InsertEmoji" OnClose="() => _showEmojiPicker = false" />
                }
                <button class="emoji-btn" @onclick="() => _showEmojiPicker = !_showEmojiPicker"
                        aria-label="Emoji" title="Emoji">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
                        <line x1="9" y1="9" x2="9.01" y2="9"/>
                        <line x1="15" y1="9" x2="15.01" y2="9"/>
                    </svg>
                </button>
            </div>

            <textarea @ref="_textareaRef"
                      @bind="_messageText"
                      @bind:event="oninput"
                      @bind:after="OnTextInput"
                      @onkeydown="HandleKeyDown"
                      placeholder="@Loc["Type a message..."]"
                      rows="1"
                      class="msg-textarea"
                      aria-label="Message input"></textarea>

            @if (CanSend)
            {
                <button @onclick="SendMessage"
                        class="send-btn send-btn-active"
                        aria-label="Send message"
                        title="Send">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z" />
                    </svg>
                </button>
            }
            else
            {
                <button class="mic-btn" @onclick="StartRecording"
                        aria-label="Record voice message" title="Record voice message">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
                        <path d="M19 10v2a7 7 0 01-14 0v-2"/>
                        <line x1="12" y1="19" x2="12" y2="23"/>
                        <line x1="8" y1="23" x2="16" y2="23"/>
                    </svg>
                </button>
            }
        }
        else
        {
            <VoiceRecorder OnRecorded="HandleVoiceRecorded" OnCancelled="HandleVoiceCancelled" />
        }
    </div>
</div>

@code {
    private string _messageText = "";
    private IBrowserFile? _selectedFile;
    private byte[]? _selectedFileBytes;
    private byte[]? _originalFileBytes; // Keeps original bytes for HD toggle
    private long _originalFileSize;
    private ContentType _selectedContentType = ContentType.Text;
    private string? _previewDataUrl;
    private string? _errorMessage;
    private bool _showAttachMenu;
    private bool _showEmojiPicker;
    private bool _isRecording;
    private bool _sendAsHd;
    private bool _globalHdDefault;
    private string? _videoPreviewBlobUrl;
    private ElementReference _textareaRef;
    private int _rateLimitRemaining;
    private Timer? _rateLimitTimer;
    private DateTime? _prevCooldownEnd;

    private bool CanSend => !string.IsNullOrWhiteSpace(_messageText) || _selectedFile is not null;

    [Parameter]
    public EventCallback<ChatInputMessage> OnSend { get; set; }

    [Parameter]
    public EventCallback OnTyping { get; set; }

    [Parameter]
    public ReplyContextModel? ReplyContext { get; set; }

    [Parameter]
    public EventCallback OnCancelReply { get; set; }

    // FR-002a: Rate limit cooldown parameter
    [Parameter]
    public DateTime? RateLimitCooldownEnd { get; set; }

    protected override void OnParametersSet()
    {
        // Start countdown timer when a new cooldown is set
        if (RateLimitCooldownEnd != _prevCooldownEnd && RateLimitCooldownEnd.HasValue)
        {
            _prevCooldownEnd = RateLimitCooldownEnd;
            StartRateLimitCountdown();
        }
    }

    private void StartRateLimitCountdown()
    {
        _rateLimitTimer?.Dispose();
        _rateLimitRemaining = RateLimitCooldownEnd.HasValue
            ? Math.Max(0, (int)(RateLimitCooldownEnd.Value - DateTime.UtcNow).TotalSeconds)
            : 0;

        if (_rateLimitRemaining <= 0) return;

        _rateLimitTimer = new Timer(_ =>
        {
            _rateLimitRemaining = RateLimitCooldownEnd.HasValue
                ? Math.Max(0, (int)(RateLimitCooldownEnd.Value - DateTime.UtcNow).TotalSeconds)
                : 0;

            InvokeAsync(StateHasChanged);

            if (_rateLimitRemaining <= 0)
            {
                _rateLimitTimer?.Dispose();
                _rateLimitTimer = null;
            }
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
    }

    // FR-032: Conversation ID for offline queue
    [Parameter]
    public long? ConversationId { get; set; }

    // FR-032: Callback when message is queued for offline sending
    [Parameter]
    public EventCallback OnQueuedOffline { get; set; }

    // FR-046: Callback when message send completes (success or failure)
    [Parameter]
    public EventCallback<bool> OnSendCompleted { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.preventEnterNewline", _textareaRef); }
            catch { /* ignored */ }

            try
            {
                var prefs = await Preferences.GetPreferencesAsync();
                _globalHdDefault = prefs.SendPhotoHd;
            }
            catch { /* fallback to false */ }
        }
    }

    private void ToggleAttachMenu()
    {
        _showAttachMenu = !_showAttachMenu;
    }

    private void CloseAttachMenu()
    {
        _showAttachMenu = false;
    }

    private async Task InsertEmoji(string emoji)
    {
        _showEmojiPicker = false;
        try
        {
            await Js.InvokeVoidAsync("mediaHelpers.insertTextAtCursor", _textareaRef, emoji);
            _messageText = await Js.InvokeAsync<string>("mediaHelpers.getTextareaValue", ".msg-textarea");
        }
        catch
        {
            // ignored
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
            await SendMessage();
    }

    private async Task OnTextInput()
    {
        await ResizeTextarea();
        await OnTyping.InvokeAsync();
    }

    private async Task ResizeTextarea()
    {
        try { await Js.InvokeVoidAsync("mediaHelpers.autoResize", _textareaRef); }
        catch
        {
            // ignored
        }
    }

    private async Task SendMessage()
    {
        if (!CanSend)
            return;

        var text = _messageText.Trim();
        byte[]? mediaBytes = null;
        string? fileName = null;
        string? mimeType = null;
        var contentType = ContentType.Text;

        if (_selectedFile is not null)
        {
            if (_selectedFileBytes is null)
            {
                _errorMessage = "Could not read the selected file. Please try again.";
                return;
            }

            // If HD is on, send original bytes; otherwise send compressed
            mediaBytes = _sendAsHd && _originalFileBytes is not null ? _originalFileBytes : _selectedFileBytes;
            fileName = _selectedFile.Name;
            // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
            mimeType = _selectedFile.ContentType ?? "image/jpeg";
            contentType = _selectedContentType;
        }

        if (string.IsNullOrEmpty(text) && mediaBytes is null)
            return;

        var msg = new ChatInputMessage
        {
            Text = text,
            MediaBytes = mediaBytes,
            FileName = fileName,
            MimeType = mimeType,
            ContentType = contentType,
            SendAsHd = _sendAsHd,
            ReplyToMessageId = ReplyContext?.MessageId
        };

        _messageText = "";
        // FR-046: Don't clear file - preserve selection on failure. Parent calls ClearInputAfterSend() on success.
        try { await Js.InvokeVoidAsync("mediaHelpers.resetHeight", _textareaRef); }
        catch
        {
            // ignored
        }

        // FR-032: Check if connected, queue offline if not
        if (!SignalR.IsConnected && ConversationId.HasValue)
        {
            try
            {
                var entry = new
                {
                    conversationId = ConversationId.Value,
                    text = msg.Text,
                    mediaBase64 = msg.MediaBytes is not null ? Convert.ToBase64String(msg.MediaBytes) : null,
                    fileName = msg.FileName,
                    mimeType = msg.MimeType,
                    contentType = msg.ContentType.ToString(),
                    sendAsHd = msg.SendAsHd,
                    replyToMessageId = msg.ReplyToMessageId
                };
                await Js.InvokeVoidAsync("toledoMessageStore.addToOfflineQueue", entry);
                // Notify parent that message was queued
                await OnQueuedOffline.InvokeAsync();
            }
            catch (Exception ex)
            {
                _errorMessage = ex.Message.Contains("OFFLINE_QUEUE_FULL")
                    ? "Message queue is full. Please try again when online."
                    : "Failed to queue message for offline sending.";
            }
            return;
        }

        await OnSend.InvokeAsync(msg);
    }

    private async Task OnMediaSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        if (e.FileCount == 0) return;
        var file = e.File;
        // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
        var contentType = file.ContentType ?? "image/jpeg";
        _selectedContentType = contentType.StartsWith("video/") ? ContentType.Video : ContentType.Image;

        // For videos, create a playable blob URL for preview
        if (_selectedContentType == ContentType.Video)
        {
            await SetSelectedFile(file, createPreview: false);
            if (_selectedFileBytes is not null)
            {
                try
                {
                    // Create playable video blob URL for the preview panel
                    var videoMime = file.ContentType ?? "video/mp4";
                    _videoPreviewBlobUrl = await Js.InvokeAsync<string>(
                        "mediaHelpers.createObjectUrl", _selectedFileBytes, videoMime);
                }
                catch
                {
                    // Video blob creation failed — try thumbnail fallback
                }

                // Also generate a static thumbnail as fallback
                if (_videoPreviewBlobUrl is null)
                {
                    try
                    {
                        var thumbnailBase64 = await Js.InvokeAsync<string>("mediaHelpers.captureVideoFrame",
                            _selectedFileBytes, file.ContentType ?? "video/mp4", 320, 0.75);
                        if (!string.IsNullOrEmpty(thumbnailBase64))
                        {
                            var thumbnailBytes = Convert.FromBase64String(thumbnailBase64);
                            _previewDataUrl = await Js.InvokeAsync<string>(
                                "mediaHelpers.createObjectUrl", thumbnailBytes, "image/jpeg");
                        }
                    }
                    catch
                    {
                        // Video thumbnail generation failed — show without preview
                    }
                }
            }
        }
        else
        {
            await SetSelectedFile(file, createPreview: _selectedContentType == ContentType.Image);
        }
    }

    private async Task OnAudioSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        if (e.FileCount == 0) return;
        _selectedContentType = ContentType.Audio;
        await SetSelectedFile(e.File, createPreview: false);
    }

    private async Task OnDocumentSelected(InputFileChangeEventArgs e)
    {
        _showAttachMenu = false;
        if (e.FileCount == 0) return;
        _selectedContentType = ContentType.File;
        await SetSelectedFile(e.File, createPreview: false);
    }

    private async Task SetSelectedFile(IBrowserFile file, bool createPreview)
    {
        // Save content type — ClearSelectedFile resets it
        var savedContentType = _selectedContentType;
        ClearSelectedFile();
        _selectedContentType = savedContentType;
        _errorMessage = null;
        _sendAsHd = _globalHdDefault;

        var maxFileSize = ProtocolConstants.MaxMediaFileSizeBytes;
        if (file.Size > maxFileSize)
        {
            _errorMessage = $"File too large. Maximum is {FormatFileSize(maxFileSize)}.";
            return;
        }

        // Read bytes eagerly
        await using var stream = file.OpenReadStream(maxAllowedSize: maxFileSize);
        _selectedFileBytes = new byte[file.Size];
        await stream.ReadExactlyAsync(_selectedFileBytes);

        _selectedFile = file;
        _originalFileSize = file.Size;

        // Compress images by default (standard quality mode) unless HD is on
        if (createPreview && _selectedContentType == ContentType.Image)
        {
            // Keep original bytes for HD toggle
            _originalFileBytes = _selectedFileBytes;

            // Only compress if HD mode is off (standard quality)
            if (!_sendAsHd)
            {
                try
                {
                    // ReSharper disable NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
                    var mimeType = file.ContentType ?? "image/jpeg";
                    var compressed = await Js.InvokeAsync<CompressedImageResult>(
                        "mediaHelpers.compressImage", _selectedFileBytes, mimeType, 1600, 0.8);

                    if (compressed.Bytes is not null && compressed.Bytes.Length > 0)
                    {
                        _selectedFileBytes = compressed.Bytes;
                    }
                }
                catch (Exception)
                {
                    // Continue without compression — original bytes will be used
                }
            }

            // Create preview from the active bytes (compressed or original)
            try
            {
                _previewDataUrl = await Js.InvokeAsync<string>(
                    "mediaHelpers.createObjectUrl", _selectedFileBytes, "image/jpeg");
            }
            // ReSharper disable once EmptyGeneralCatchClause
            catch (Exception)
            {
            }

            // Fallback to data URL if blob creation failed
            if (_previewDataUrl is null && _selectedFileBytes is not null)
            {
                var base64 = Convert.ToBase64String(_selectedFileBytes);
                _previewDataUrl = $"data:image/jpeg;base64,{base64}";
            }
        }
        else if (createPreview && _selectedFileBytes is not null)
        {
            try
            {
                // ReSharper disable once NullCoalescingConditionIsAlwaysNotNullAccordingToAPIContract
                var mimeType = file.ContentType ?? "image/jpeg";
                _previewDataUrl = await Js.InvokeAsync<string>(
                    "mediaHelpers.createObjectUrl", _selectedFileBytes, mimeType);
            }
            catch
            {
                // Preview is optional
            }
        }
    }

    private sealed class CompressedImageResult
    {
        // ReSharper disable  PropertyCanBeMadeInitOnly.Local
        public byte[]? Bytes { get; set; }
        public int Width { get; set; }
        public int Height { get; set; }
    }

    private async Task ToggleHdQuality()
    {
        if (_selectedFile is null || _selectedContentType != ContentType.Image) return;

        _sendAsHd = !_sendAsHd;

        // Revoke old preview
        if (_previewDataUrl is not null)
        {
            await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
            _previewDataUrl = null;
        }

        if (_sendAsHd)
        {
            // Switch to original (HD) bytes for preview
            if (_originalFileBytes is not null)
            {
                _selectedFileBytes = _originalFileBytes;
                try
                {
                    var mimeType = _selectedFile.ContentType ?? "image/jpeg";
                    _previewDataUrl = await Js.InvokeAsync<string>(
                        "mediaHelpers.createObjectUrl", _originalFileBytes, mimeType);
                }
                catch { /* ignore preview errors */ }
            }
        }
        else
        {
            // Re-compress the image
            if (_originalFileBytes is not null)
            {
                try
                {
                    var mimeType = _selectedFile.ContentType ?? "image/jpeg";
                    var compressed = await Js.InvokeAsync<CompressedImageResult>(
                        "mediaHelpers.compressImage", _originalFileBytes, mimeType, 1600, 0.8);

                    if (compressed.Bytes is not null && compressed.Bytes.Length > 0)
                    {
                        _selectedFileBytes = compressed.Bytes;
                    }
                }
                catch { /* ignore compression errors — use original */ }
            }

            // Show compressed preview
            if (_selectedFileBytes is not null)
            {
                try
                {
                    _previewDataUrl = await Js.InvokeAsync<string>(
                        "mediaHelpers.createObjectUrl", _selectedFileBytes, "image/jpeg");
                }
                catch { /* ignore preview errors */ }
            }
        }
    }

    private void ClearSelectedFile()
    {
        if (_previewDataUrl is not null)
        {
            _ = Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl);
            _previewDataUrl = null;
        }
        if (_videoPreviewBlobUrl is not null)
        {
            _ = Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _videoPreviewBlobUrl);
            _videoPreviewBlobUrl = null;
        }
        _selectedFile = null;
        _selectedFileBytes = null;
        _originalFileBytes = null;
        _originalFileSize = 0;
        _selectedContentType = ContentType.Text;
        _sendAsHd = false;
        _errorMessage = null;
    }

    private void StartRecording()
    {
        _isRecording = true;
    }

    private async Task HandleVoiceRecorded(VoiceRecorder.VoiceRecordingResult result)
    {
        _isRecording = false;

        var ext = result.MimeType switch
        {
            "audio/ogg" => "ogg",
            "audio/mp4" => "m4a",
            _ => "webm"
        };

        var msg = new ChatInputMessage
        {
            Text = "",
            MediaBytes = result.AudioData,
            FileName = $"voice_{DateTimeOffset.UtcNow:yyyyMMdd_HHmmss}.{ext}",
            MimeType = result.MimeType,
            ContentType = ContentType.Audio,
            ReplyToMessageId = ReplyContext?.MessageId,
            Waveform = result.Waveform
        };

        await OnSend.InvokeAsync(msg);
    }

    private void HandleVoiceCancelled()
    {
        _isRecording = false;
    }

    private static string GetFileIcon(ContentType type)
    {
        return type switch
        {
            ContentType.Audio => "\ud83c\udfb5",
            ContentType.Video => "\ud83c\udfac",
            ContentType.Image => "\ud83d\uddbc\ufe0f",
            _ => "\ud83d\udcc4"
        };
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    public sealed class ChatInputMessage
    {
        public string Text { get; set; } = "";
        public byte[]? MediaBytes { get; set; }
        public string? FileName { get; set; }
        public string? MimeType { get; set; }
        public ContentType ContentType { get; set; } = ContentType.Text;
        public bool SendAsHd { get; set; }
        public bool HasMedia => MediaBytes is not null;
        public long? ReplyToMessageId { get; set; }
        public int[]? Waveform { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (_rateLimitTimer is not null)
        {
            await _rateLimitTimer.DisposeAsync();
        }
        if (_previewDataUrl is not null)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _previewDataUrl); }
            catch { /* ignored */ }
        }
        if (_videoPreviewBlobUrl is not null)
        {
            try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _videoPreviewBlobUrl); }
            catch { /* ignored */ }
        }
    }

    // FR-046: Clear input after successful send (preserves file on failure)
    public void ClearInputAfterSend()
    {
        ClearSelectedFile();
    }

    public sealed class ReplyContextModel
    {
        public long MessageId { get; set; }
