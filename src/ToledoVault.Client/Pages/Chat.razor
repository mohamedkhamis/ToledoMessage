    private async void HandleMessageDeleted(long messageId, long conversationId)
    {
        if (_disposed) return;
        try {
        if (conversationId != ConversationId)
            return;

        await InvokeAsync(async () =>
        {
            var msg = _messages.FirstOrDefault(m => m.MessageId == messageId);
            if (msg is not null)
            {
                // Revoke blob URLs to prevent memory leak
                if (msg.MediaDataUrl is not null && msg.MediaDataUrl.StartsWith("blob:"))
                {
                    try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", msg.MediaDataUrl); }
                    catch { /* ignored */ }
                    _blobUrls.Remove(msg.MediaDataUrl);
                }
                if (msg.ThumbnailDataUrl is not null && msg.ThumbnailDataUrl.StartsWith("blob:"))
                {
                    try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", msg.ThumbnailDataUrl); }
                    catch { /* ignored */ }
                    _blobUrls.Remove(msg.ThumbnailDataUrl);
                }

                _messages.Remove(msg);

                // Clear reply context if the deleted message was being replied to
                if (_replyingTo?.MessageId == messageId)
                    CancelReply();
            }
            _messageReactions.Remove(messageId);
            try { await MessageStore.UpdateMessageStatusAsync(messageId.ToString(CultureInfo.InvariantCulture), -1); }
            catch
            {
                // ignored
            }
            StateHasChanged();
        });
        } catch { /* prevent async void crash */ }
    }

    // FR-032: Handle SignalR reconnection - flush offline queue
    private async void HandleReconnected()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                await FlushOfflineQueueAsync();
                StateHasChanged();
            });
        }
        catch { /* prevent async void crash */ }
    }

    // FR-032: Flush offline queue - send queued messages
    private async Task FlushOfflineQueueAsync()
    {
        if (!SignalR.IsConnected || ConversationId <= 0)
            return;

        try
        {
            var queue = await Js.InvokeAsync<List<JsonElement>>("toledoMessageStore.getOfflineQueue", ConversationId, "pending");
            if (queue.Count == 0)
                return;

            foreach (var entry in queue)
            {
                try
                {
                    var text = entry.TryGetProperty("text", out var t) ? t.GetString() ?? "" : "";
                    byte[]? mediaBytes = null;
                    if (entry.TryGetProperty("mediaBase64", out var mb) && mb.ValueKind == JsonValueKind.String)
                    {
                        mediaBytes = Convert.FromBase64String(mb.GetString()!);
                    }
                    var fileName = entry.TryGetProperty("fileName", out var fn) ? fn.GetString() : null;
                    var mimeType = entry.TryGetProperty("mimeType", out var mt) ? mt.GetString() : null;
                    var contentTypeStr = entry.TryGetProperty("contentType", out var ct) ? ct.GetString() : "Text";
                    var sendAsHd = entry.TryGetProperty("sendAsHd", out var hd) && hd.GetBoolean();
                    var replyToMsgId = entry.TryGetProperty("replyToMessageId", out var rid) && rid.ValueKind == JsonValueKind.Number
                        ? rid.GetInt64() : (long?)null;

                    var id = entry.TryGetProperty("id", out var idProp) ? idProp.GetInt64() : 0;

                    var msg = new MessageInput.ChatInputMessage
                    {
                        Text = text,
                        MediaBytes = mediaBytes,
                        FileName = fileName,
                        MimeType = mimeType,
                        ContentType = Enum.Parse<ContentType>(contentTypeStr ?? "Text"),
                        SendAsHd = sendAsHd,
                        ReplyToMessageId = replyToMsgId
                    };

                    // Send the message
                    await SendTextToRecipients(msg.Text, null, msg.ReplyToMessageId);

                    // Remove from queue after successful send
                    if (id > 0)
                    {
                        await Js.InvokeVoidAsync("toledoMessageStore.removeFromOfflineQueue", id);
                    }
                }
                catch
                {
                    // Continue with next message if one fails
                }
            }
        }
        catch
        {
            // Queue flush failed - will retry on next reconnect
        }
    }

