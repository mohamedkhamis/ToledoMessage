    /// <summary>
    /// Extracts the user ID from a JWT token by decoding the payload.
    /// </summary>
    private static long ExtractUserIdFromJwt(string token)
    {
        var parts = token.Split('.');
        if (parts.Length != 3)
            throw new InvalidOperationException("Invalid JWT token format.");

        var payload = parts[1];
        // Fix base64 padding
        switch (payload.Length % 4)
        {
            case 2: payload += "=="; break;
            case 3: payload += "="; break;
        }
        // Handle base64url encoding (JWT uses base64url per RFC 7515)
        payload = payload.Replace('-', '+').Replace('_', '/');

        var jsonBytes = Convert.FromBase64String(payload);
        using var doc = JsonDocument.Parse(jsonBytes);
        var root = doc.RootElement;

        // Try "sub" claim first, then "nameid"
        if (root.TryGetProperty("sub", out var subProp))
            return long.Parse(subProp.GetString()!);

        if (root.TryGetProperty("nameid", out var nameidProp))
            return long.Parse(nameidProp.GetString()!);

        if (root.TryGetProperty("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier", out var fullProp))
            return long.Parse(fullProp.GetString()!);

        throw new InvalidOperationException("JWT token does not contain a user ID claim.");
    }

    private async Task LoadWallpaperStyle()
    {
        var wallpaperId = await Theme.GetWallpaperAsync();
        var themeId = await Theme.GetThemeAsync();
        var isDark = ThemeService.IsDarkTheme(themeId);

        if (wallpaperId == "none")
        {
            _wallpaperStyle = "--chat-bg-image: none;";
            return;
        }

        if (wallpaperId == "default")
        {
            // Let the theme's CSS handle it
            _wallpaperStyle = "";
            return;
        }

        var wallpaper = ThemeService.GetAvailableWallpapers()
            .FirstOrDefault(w => w.Id == wallpaperId);

        if (wallpaper is null)
        {
            _wallpaperStyle = "";
            return;
        }

        var pattern = isDark ? wallpaper.DarkPattern : wallpaper.LightPattern;
        _wallpaperStyle = pattern is not null ? $"--chat-bg-image: {pattern};" : "";
    }

