    private async Task ShowContextMenu(double x, double y, ChatMessage msg)
    {
        _contextMenuMessage = msg;
        _contextMenuX = x;

        // Get viewport height to determine if we need to flip the menu upward
        double viewportHeight;
        try { viewportHeight = await Js.InvokeAsync<double>("mediaHelpers.getViewportHeight"); }
        catch { viewportHeight = 800; }

        // Estimate menu height: ~40px per item, 5-6 items + padding
        var itemCount = 4 + (msg.IsMine ? 1 : 0) + (!string.IsNullOrEmpty(msg.MediaDataUrl) ? 1 : 0);
        var estimatedMenuHeight = itemCount * 40 + 16;

        if (y + estimatedMenuHeight > viewportHeight - 20)
        {
            _contextMenuFlipUp = true;
            _contextMenuBottomY = viewportHeight - y;
            _contextMenuY = 0; // unused when flipped
        }
        else
        {
            _contextMenuFlipUp = false;
            _contextMenuY = y;
            _contextMenuBottomY = 0;
        }

        _showContextMenu = true;
    }

