            if (_contextMenuMessage.MediaDataUrl is not null && _contextMenuMessage.MediaDataUrl.StartsWith("blob:"))
            {
                try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _contextMenuMessage.MediaDataUrl); }
