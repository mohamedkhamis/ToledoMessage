    private async Task UpdateSearchResults()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResults.Clear();
            _searchIndex = 0;
            return;
        }

        _searchResults = _messages
            .Where(m => !string.IsNullOrEmpty(m.Text) && m.Text.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            .ToList();

        _searchIndex = _searchResults.Count > 0 ? _searchResults.Count - 1 : 0;

        if (_searchResults.Count > 0)
            await ScrollToMessage(_searchResults[_searchIndex].MessageId);
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            CloseSearch();
        }
        else if (e.Key == "Enter")
        {
            if (e.ShiftKey)
                await SearchPrevious();
            else
                await SearchNext();
        }
    }

    private async Task SearchNext()
    {
        if (_searchResults.Count == 0) return;
        _searchIndex = (_searchIndex + 1) % _searchResults.Count;
        await ScrollToMessage(_searchResults[_searchIndex].MessageId);
    }

    private async Task SearchPrevious()
    {
        if (_searchResults.Count == 0) return;
        _searchIndex = (_searchIndex - 1 + _searchResults.Count) % _searchResults.Count;
        await ScrollToMessage(_searchResults[_searchIndex].MessageId);
    }

