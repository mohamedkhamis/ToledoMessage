                _blobUrls.Remove(_contextMenuMessage.MediaDataUrl);
            }
            if (_contextMenuMessage.ThumbnailDataUrl is not null && _contextMenuMessage.ThumbnailDataUrl.StartsWith("blob:"))
            {
                try { await Js.InvokeVoidAsync("mediaHelpers.revokeObjectUrl", _contextMenuMessage.ThumbnailDataUrl); }
                catch { /* ignored */ }
                _blobUrls.Remove(_contextMenuMessage.ThumbnailDataUrl);
            }

            _messages.Remove(_contextMenuMessage);
            _messageReactions.Remove(_contextMenuMessage.MessageId);

            // Clear reply context if replying to the deleted message
            if (_replyingTo?.MessageId == _contextMenuMessage.MessageId)
                CancelReply();

            try { await MessageStore.UpdateMessageStatusAsync(_contextMenuMessage.MessageId.ToString(CultureInfo.InvariantCulture), -1); }
            catch
