    private async Task HandleSend(MessageInput.ChatInputMessage input)
    {
        var hasMedia = input.HasMedia;

        var contentType = input.ContentType;

        string? mediaDataUrl = null;
        if (hasMedia && input.MediaBytes is not null)
        {
            try
            {
                var blobMime = input.MimeType ?? GetDefaultMimeType(contentType);
                mediaDataUrl = await CreateMediaBlobUrl(blobMime, input.MediaBytes);
            }
            // ReSharper disable EmptyGeneralCatchClause
            catch (Exception)
            {
            }

            // Fallback to data URL if blob URL creation failed
            if (mediaDataUrl is null)
            {
                var fallbackMime = input.MimeType ?? GetDefaultMimeType(contentType);
                var base64 = Convert.ToBase64String(input.MediaBytes);
                mediaDataUrl = $"data:{fallbackMime};base64,{base64}";
            }
        }

        var tempMessage = new ChatMessage
        {
            MessageId = 0,
            Text = input.Text,
            Timestamp = DateTimeOffset.UtcNow,
            IsMine = true,
            ContentType = contentType,
            FileName = input.FileName,
            MediaDataUrl = mediaDataUrl,
            MediaBytes = hasMedia ? input.MediaBytes : null,
            MimeType = hasMedia ? input.MimeType : null,
            Status = Shared.Enums.DeliveryStatus.Sending,
            Waveform = input.Waveform,
            ReplyToMessageId = _replyingTo?.MessageId,
            ReplyToSenderName = _replyingTo is not null ? (_replyingTo.IsMine ? "You" : GetSenderDisplayName(_replyingTo)) : null,
            ReplyToText = _replyingTo is not null ? FormatReplyText(_replyingTo) : null,
            ReplyToMediaDataUrl = _replyingTo?.MediaDataUrl,
            ReplyToThumbnailDataUrl = _replyingTo?.ThumbnailDataUrl,
            ReplyToContentType = _replyingTo?.ContentType ?? ContentType.Text
        };
        CancelReply();
        _messages.Add(tempMessage);
        _needsScrollToBottom = true;
        StateHasChanged();

        // FR-032: If disconnected, queue the message for later delivery
        if (!SignalR.IsConnected)
        {
            try
            {
                await Js.InvokeVoidAsync("toledoMessageStore.addToOfflineQueue", new
                {
                    conversationId = ConversationId.ToString(CultureInfo.InvariantCulture),
                    text = input.Text,
                    contentType = contentType.ToString(),
                    fileName = input.FileName,
                    mimeType = input.MimeType,
                    mediaBase64 = input.MediaBytes is not null ? Convert.ToBase64String(input.MediaBytes) : null,
                    sendAsHd = input.SendAsHd,
                    replyToMessageId = input.ReplyToMessageId
                });
                tempMessage.Status = Shared.Enums.DeliveryStatus.Sending; // Show as pending
                await PersistMessageAsync(tempMessage);
                _messageInput?.ClearInputAfterSend();
                await HandleMessageQueuedOffline();
            }
            catch (Exception ex) when (ex.Message.Contains("OFFLINE_QUEUE_FULL"))
            {
                _errorMessage = "Offline queue is full. Please wait until you are back online.";
            }
            catch
            {
                _errorMessage = "Failed to queue message for offline delivery.";
            }
            StateHasChanged();
            return;
        }

        try
        {
            // When there's media, we send the media as the encrypted payload.
            // The text caption is sent alongside as plain metadata (not encrypted separately).
            // When there's text only, we send a normal text message.
            if (hasMedia)
            {
                // Update input content type for SendMediaToRecipients
                input.ContentType = contentType;
                await SendMediaToRecipients(input, tempMessage);
            }
            else
            {
                await SendTextToRecipients(input.Text, tempMessage, input.ReplyToMessageId);
            }

            // Persist sent message to IndexedDB
            await PersistMessageAsync(tempMessage);

            // Release media bytes to free memory after persistence
            if (hasMedia)
            {
                tempMessage.MediaBytes = null;
            }

            // FR-046: Clear input after successful send (preserves file on failure)
            _messageInput?.ClearInputAfterSend();
        }
        catch (Exception ex)
        {
            // FR-002a: Handle rate limit errors with countdown
            if (ex.Message.Contains("RATE_LIMIT_EXCEEDED"))
            {
                _rateLimitCooldownEnd = DateTime.UtcNow.AddSeconds(60);
                _errorMessage = "You are sending messages too quickly. Please wait before sending more.";
            }
            else
            {
                _errorMessage = $"Failed to send message: {ex.Message}";
            }
        }

        StateHasChanged();
    }

    private async Task SendTextToRecipients(string text, ChatMessage? tempMessage, long? replyToMessageId = null)
    {
        if (_conversationDetail is not null && _conversationDetail.Type == ConversationType.Group)
        {
            var requests = await Crypto.EncryptGroupMessageAsync(ConversationId, _localUserId, _localDeviceId, text);

            SendMessageResult? lastResult = null;
            foreach (var request in requests)
            {
                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage?.MessageId = lastResult.MessageId;
                tempMessage?.SequenceNumber = lastResult.SequenceNumber;
                tempMessage?.Timestamp = lastResult.ServerTimestamp;
                tempMessage?.Status = Shared.Enums.DeliveryStatus.Sent;
            }
        }
        else
        {
            var recipient = _participants.FirstOrDefault(p => p.UserId != _localUserId);
            if (recipient is null)
            {
                _errorMessage = "Could not determine the recipient.";
                return;
            }

            var deviceCiphertexts = await Crypto.EncryptMessageForAllDevicesAsync(recipient.UserId, text);

            SendMessageResult? lastResult = null;
            foreach (var (deviceId, ciphertextBase64, messageType) in deviceCiphertexts)
            {
                var request = new SendMessageRequest
                {
                    ConversationId = ConversationId,
                    SenderDeviceId = _localDeviceId,
                    RecipientDeviceId = deviceId,
                    Ciphertext = ciphertextBase64,
                    MessageType = messageType,
                    ContentType = ContentType.Text,
                    ReplyToMessageId = replyToMessageId
                };

                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage?.MessageId = lastResult.MessageId;
                tempMessage?.SequenceNumber = lastResult.SequenceNumber;
                tempMessage?.Timestamp = lastResult.ServerTimestamp;
                tempMessage?.Status = Shared.Enums.DeliveryStatus.Sent;
            }
        }
    }

    private async Task SendMediaToRecipients(MessageInput.ChatInputMessage input, ChatMessage tempMessage)
    {
        // Generate thumbnail for images and videos
        string? thumbnailBase64 = null;
        if (input.ContentType == ContentType.Image)
        {
            try
            {
                // generateThumbnail returns a base64 string (not byte[])
                var thumbnailBase64Result = await Js.InvokeAsync<string>("mediaHelpers.generateThumbnail",
                    input.MediaBytes, input.MimeType, 200, 0.6);
                if (!string.IsNullOrEmpty(thumbnailBase64Result))
                {
                    thumbnailBase64 = thumbnailBase64Result;
                }
            }
            catch (Exception)
            {
            }
        }
        else if (input.ContentType == ContentType.Video)
        {
            try
            {
                var thumbnailBase64Result = await Js.InvokeAsync<string>("mediaHelpers.captureVideoFrame",
                    input.MediaBytes, input.MimeType ?? "video/mp4", 320, 0.75);
                if (!string.IsNullOrEmpty(thumbnailBase64Result))
                {
                    thumbnailBase64 = thumbnailBase64Result;
                }
            }
            catch (Exception)
            {
            }
        }

        // Set thumbnail blob URL on the sender's temp message for immediate display
        if (!string.IsNullOrEmpty(thumbnailBase64))
        {
            try
            {
                var thumbBytes = Convert.FromBase64String(thumbnailBase64);
                tempMessage.ThumbnailDataUrl = await CreateMediaBlobUrl("image/jpeg", thumbBytes);
            }
            catch (Exception)
            {
            }
        }

        // Create MediaPayload with all metadata bundled inside
        var mediaPayload = new MediaPayload
        {
            FileName = MediaPayload.SanitizeFileName(input.FileName),
            MimeType = input.MimeType ?? "application/octet-stream",
            Caption = input.Text,
            Thumbnail = thumbnailBase64,
            Data = Convert.ToBase64String(input.MediaBytes!),
            Waveform = input.Waveform
        };

        // Serialize payload to bytes
        var payloadBytes = MediaPayload.Serialize(mediaPayload);

        if (_conversationDetail is not null && _conversationDetail.Type == ConversationType.Group)
        {
            var requests = await Crypto.EncryptGroupBytesAsync(
                ConversationId, _localUserId, _localDeviceId,
                payloadBytes, input.ContentType, null, null);

            SendMessageResult? lastResult = null;
            foreach (var request in requests)
            {
                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.SequenceNumber = lastResult.SequenceNumber;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = Shared.Enums.DeliveryStatus.Sent;
            }
        }
        else
        {
            var recipient = _participants.FirstOrDefault(p => p.UserId != _localUserId);
            if (recipient is null)
            {
                _errorMessage = "Could not determine the recipient.";
                return;
            }

            var deviceCiphertexts = await Crypto.EncryptBytesForAllDevicesAsync(recipient.UserId, payloadBytes);

            SendMessageResult? lastResult = null;
            foreach (var (deviceId, ciphertextBase64, messageType) in deviceCiphertexts)
            {
                var request = new SendMessageRequest
                {
                    ConversationId = ConversationId,
                    SenderDeviceId = _localDeviceId,
                    RecipientDeviceId = deviceId,
                    Ciphertext = ciphertextBase64,
                    MessageType = messageType,
                    ContentType = input.ContentType,
                    FileName = null, // FileName now inside encrypted payload
                    MimeType = null, // MimeType now inside encrypted payload
                    ReplyToMessageId = input.ReplyToMessageId
                };

                lastResult = await SignalR.SendMessageAsync(request);
            }

            if (lastResult is not null)
            {
                tempMessage.MessageId = lastResult.MessageId;
                tempMessage.SequenceNumber = lastResult.SequenceNumber;
                tempMessage.Timestamp = lastResult.ServerTimestamp;
                tempMessage.Status = Shared.Enums.DeliveryStatus.Sent;
            }
        }
    }

    private async Task<ChatMessage> DecryptEnvelopeToChatMessage(MessageEnvelope envelope, bool isMine)
    {
        // Resolve reply info from local messages
        string? replyToText = null;
        string? replyToSenderName = null;
        string? replyToMediaDataUrl = null;
        string? replyToThumbnailDataUrl = null;
        ContentType replyToContentType = ContentType.Text;
        if (envelope.ReplyToMessageId.HasValue)
        {
            var replyMsg = _messages.FirstOrDefault(m => m.MessageId == envelope.ReplyToMessageId.Value);
            if (replyMsg is not null)
            {
                replyToSenderName = replyMsg.IsMine ? "You" : GetSenderDisplayName(replyMsg);
                replyToText = FormatReplyText(replyMsg);
                replyToMediaDataUrl = replyMsg.MediaDataUrl;
                replyToThumbnailDataUrl = replyMsg.ThumbnailDataUrl;
                replyToContentType = replyMsg.ContentType;
            }
            else
            {
                replyToSenderName = "...";
                replyToText = "...";
            }
        }

        if (envelope.ContentType is ContentType.Image or ContentType.Audio or ContentType.Video or ContentType.File)
        {
            // Decrypt to bytes and deserialize as MediaPayload
            var payloadBytes = await Crypto.DecryptToBytesAsync(
                envelope.SenderDeviceId, envelope.Ciphertext, envelope.MessageType);
            var mediaPayload = MediaPayload.Deserialize(payloadBytes);

            // Decode media data from base64
            var mediaData = Convert.FromBase64String(mediaPayload.Data);

            // Get MIME type from payload or fall back to envelope/default
            var mimeType = !string.IsNullOrEmpty(mediaPayload.MimeType)
                ? mediaPayload.MimeType
                : (envelope.MimeType ?? GetDefaultMimeType(envelope.ContentType));

            // Create blob URL for full media
            var blobUrl = await CreateMediaBlobUrl(mimeType, mediaData);

            // Create thumbnail blob URL if available
            string? thumbnailBlobUrl = null;
            if (!string.IsNullOrEmpty(mediaPayload.Thumbnail))
            {
                try
                {
                    var thumbnailData = Convert.FromBase64String(mediaPayload.Thumbnail);
                    thumbnailBlobUrl = await CreateMediaBlobUrl("image/jpeg", thumbnailData);
                }
                catch (Exception)
                {
                }
            }

            // For audio: use waveform from payload, or analyze the audio bytes
            int[]? waveform = mediaPayload.Waveform;
            if (waveform is null && envelope.ContentType == ContentType.Audio)
            {
                try
                {
                    waveform = await Js.InvokeAsync<int[]?>("mediaHelpers.analyzeAudioWaveform",
                        mediaData, mimeType, 64);
                }
                catch { /* fallback to null — MessageBubble will use static bars */ }
            }

            return new ChatMessage
            {
                MessageId = envelope.MessageId,
                SequenceNumber = envelope.SequenceNumber,
                Text = mediaPayload.Caption ?? "",
                Timestamp = envelope.ServerTimestamp,
                IsMine = isMine,
                ContentType = envelope.ContentType,
                FileName = MediaPayload.SanitizeFileName(mediaPayload.FileName),
                MediaDataUrl = blobUrl,
                ThumbnailDataUrl = thumbnailBlobUrl,
                MediaBytes = mediaData, // Keep for IndexedDB persistence - will be nulled after persist
                MimeType = mimeType,
                Status = Shared.Enums.DeliveryStatus.Delivered,
                Waveform = waveform,
                ReplyToMessageId = envelope.ReplyToMessageId,
                ReplyToText = replyToText,
                ReplyToSenderName = replyToSenderName,
                ReplyToMediaDataUrl = replyToMediaDataUrl,
                ReplyToThumbnailDataUrl = replyToThumbnailDataUrl,
                ReplyToContentType = replyToContentType
            };
        }
        else
        {
            // Decrypt as bytes first so we can detect misrouted media payloads
            var decryptedBytes = await Crypto.DecryptToBytesAsync(
                envelope.SenderDeviceId, envelope.Ciphertext, envelope.MessageType);

            // Defensive check: if ContentType came through as Text but the decrypted content
            // is actually a MediaPayload JSON (e.g., due to enum serialization issues over SignalR),
            // detect and handle it as media instead of displaying raw JSON to the user.
            if (decryptedBytes.Length > 5 && decryptedBytes[0] == (byte)'{')
            {
                try
                {
                    var possiblePayload = MediaPayload.Deserialize(decryptedBytes);
                    if (!string.IsNullOrEmpty(possiblePayload.Data) && !string.IsNullOrEmpty(possiblePayload.MimeType))
                    {
                        var mediaData = Convert.FromBase64String(possiblePayload.Data);
                        var mimeType = possiblePayload.MimeType;
                        var blobUrl = await CreateMediaBlobUrl(mimeType, mediaData);

                        string? thumbnailBlobUrl = null;
                        if (!string.IsNullOrEmpty(possiblePayload.Thumbnail))
                        {
                            try
                            {
                                var thumbnailData = Convert.FromBase64String(possiblePayload.Thumbnail);
                                thumbnailBlobUrl = await CreateMediaBlobUrl("image/jpeg", thumbnailData);
                            }
                            catch { /* ignored */ }
                        }

                        // Infer content type from MIME type
                        var inferredContentType = mimeType.ToLowerInvariant() switch
                        {
                            var m when m.StartsWith("image/") => ContentType.Image,
                            var m when m.StartsWith("video/") => ContentType.Video,
                            var m when m.StartsWith("audio/") => ContentType.Audio,
                            _ => ContentType.File
                        };

                        return new ChatMessage
                        {
                            MessageId = envelope.MessageId,
                            Text = possiblePayload.Caption ?? "",
                            Timestamp = envelope.ServerTimestamp,
                            IsMine = isMine,
                            ContentType = inferredContentType,
                            FileName = MediaPayload.SanitizeFileName(possiblePayload.FileName),
                            MediaDataUrl = blobUrl,
                            ThumbnailDataUrl = thumbnailBlobUrl,
                            MediaBytes = mediaData,
                            MimeType = mimeType,
                            Waveform = possiblePayload.Waveform,
                            Status = Shared.Enums.DeliveryStatus.Delivered,
                            ReplyToMessageId = envelope.ReplyToMessageId,
                            ReplyToText = replyToText,
                            ReplyToSenderName = replyToSenderName
                        };
                    }
                }
                catch
                {
                    // Not a MediaPayload — fall through to normal text handling
                }
            }

            var plaintext = Encoding.UTF8.GetString(decryptedBytes);
            return new ChatMessage
            {
                MessageId = envelope.MessageId,
                SequenceNumber = envelope.SequenceNumber,
                Text = plaintext,
                Timestamp = envelope.ServerTimestamp,
                IsMine = isMine,
                ContentType = ContentType.Text,
                Status = Shared.Enums.DeliveryStatus.Delivered,
                ReplyToMessageId = envelope.ReplyToMessageId,
                ReplyToText = replyToText,
                ReplyToSenderName = replyToSenderName
            };
        }
    }

