@page "/chat/{ConversationId:long}"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@layout ChatLayout
@using System.Globalization
@using System.Text
@using System.Text.Json
@using ToledoVault.Shared.Helpers
@using ToledoVault.Shared.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject CryptoService Crypto
@inject SignalRService SignalR
@inject LocalStorageService Storage
@* ReSharper disable  UnusedMember.Local *@
@inject PreKeyReplenishmentService PreKeyReplenishment
@inject IJSRuntime Js
@inject MessageStoreService MessageStore
@inject ThemeService Theme
@inject MessageExpiryService MessageExpiry
@inject IStringLocalizer<SharedResource> Loc
@implements IAsyncDisposable

<div class="chat-container">
    <div class="chat-header">
        @* FR-026: Offline indicator *@
        @if (!SignalR.IsConnected)
        {
            <div class="offline-indicator" role="alert">
                @Loc["Offline - messages will be sent when connected"]
            </div>
        }

        <button class="back-link back-link-desktop-hidden" @onclick="NavigateBack" aria-label="Back to conversations">&larr;</button>
        @{
            var peer = _participants.FirstOrDefault(p => p.UserId != _localUserId);
            var headerName = _conversationDetail?.Type == ConversationType.Group
                ? (_conversationDetail.GroupName ?? "Group")
                : (peer is not null ? DisplayNameHelper.Resolve(peer.DisplayName, peer.DisplayNameSecondary) : "Conversation");
        }
        <AvatarInitials DisplayName="@headerName" Size="38" />
        <div>
            <h3 class="chat-header-title">@headerName</h3>
            @if (_conversationDetail is not null && _conversationDetail.Type == ConversationType.Group)
            {
                <span class="chat-header-subtitle">@string.Format(Loc["{0} members"], _participants.Count)</span>
            }
            else if (_peerIsOnline)
            {
                <span class="chat-header-subtitle presence-online">@Loc["online"]</span>
            }
            else if (_peerLastSeen.HasValue)
            {
                <span class="chat-header-subtitle presence-text">@string.Format(Loc["last seen {0}"], _peerLastSeen.Value.ToLocalTime().ToString("MMM d, HH:mm"))</span>
            }
        </div>
        @if (!string.IsNullOrEmpty(_typingIndicator))
        {
            <span class="chat-typing-indicator">@_typingIndicator</span>
        }
        <div style="margin-left:auto; display:flex; align-items:center; gap:4px;">
            <button class="msg-action-btn" @onclick="ToggleSearch" title="@Loc["Search messages..."]">&#128269;</button>
            <button class="msg-action-btn" @onclick="() => _showChatMenu = !_showChatMenu" title="More options">&#8942;</button>
            @if (_showChatMenu)
            {
                <div class="context-menu-backdrop" @onclick="() => _showChatMenu = false"></div>
                <div class="context-menu chat-header-menu">
                    <button class="context-menu-item danger" @onclick="OpenClearChatDialog">
                        <span class="context-menu-icon">&#128465;</span> @Loc["Clear chat"]
                    </button>
                </div>
            }
        </div>
    </div>

    @if (_showSearch)
    {
        <div class="chat-search-bar">
            <input type="text" class="chat-search-input" placeholder="@Loc["Search messages..."]"
                   @bind="_searchQuery" @bind:event="oninput" @bind:after="UpdateSearchResults"
                   @onkeydown="HandleSearchKeyDown" />
            @if (_searchResults.Count > 0)
            {
                <span class="chat-search-count">@(_searchIndex + 1) / @_searchResults.Count</span>
            }
            else if (!string.IsNullOrEmpty(_searchQuery))
            {
                <span class="chat-search-count">0 / 0</span>
            }
            <button class="msg-action-btn" @onclick="SearchPrevious" title="Previous match" disabled="@(_searchResults.Count == 0)">&#9650;</button>
            <button class="msg-action-btn" @onclick="SearchNext" title="Next match" disabled="@(_searchResults.Count == 0)">&#9660;</button>
            <button class="msg-action-btn" @onclick="CloseSearch" title="Close search">&#10005;</button>
        </div>
    }

    @if (_conversationDetail is not null && _conversationDetail.Type == ConversationType.Group && _showParticipants)
    {
        <div class="participants-panel">
            <div class="participants-list">
                @foreach (var p in _participants)
                {
                    <span class="participant-tag">
                        @DisplayNameHelper.Resolve(p.DisplayName, p.DisplayNameSecondary)
                        @if (p.Role == ParticipantRole.Admin)
                        {
                            <span class="participant-admin">Admin</span>
                        }
                    </span>
                }
            </div>
        </div>
    }

    @if (_conversationDetail is not null && _conversationDetail.Type == ConversationType.Group)
    {
        <div class="toggle-participants-row">
            <button class="toggle-participants-btn"
                    @onclick="() => _showParticipants = !_showParticipants">
                @(_showParticipants ? "Hide participants" : "Show participants")
            </button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-error mx-chat" role="alert">
            @_errorMessage
            <button class="btn-link" @onclick="RetryLoadMessages">@Loc["Retry"]</button>
        </div>
    }
    @if (!string.IsNullOrEmpty(_infoMessage))
    {
        <div class="alert alert-info mx-chat" role="status">
            @_infoMessage
        </div>
    }

    <div class="chat-messages" @ref="_messageContainer" role="log" aria-live="polite"
         style="@_wallpaperStyle">
        @if (_isLoading)
        {
            <SkeletonLoader Variant="SkeletonLoader.SkeletonVariant.ChatMessages" />
        }
        else if (_messages.Count == 0)
        {
            <div class="empty-state">
                <svg class="empty-state-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
                </svg>
                <h3>@Loc["No messages yet"]</h3>
                <p>@Loc["Send the first message to start the conversation."]</p>
            </div>
        }
        else
        {
            @if (_hasMoreMessages)
            {
                <div class="load-earlier-messages">
                    <button class="btn-link" @onclick="LoadEarlierMessages" disabled="@_isLoadingMore">
                        @if (_isLoadingMore)
                        {
                            <span>@Loc["Loading..."]</span>
                        }
                        else
                        {
                            <span>&#8593; @Loc["Load earlier messages"]</span>
                        }
                    </button>
                </div>
            }
            @for (int i = 0; i < _messages.Count; i++)
            {
                var msg = _messages[i];
                var prevMsg = i > 0 ? _messages[i - 1] : null;
                var nextMsg = i < _messages.Count - 1 ? _messages[i + 1] : null;

                bool showDateSeparator = prevMsg is null ||
                    msg.Timestamp.LocalDateTime.Date != prevMsg.Timestamp.LocalDateTime.Date;

                if (showDateSeparator)
                {
                    <DateSeparator Date="msg.Timestamp" />
                }

                @if (_firstUnreadMessageId.HasValue && msg.MessageId == _firstUnreadMessageId.Value)
                {
                    var unreadCount = _serverUnreadCount;
                    <div class="unread-divider">
                        <span>@string.Format(Loc["{0} new message(s)"], unreadCount)</span>
                    </div>
                }

                bool isFirstInGroup = prevMsg is null || prevMsg.IsMine != msg.IsMine || showDateSeparator;
                bool isLastInGroup = nextMsg is null || nextMsg.IsMine != msg.IsMine ||
                    nextMsg.Timestamp.LocalDateTime.Date != msg.Timestamp.LocalDateTime.Date;

                <MessageBubble @key="msg" MessageId="msg.MessageId"
                               Text="@msg.Text"
                               Timestamp="msg.Timestamp"
                               IsMine="msg.IsMine"
                               Status="msg.Status"
                               ContentType="msg.ContentType"
                               MediaDataUrl="@msg.MediaDataUrl"
                               ThumbnailDataUrl="@msg.ThumbnailDataUrl"
                               MimeType="@msg.MimeType"
                               FileName="@msg.FileName"
                               IsFirstInGroup="isFirstInGroup"
                               IsLastInGroup="isLastInGroup"
                               IsForwarded="msg.IsForwarded"
                               IsSearchHighlight="IsSearchHighlighted(msg.MessageId)"
                               OnImageClick="HandleImageClick"
                               OnVideoClick="HandleVideoClick"
                               OnReply="() => SetReplyTo(msg)"
                               OnContextMenu="(pos) => ShowContextMenu(pos.X, pos.Y, msg)"
                               ReplyToMessageId="msg.ReplyToMessageId"
                               ReplyToSenderName="@msg.ReplyToSenderName"
                               ReplyToText="@msg.ReplyToText"
                               ReplyToMediaDataUrl="@msg.ReplyToMediaDataUrl"
                               ReplyToThumbnailDataUrl="@msg.ReplyToThumbnailDataUrl"
                               ReplyToContentType="msg.ReplyToContentType"
                               AudioWaveform="msg.Waveform"
                               FileSizeBytes="msg.MediaBytes?.Length ?? 0"
                               OnReplyQuoteClick="ScrollToMessage"
                               ReactionBadges="GetReactionBadges(msg.MessageId)"
                               OnReactionToggle="(emoji) => ToggleReaction(msg.MessageId, emoji)"
                               OnPdfThumbnailGenerated="(thumb) => { msg.ThumbnailDataUrl = thumb; }" />
            }
        }
    </div>

    <ScrollToBottom Visible="_showScrollButton" OnClick="ScrollToBottom" />
    <MessageInput @ref="_messageInput" OnSend="HandleSend" OnTyping="HandleTyping"
                  ReplyContext="@_replyContext" OnCancelReply="CancelReply"
                  RateLimitCooldownEnd="@_rateLimitCooldownEnd"
                  ConversationId="@ConversationId"
                  OnQueuedOffline="HandleMessageQueuedOffline" />
</div>

<ImageLightbox IsVisible="_lightboxVisible"
               ImageUrls="_lightboxImageUrls"
               CurrentIndex="_lightboxIndex"
               OnClose="CloseLightbox"
               OnIndexChanged="SetLightboxIndex" />

@if (_videoLightboxVisible && _videoLightboxUrl is not null)
{
    <div class="video-lightbox-overlay" @onclick="CloseVideoLightbox">
        <button class="lightbox-close" @onclick="CloseVideoLightbox" aria-label="Close">&times;</button>
        <div class="video-lightbox-content" @onclick:stopPropagation="true">
            <video controls autoplay playsinline
                   src="@_videoLightboxUrl"
                   class="video-lightbox-player"
                   aria-label="Video player">
                Your browser does not support video playback.
            </video>
        </div>
    </div>
}

@if (_showContextMenu && _contextMenuMessage is not null)
{
    <div class="context-menu-backdrop" @onclick="CloseContextMenu"></div>
    <div class="context-menu @(_contextMenuFlipUp ? "flip-up" : "")" style="left: @(_contextMenuX)px; @(_contextMenuFlipUp ? $"bottom: {_contextMenuBottomY}px" : $"top: {_contextMenuY}px");">
        <button class="context-menu-item" @onclick="CopyMessageText">
            <span class="context-menu-icon">&#128203;</span> @Loc["Copy"]
        </button>
        <button class="context-menu-item" @onclick="ReplyFromContextMenu">
            <span class="context-menu-icon">&#8617;</span> @Loc["Reply"]
        </button>
        @if (!string.IsNullOrEmpty(_contextMenuMessage.MediaDataUrl))
        {
            <button class="context-menu-item" @onclick="DownloadMediaFromContextMenu">
                <span class="context-menu-icon">&#8595;</span> @Loc["Download"]
            </button>
        }
        <button class="context-menu-item" @onclick="ForwardFromContextMenu">
            <span class="context-menu-icon">&#10150;</span> @Loc["Forward"]
        </button>
        <button class="context-menu-item danger" @onclick="DeleteForMe">
            <span class="context-menu-icon">&#128465;</span> @Loc["Delete for me"]
        </button>
        @if (_contextMenuMessage.IsMine)
        {
            <button class="context-menu-item danger" @onclick="DeleteForEveryone">
                <span class="context-menu-icon">&#128465;</span> @Loc["Delete for everyone"]
            </button>
        }
    </div>
}

@if (_showClearChatDialog)
{
    <div class="context-menu-backdrop" @onclick="() => _showClearChatDialog = false"></div>
    <div class="clear-chat-dialog">
        <h4>@Loc["Clear chat messages"]</h4>
        <p>@Loc["Choose which messages to delete:"]</p>
        <div class="clear-chat-options">
            <button class="clear-chat-option" @onclick="() => ClearChat(TimeSpan.FromHours(1))">@Loc["Last hour"]</button>
            <button class="clear-chat-option" @onclick="() => ClearChat(TimeSpan.FromHours(24))">@Loc["Last 24 hours"]</button>
            <button class="clear-chat-option" @onclick="() => ClearChat(TimeSpan.FromDays(7))">@Loc["Last 7 days"]</button>
            <button class="clear-chat-option" @onclick="() => ClearChat(TimeSpan.FromDays(30))">@Loc["Last 30 days"]</button>
            <button class="clear-chat-option danger" @onclick="() => ClearChat(TimeSpan.Zero)">@Loc["All messages"]</button>
        </div>
        <button class="clear-chat-cancel" @onclick="() => _showClearChatDialog = false">@Loc["Cancel"]</button>
    </div>
}

@if (_showForwardDialog && _forwardingMessage is not null)
{
    <div class="forward-dialog-overlay" @onclick="CloseForwardDialog">
        <div class="forward-dialog" @onclick:stopPropagation="true">
            <div class="forward-dialog-header">
                <h4>@Loc["Forward message"]</h4>
                <button class="msg-action-btn" @onclick="CloseForwardDialog">&#10005;</button>
            </div>
            <input type="text" class="forward-search-input" placeholder="@Loc["Search conversations..."]"
                   @bind="_forwardSearchQuery" @bind:event="oninput" />
            <div class="forward-conversation-list">
                @if (_forwardConversations is null)
                {
                    <p style="padding:16px; color:var(--text-secondary);">Loading...</p>
                }
                else
                {
                    var filtered = string.IsNullOrWhiteSpace(_forwardSearchQuery)
                        ? _forwardConversations
                        : _forwardConversations.Where(c => c.DisplayName.Contains(_forwardSearchQuery, StringComparison.OrdinalIgnoreCase)).ToList();
                    @foreach (var conv in filtered)
                    {
                        if (conv.ConversationId == ConversationId) continue;
                        <button class="forward-conversation-item" @onclick="() => ForwardToConversation(conv.ConversationId)">
                            <AvatarInitials DisplayName="@conv.DisplayName" Size="36" />
                            <span>@conv.DisplayName</span>
                        </button>
                    }
                    @if (filtered.All(c => c.ConversationId == ConversationId))
                    {
                        <p style="padding:16px; color:var(--text-secondary);">No conversations found.</p>
                    }
                }
            </div>
        </div>
    </div>
}

@* ReSharper disable NotAccessedField.Local *@
@code {
    [Parameter]
    public long ConversationId { get; set; }

    protected override void OnInitialized()
    {
        Theme.OnThemeChanged += OnThemeChanged;
    }

    private bool _disposed;
    private bool _needsScrollToUnread;
    private bool _needsScrollToBottom;
    private bool _initialScrollDone;
    private bool _hasMoreMessages;
    private bool _isLoadingMore;
    private const int PageSize = 50;
    private DotNetObjectReference<Chat>? _dotNetRef;

    // Read tracking (watermark — sequence number based)
    private long _lastReadSequenceNumber;
    private System.Timers.Timer? _readDebounceTimer;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Set up scroll observer once
        if (!_isLoading && _dotNetRef is null && _messages.Count > 0)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await Js.InvokeVoidAsync("mediaHelpers.observeScroll", ".chat-messages", _dotNetRef);
            }
            catch { /* ignored */ }
        }

        if (_needsScrollToUnread && _firstUnreadMessageId.HasValue)
        {
            _needsScrollToUnread = false;
            _initialScrollDone = true;
            try
            {
                await Js.InvokeVoidAsync("mediaHelpers.scrollToElement",
                    $"[data-msg-id=\"{_firstUnreadMessageId.Value}\"]");
            }
            catch { /* ignored */ }
        }
        else if (_needsScrollToBottom)
        {
            _needsScrollToBottom = false;
            var isFirstScroll = !_initialScrollDone;
            _initialScrollDone = true;
            try
            {
                await Js.InvokeVoidAsync("mediaHelpers.scrollToBottom", ".chat-messages", isFirstScroll);
            }
            catch { /* ignored */ }
        }
    }

    private void OnThemeChanged()
    {
        InvokeAsync(async () =>
        {
            await LoadWallpaperStyle();
            StateHasChanged();
        });
    }

    private readonly List<ChatMessage> _messages = [];
    private ElementReference _messageContainer;
    private MessageInput? _messageInput;
    private string? _errorMessage;
    private string? _infoMessage; // FR-032: Info messages (e.g., offline queue)
    private DateTime? _rateLimitCooldownEnd; // FR-002a: Rate limit cooldown tracking
    private bool _isLoading = true;
    private string _wallpaperStyle = "";
    private string? _typingIndicator;
    private long _localDeviceId;
    private long _localUserId;
    private string? _accessToken;
    private System.Timers.Timer? _typingTimer;
    private ConversationDetailResponse? _conversationDetail;
    private List<ParticipantResponse> _participants = [];
    private bool _showParticipants;
    private bool _showScrollButton;
    private long? _firstUnreadMessageId;
    private int _serverUnreadCount;
    private bool _lightboxVisible;
    private List<string> _lightboxImageUrls = [];
    private int _lightboxIndex;
    private bool _videoLightboxVisible;
    private string? _videoLightboxUrl;
    private ChatMessage? _replyingTo;

    // Context menu state
    private bool _showContextMenu;
    private double _contextMenuX;
    private double _contextMenuY;
    private double _contextMenuBottomY;
    private bool _contextMenuFlipUp;
    private ChatMessage? _contextMenuMessage;

    // Presence state
    private bool _peerIsOnline;
    private DateTimeOffset? _peerLastSeen;

    // Clear chat / header menu state
    private bool _showChatMenu;
    private bool _showClearChatDialog;

    // Search state
    private bool _showSearch;
    private string _searchQuery = "";
    private List<ChatMessage> _searchResults = [];
    private int _searchIndex;

    // Forward state
    private bool _showForwardDialog;
    private ChatMessage? _forwardingMessage;
    private string _forwardSearchQuery = "";
    private List<ConversationListItemResponse>? _forwardConversations;

    // Static pending forward — survives navigation between chat pages
    internal static (string Text, ContentType ContentType, string? FileName, string? MimeType, string? MediaDataUrl, bool IsForwarded, byte[]? MediaBytes)? PendingForward;

    protected override async Task OnInitializedAsync()
    {
        // Capture and clear any pending forward immediately to prevent stale forwards
        var pendingFwd = PendingForward;
        PendingForward = null;

        try
        {
            // Retrieve local deviceId and token from storage
            var deviceIdBytes = await Storage.GetAsync("local.deviceId");
            var tokenBytes = await Storage.GetAsync("auth.token");

            if (deviceIdBytes is null || tokenBytes is null)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            _localDeviceId = long.Parse(Encoding.UTF8.GetString(deviceIdBytes));
            _accessToken = Encoding.UTF8.GetString(tokenBytes);

            // Extract userId from JWT token
            _localUserId = ExtractUserIdFromJwt(_accessToken);

            // Load wallpaper
            await LoadWallpaperStyle();

            // Set auth header for HTTP requests
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", _accessToken);

            // Initialize message store
            await MessageStore.InitializeAsync();

            // Load conversation details and participants
            await LoadConversationDetails();
            await LoadParticipants();

            // Connect to SignalR hub first (reuses existing connection from sidebar)
            var hubUrl = Navigation.ToAbsoluteUri("/hubs/chat").ToString();
            await SignalR.ConnectAsync(hubUrl, _accessToken);
            try
            {
                await SignalR.RegisterDeviceAsync(_localDeviceId);
            }
            catch (Exception ex) when (ex.Message.Contains("Device not found"))
            {
                await Js.InvokeVoidAsync("toledoStorage.clearAuthData");
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            // Subscribe to real-time events BEFORE loading messages
            SignalR.OnMessageReceived += HandleMessageReceived;
            SignalR.OnMessageDelivered += HandleMessageDelivered;
            SignalR.OnMessageRead += HandleMessageRead;
            SignalR.OnTypingIndicator += HandleTypingIndicator;
            SignalR.OnParticipantAdded += HandleParticipantAdded;
            SignalR.OnParticipantRemoved += HandleParticipantRemoved;
            SignalR.OnUserOnline += HandleUserOnline;
            SignalR.OnUserOffline += HandleUserOffline;
            SignalR.OnReactionAdded += HandleReactionAdded;
            SignalR.OnReactionRemoved += HandleReactionRemoved;
            SignalR.OnMessageDeleted += HandleMessageDeleted;
            SignalR.OnReconnected += HandleReconnected;
            MessageExpiry.OnMessageExpired += HandleMessageExpired;

            // Load cached messages from IndexedDB (instant display)
            await LoadCachedMessages();

            // Load pending messages
            await LoadPendingMessages();

            // Bulk-acknowledge delivery FIRST, then get unread count
            // (unread = delivered but not read; must deliver before counting)
            try { await Http.PostAsync($"/api/messages/acknowledge-all?deviceId={_localDeviceId}", null); }
            catch { /* best effort */ }

            // NOW get unread count + read pointer (after delivery ack, so newly delivered messages are counted)
            try
            {
                var unreadResp = await Http.GetFromJsonAsync<JsonElement>(
                    $"/api/messages/unread-count?deviceId={_localDeviceId}&conversationId={ConversationId}");
                _serverUnreadCount = unreadResp.GetProperty("unreadCount").GetInt32();
                // Initialize read pointer from server so we don't re-mark already-read messages
                if (unreadResp.TryGetProperty("lastReadSequenceNumber", out var lrsn))
                    _lastReadSequenceNumber = lrsn.GetInt64();
            }
            catch { _serverUnreadCount = 0; }

            // Place the unread divider based on server unread count
            // (covers both fresh pending messages and returning to a chat with cached messages)
            if (_serverUnreadCount > 0 && _messages.Count > 0)
            {
                // Count incoming messages from the end to find where the divider goes
                var incomingCount = 0;
                for (var i = _messages.Count - 1; i >= 0; i--)
                {
                    if (!_messages[i].IsMine)
                    {
                        incomingCount++;
                        if (incomingCount == _serverUnreadCount)
                        {
                            _firstUnreadMessageId = _messages[i].MessageId;
                            break;
                        }
                    }
                }
            }

            // FR-030: Flush messages already expired before app started
            var expiredOnStartup = MessageExpiry.FlushExpired();
            foreach (var expiredId in expiredOnStartup)
            {
                var msg = _messages.FirstOrDefault(m => m.MessageId == expiredId);
                if (msg is null) continue;
                _messages.Remove(msg);
                try
                {
                    await MessageStore.DeleteMessageAsync(
                        expiredId.ToString(CultureInfo.InvariantCulture));
                }
                catch { /* best effort */ }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to initialize chat: {ex.Message}";
        }
        finally
        {
            _isLoading = false;

            // Determine scroll position
            if (_firstUnreadMessageId.HasValue)
            {
                _needsScrollToUnread = true;
            }
            else if (_messages.Count > 0)
            {
                _needsScrollToBottom = true;
            }
        }

        // Check for pending forwarded message (use captured value from start of method)
        if (pendingFwd is not null)
        {
            var fwd = pendingFwd.Value;
            await SendForwardedMessage(fwd.Text, fwd.ContentType, fwd.FileName, fwd.MimeType, fwd.MediaDataUrl, fwd.MediaBytes);
        }
    }

    private async Task LoadConversationDetails()
    {
        try
        {
            _conversationDetail = await Http.GetFromJsonAsync<ConversationDetailResponse>(
                $"/api/conversations/{ConversationId}");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load conversation details: {ex.Message}";
        }
    }

    private async Task LoadParticipants()
    {
        try
        {
            _participants = await Http.GetFromJsonAsync<List<ParticipantResponse>>(
                $"/api/conversations/{ConversationId}/participants") ?? [];
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load participants: {ex.Message}";
        }
    }

    private async Task LoadCachedMessages()
    {
        try
        {
            var conversationKey = ConversationId.ToString(CultureInfo.InvariantCulture);

            // FR-012: Load only the most recent page initially for performance
            var totalCount = await MessageStore.GetMessageCountAsync(conversationKey);
            var offset = Math.Max(0, totalCount - PageSize);
            var cached = await MessageStore.GetMessagesPagedAsync(conversationKey, offset, PageSize);
            _hasMoreMessages = offset > 0;

            foreach (var stored in cached)
            {
                // Skip if already in messages list (shouldn't happen, but guard against duplicates)
                if (_messages.Any(m => m.MessageId.ToString(CultureInfo.InvariantCulture) == stored.MessageId))
                    continue;

                _messages.Add(new ChatMessage
                {
                    MessageId = long.TryParse(stored.MessageId, out var mid) ? mid : 0,
                    SequenceNumber = stored.SequenceNumber,
                    Text = stored.Text,
                    Timestamp = DateTimeOffset.TryParse(stored.Timestamp, out var ts) ? ts : DateTimeOffset.UtcNow,
                    IsMine = stored.IsMine,
                    ContentType = (ContentType)stored.ContentType,
                    FileName = stored.FileName,
                    MimeType = stored.MimeType,
                    MediaDataUrl = stored.MediaDataBase64 is not null
                        ? await CreateMediaBlobUrlFromBase64(stored.MediaDataBase64, stored.MimeType, stored.FileName)
                        : null,
                    Status = (Shared.Enums.DeliveryStatus)stored.Status,
                    ReplyToMessageId = long.TryParse(stored.ReplyToMessageId, out var rid) ? rid : null,
                    ReplyToText = stored.ReplyToText,
                    ReplyToSenderName = stored.ReplyToSenderName
                });
            }

            // FR-030: Track loaded messages for disappearing timer expiry
            foreach (var msg in _messages)
                TrackForExpiry(msg);
        }
        catch
        {
            // Non-critical: will still load from server
        }
    }

    /// <summary>
    /// FR-012: Load the previous page of older messages when user scrolls to top.
    /// </summary>
    private async Task LoadEarlierMessages()
    {
        if (_isLoadingMore || !_hasMoreMessages) return;
        _isLoadingMore = true;

        try
        {
            var conversationKey = ConversationId.ToString(CultureInfo.InvariantCulture);
            var totalCount = await MessageStore.GetMessageCountAsync(conversationKey);
            var alreadyLoaded = _messages.Count;
            var offset = Math.Max(0, totalCount - alreadyLoaded - PageSize);
            var count = Math.Min(PageSize, totalCount - alreadyLoaded);

            if (count <= 0) { _hasMoreMessages = false; return; }

            var older = await MessageStore.GetMessagesPagedAsync(conversationKey, offset, count);
            _hasMoreMessages = offset > 0;

            var newMessages = new List<ChatMessage>();
            foreach (var stored in older)
            {
                if (_messages.Any(m => m.MessageId.ToString(CultureInfo.InvariantCulture) == stored.MessageId))
                    continue;

                var chatMsg = new ChatMessage
                {
                    MessageId = long.TryParse(stored.MessageId, out var mid) ? mid : 0,
                    SequenceNumber = stored.SequenceNumber,
                    Text = stored.Text,
                    Timestamp = DateTimeOffset.TryParse(stored.Timestamp, out var ts) ? ts : DateTimeOffset.UtcNow,
                    IsMine = stored.IsMine,
                    ContentType = (ContentType)stored.ContentType,
                    FileName = stored.FileName,
                    MimeType = stored.MimeType,
                    MediaDataUrl = stored.MediaDataBase64 is not null
                        ? await CreateMediaBlobUrlFromBase64(stored.MediaDataBase64, stored.MimeType, stored.FileName)
                        : null,
                    Status = (Shared.Enums.DeliveryStatus)stored.Status,
                    ReplyToMessageId = long.TryParse(stored.ReplyToMessageId, out var rid) ? rid : null,
                    ReplyToText = stored.ReplyToText,
                    ReplyToSenderName = stored.ReplyToSenderName
                };
                TrackForExpiry(chatMsg);
                newMessages.Add(chatMsg);
            }

            // Insert older messages at the beginning
            _messages.InsertRange(0, newMessages);
            StateHasChanged();
        }
        catch
        {
            // Non-critical
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    private async Task<string?> CreateMediaBlobUrlFromBase64(string base64Data, string? storedMimeType, string? fileName)
    {
        try
        {
            var bytes = Convert.FromBase64String(base64Data);
            var mimeType = storedMimeType
                           ?? (fileName is not null ? GetMimeTypeFromFileName(fileName) : "application/octet-stream");
            return await CreateMediaBlobUrl(mimeType, bytes);
        }
        catch
        {
            return null;
        }
    }

    private static string GetMimeTypeFromFileName(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return ext switch
        {
            ".jpg" or ".jpeg" => "image/jpeg",
            ".png" => "image/png",
            ".gif" => "image/gif",
            ".webp" => "image/webp",
            ".mp4" => "video/mp4",
            ".webm" => "video/webm",
            ".mp3" => "audio/mpeg",
            ".ogg" => "audio/ogg",
            ".wav" => "audio/wav",
            ".pdf" => "application/pdf",
            _ => "application/octet-stream"
        };
    }

    private async Task LoadPendingMessages()
    {
        try
        {
            var envelopes = await Http.GetFromJsonAsync<List<MessageEnvelope>>(
                $"/api/messages/pending?deviceId={_localDeviceId}");

            if (envelopes is null || envelopes.Count == 0)
                return;

            // Process ALL pending messages (not just current conversation)
            foreach (var envelope in envelopes)
            {
                if (envelope.ConversationId == ConversationId)
                {
                    // Current conversation — decrypt and display
                    if (_messages.Any(m => m.MessageId == envelope.MessageId))
                        continue;

                    ChatMessage chatMsg;
                    try
                    {
                        chatMsg = await DecryptEnvelopeToChatMessage(envelope, isMine: false);
                    }
                    catch (Exception)
                    {
                        chatMsg = new ChatMessage
                        {
                            MessageId = envelope.MessageId,
                            SequenceNumber = envelope.SequenceNumber,
                            Text = "\ud83d\udd12 Waiting for encryption keys...",
                            Timestamp = envelope.ServerTimestamp,
                            IsMine = false,
                            ContentType = ContentType.Text,
                            Status = Shared.Enums.DeliveryStatus.Delivered
                        };
                    }

                    _messages.Add(chatMsg);

                    await PersistMessageAsync(chatMsg);
                    if (chatMsg.MediaBytes is not null)
                        chatMsg.MediaBytes = null;
                }
                else
                {
                    // Other conversation — decrypt to advance ratchet, persist to IndexedDB
                    try
                    {
                        var otherMsg = await DecryptEnvelopeToChatMessage(envelope, isMine: false);
                        await MessageStore.StoreMessageAsync(new StoredMessage
                        {
                            MessageId = otherMsg.MessageId.ToString(CultureInfo.InvariantCulture),
                            ConversationId = envelope.ConversationId.ToString(CultureInfo.InvariantCulture),
                            Text = otherMsg.Text,
                            Timestamp = otherMsg.Timestamp.ToString("O"),
                            IsMine = false,
                            ContentType = (int)otherMsg.ContentType,
                            FileName = otherMsg.FileName,
                            MediaDataBase64 = otherMsg.MediaBytes is not null ? Convert.ToBase64String(otherMsg.MediaBytes) : null,
                            MimeType = otherMsg.MimeType,
                            Status = (int)Shared.Enums.DeliveryStatus.Delivered
                        });
                    }
                    catch { /* decryption failed — still acknowledge via bulk */ }
                }
            }
            // Individual acks removed — bulk acknowledge-all handles it
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load messages: {ex.Message}";
        }
    }

    // FR-025: Retry button for message loading failure
    private async Task RetryLoadMessages()
    {
        _errorMessage = null;
        await LoadCachedMessages();
    }

    private async Task PersistMessageAsync(ChatMessage chatMsg)
    {
        try
        {
            await MessageStore.StoreMessageAsync(new StoredMessage
            {
                MessageId = chatMsg.MessageId.ToString(CultureInfo.InvariantCulture),
                SequenceNumber = chatMsg.SequenceNumber,
                ConversationId = ConversationId.ToString(CultureInfo.InvariantCulture),
                Text = chatMsg.Text,
                Timestamp = chatMsg.Timestamp.ToString("O"),
                IsMine = chatMsg.IsMine,
                ContentType = (int)chatMsg.ContentType,
                FileName = chatMsg.FileName,
                MediaDataBase64 = chatMsg.MediaBytes is not null ? Convert.ToBase64String(chatMsg.MediaBytes) : null,
                MimeType = chatMsg.MimeType,
                Status = (int)chatMsg.Status,
                ReplyToMessageId = chatMsg.ReplyToMessageId?.ToString(),
                ReplyToText = chatMsg.ReplyToText,
                ReplyToSenderName = chatMsg.ReplyToSenderName
            });
        }
        catch
        {
            // Non-critical: message is still in memory
        }
    }

    // ReSharper disable once AsyncVoidMethod
    private async void HandleMessageReceived(MessageEnvelope envelope)
    {
        if (_disposed) return;
        if (envelope.ConversationId != ConversationId)
            return;

        try
        {
            await InvokeAsync(async () =>
            {
                // Skip duplicates
                if (_messages.Any(m => m.MessageId == envelope.MessageId))
                    return;

                ChatMessage chatMsg;
                try
                {
                    chatMsg = await DecryptEnvelopeToChatMessage(envelope, isMine: false);
                }
                catch
                {
                    chatMsg = new ChatMessage
                    {
                        MessageId = envelope.MessageId,
                        Text = "\ud83d\udd12 Waiting for encryption keys...",
                        Timestamp = envelope.ServerTimestamp,
                        IsMine = false,
                        ContentType = ContentType.Text,
                        Status = Shared.Enums.DeliveryStatus.Delivered
                    };
                }

                _messages.Add(chatMsg);
                TrackForExpiry(chatMsg);
                await PersistMessageAsync(chatMsg);

                // Release media bytes after persistence to free memory
                if (chatMsg.MediaBytes is not null)
                {
                    chatMsg.MediaBytes = null;
                }

                _needsScrollToBottom = true;
                StateHasChanged();
            });

            // Always acknowledge delivery — even if decryption failed.
            await SignalR.AcknowledgeDeliveryAsync(envelope.MessageId);
        }
        catch
        {
            // Prevent async void from crashing the WASM runtime
        }
    }

