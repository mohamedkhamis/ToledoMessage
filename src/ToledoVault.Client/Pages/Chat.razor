    private async Task LoadForwardConversations()
    {
        try
        {
            _forwardConversations = await Http.GetFromJsonAsync<List<ConversationListItemResponse>>(
                "/api/conversations");
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            _forwardConversations = [];
            await InvokeAsync(StateHasChanged);
        }
    }

    private void CloseForwardDialog()
    {
        _showForwardDialog = false;
        _forwardingMessage = null;
        _forwardSearchQuery = "";
    }

    private async void ForwardToConversation(long targetConversationId)
    {
        if (_forwardingMessage is null) return;

        // BUG-CR-004 FIX: Convert blob URL to bytes before navigation
        // otherwise the URL gets revoked when the old component disposes
        string? mediaDataUrl = _forwardingMessage.MediaDataUrl;
        byte[]? mediaBytes = null;
        if (_forwardingMessage.ContentType != ContentType.Text && !string.IsNullOrEmpty(mediaDataUrl))
        {
            try
            {
                mediaBytes = await Js.InvokeAsync<byte[]>("mediaHelpers.fetchBlobAsBytes", mediaDataUrl);
            }
            catch
            {
                _errorMessage = "Could not forward media — the file is no longer available.";
                return;
            }
        }

        // Store bytes instead of blob URL (null means bytes are in MediaBytes)
        PendingForward = (
            _forwardingMessage.Text,
            _forwardingMessage.ContentType,
            _forwardingMessage.FileName,
            _forwardingMessage.MimeType,
            mediaBytes is not null ? null : mediaDataUrl, // if we have bytes, don't need URL
            true,
            mediaBytes
        );

        CloseForwardDialog();
        Navigation.NavigateTo($"/chat/{targetConversationId}", forceLoad: false);
    }

    private async Task SendForwardedMessage(string text, ContentType contentType, string? fileName, string? mimeType, string? mediaDataUrl, byte[]? mediaBytesFromForward = null)
    {
        try
        {
            if (contentType != ContentType.Text && (mediaBytesFromForward is not null || !string.IsNullOrEmpty(mediaDataUrl)))
            {
                // For media: use pre-fetched bytes if available, otherwise fetch from blob URL
                byte[]? mediaBytes = mediaBytesFromForward;
                if (mediaBytes is null)
                {
                    try
                    {
                        mediaBytes = await Js.InvokeAsync<byte[]>("mediaHelpers.fetchBlobAsBytes", mediaDataUrl);
                    }
                    catch
                    {
                        _errorMessage = "Could not forward media — the file is no longer available. Try re-sending.";
                        return;
                    }
                }

                if (mediaBytes.Length == 0)
                {
                    _errorMessage = "Could not forward media — the file is no longer available. Try re-sending.";
                    return;
                }

                // Use forwarded MimeType if available, otherwise fall back to filename guess
                var resolvedMimeType = mimeType ?? (fileName is not null ? GetMimeTypeFromFileName(fileName) : GetDefaultMimeType(contentType));
                var input = new MessageInput.ChatInputMessage
                {
                    Text = text,
                    ContentType = contentType,
                    FileName = fileName,
                    MimeType = resolvedMimeType,
                    MediaBytes = mediaBytes
                };
                var tempMessage = new ChatMessage
                {
                    MessageId = 0,
                    Text = text,
                    Timestamp = DateTimeOffset.UtcNow,
                    IsMine = true,
                    ContentType = contentType,
                    FileName = fileName,
                    MediaDataUrl = await CreateMediaBlobUrl(mimeType, mediaBytes),
                    MediaBytes = mediaBytes, // Keep until persisted
                    MimeType = mimeType,
                    Status = Shared.Enums.DeliveryStatus.Sending,
                    IsForwarded = true
                };
                _messages.Add(tempMessage);
                StateHasChanged();
                await SendMediaToRecipients(input, tempMessage);
                await PersistMessageAsync(tempMessage);
                tempMessage.MediaBytes = null; // Release after persist
                StateHasChanged();
                return;
            }

            // Text-only forward
            if (!string.IsNullOrEmpty(text))
            {
                var tempMessage = new ChatMessage
                {
                    MessageId = 0,
                    Text = text,
                    Timestamp = DateTimeOffset.UtcNow,
                    IsMine = true,
                    ContentType = ContentType.Text,
                    Status = Shared.Enums.DeliveryStatus.Sending,
                    IsForwarded = true
                };
                _messages.Add(tempMessage);
                StateHasChanged();
                await SendTextToRecipients(text, tempMessage);
                await PersistMessageAsync(tempMessage);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to forward message: {ex.Message}";
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        // Unsubscribe from theme changes (BUG-CR-001 fix: must be in DisposeAsync, not Dispose)
        Theme.OnThemeChanged -= OnThemeChanged;

        // Unsubscribe from events
        SignalR.OnMessageReceived -= HandleMessageReceived;
        SignalR.OnMessageDelivered -= HandleMessageDelivered;
        SignalR.OnMessageRead -= HandleMessageRead;
        SignalR.OnTypingIndicator -= HandleTypingIndicator;
        SignalR.OnParticipantAdded -= HandleParticipantAdded;
        SignalR.OnParticipantRemoved -= HandleParticipantRemoved;
        SignalR.OnUserOnline -= HandleUserOnline;
        SignalR.OnUserOffline -= HandleUserOffline;
        SignalR.OnReactionAdded -= HandleReactionAdded;
        SignalR.OnReactionRemoved -= HandleReactionRemoved;
        SignalR.OnMessageDeleted -= HandleMessageDeleted;
        SignalR.OnReconnected -= HandleReconnected;
        MessageExpiry.OnMessageExpired -= HandleMessageExpired;

        _typingTimer?.Stop();
        _typingTimer?.Dispose();
        _readDebounceTimer?.Stop();
        _readDebounceTimer?.Dispose();

        // Send final read ack for messages the user has scrolled past BEFORE disposing dotNetRef
        try { await SendReadAck(); }
        catch { /* best effort */ }

        _dotNetRef?.Dispose();
        _dotNetRef = null;

        // Revoke blob URLs to free browser memory
        await RevokeBlobUrls();
    }

    // ─── Disappearing Messages (FR-030) ───

    /// <summary>
    /// Track a message for automatic expiry if the conversation has a disappearing timer.
    /// </summary>
    private void TrackForExpiry(ChatMessage msg)
    {
        if (_conversationDetail?.DisappearingTimerSeconds is not > 0) return;
        var expiresAt = msg.Timestamp.AddSeconds(_conversationDetail.DisappearingTimerSeconds.Value);
        MessageExpiry.TrackMessage(msg.MessageId, expiresAt);
    }

    private void HandleMessageExpired(long messageId)
    {
        InvokeAsync(async () =>
        {
            if (_disposed) return;

            var msg = _messages.FirstOrDefault(m => m.MessageId == messageId);
            if (msg is null) return;

            // Revoke blob URL if present
            if (!string.IsNullOrEmpty(msg.MediaDataUrl))
            {
                try { await Js.InvokeVoidAsync("URL.revokeObjectURL", msg.MediaDataUrl); }
                catch { /* ignored */ }
            }

            _messages.Remove(msg);

            // Remove from IndexedDB
            try
            {
                await MessageStore.DeleteMessageAsync(
                    messageId.ToString(CultureInfo.InvariantCulture));
            }
            catch { /* best effort */ }

            StateHasChanged();
        });
    }

    /// <summary>
    /// Local view model for a chat message displayed in the UI.
    /// </summary>
    private sealed class ChatMessage
    {
        public long MessageId { get; set; }
        public long SequenceNumber { get; set; }
        // ReSharper disable once PropertyCanBeMadeInitOnly.Local
        public string Text { get; set; } = "";
        public DateTimeOffset Timestamp { get; set; }
        public bool IsMine { get; init; }
        public Shared.Enums.DeliveryStatus Status { get; set; }
        public ContentType ContentType { get; init; } = ContentType.Text;
        public string? MediaDataUrl { get; init; }
        public string? ThumbnailDataUrl { get; set; }
        public byte[]? MediaBytes { get; set; }
        public string? MimeType { get; init; }
        public string? FileName { get; init; }
        public long? ReplyToMessageId { get; init; }
        public string? ReplyToText { get; init; }
        public string? ReplyToSenderName { get; init; }
        public string? ReplyToMediaDataUrl { get; init; }
        public string? ReplyToThumbnailDataUrl { get; init; }
        public ContentType ReplyToContentType { get; init; } = ContentType.Text;
        public bool IsForwarded { get; init; }
        public int[]? Waveform { get; init; }
    }
