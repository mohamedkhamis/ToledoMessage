    private List<MessageBubble.ReactionBadgeModel> GetReactionBadges(long messageId)
    {
        if (!_messageReactions.TryGetValue(messageId, out var reactions) || reactions.Count == 0)
            return [];

        return reactions
            .GroupBy(r => r.Emoji)
            .Select(g => new MessageBubble.ReactionBadgeModel
            {
                Emoji = g.Key,
                Count = g.Count(),
                IncludesMine = g.Any(r => r.UserId == _localUserId)
            })
            .ToList();
    }

