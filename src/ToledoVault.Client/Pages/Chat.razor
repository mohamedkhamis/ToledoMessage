    [JSInvokable]
    public void OnVisibleMessageChanged(string messageIdStr)
    {
        if (!long.TryParse(messageIdStr, out var messageId))
            return;

        var msg = _messages.FirstOrDefault(m => m.MessageId == messageId);
        if (msg is null)
            return;

        // Use the sequence number of the visible message (works for both mine and incoming)
        // All messages up to this sequence number have been "seen" by the user
        var seqNum = msg.SequenceNumber;

        // If the visible message is ours, also check earlier incoming messages
        if (msg.IsMine)
        {
            var visibleIndex = _messages.IndexOf(msg);
            for (var i = visibleIndex; i >= 0; i--)
            {
                if (!_messages[i].IsMine && _messages[i].SequenceNumber > 0)
                {
                    seqNum = Math.Max(seqNum, _messages[i].SequenceNumber);
                    break;
                }
            }
        }

        if (seqNum <= 0 || seqNum <= _lastReadSequenceNumber)
            return;

        _lastReadSequenceNumber = seqNum;
        ScheduleReadAck();
    }

    private void ScheduleReadAck()
    {
        // Debounce: send read ack 500ms after the last scroll stop
        _readDebounceTimer?.Stop();
        _readDebounceTimer?.Dispose();
        _readDebounceTimer = new System.Timers.Timer(500);
        _readDebounceTimer.AutoReset = false;
        _readDebounceTimer.Elapsed += async (_, _) =>
        {
            await SendReadAck();
        };
        _readDebounceTimer.Start();
    }

    private async Task SendReadAck()
    {
        if (_lastReadSequenceNumber <= 0)
            return;

        var upToSeq = _lastReadSequenceNumber;
        try
        {
            // Use HTTP endpoint with sequence number — O(1) pointer update on server
            var url = $"/api/messages/read?conversationId={ConversationId}&upToSequenceNumber={upToSeq}";
            var response = await Http.PostAsync(url, null);
            if (!response.IsSuccessStatusCode)
                return;

            // Update local unread count based on sequence numbers
            await InvokeAsync(() =>
            {
                _serverUnreadCount = _messages.Count(m => !m.IsMine && m.SequenceNumber > upToSeq);

                if (_serverUnreadCount == 0)
                {
                    _firstUnreadMessageId = null;
                }
                else
                {
                    var firstUnread = _messages
                        .Where(m => !m.IsMine && m.SequenceNumber > upToSeq)
                        .OrderBy(static m => m.SequenceNumber)
                        .FirstOrDefault();
                    _firstUnreadMessageId = firstUnread?.MessageId;
                }
                // Notify sidebar to update the badge
                SignalR.NotifyUnreadCountChanged(ConversationId, _serverUnreadCount);

                StateHasChanged();
            });

        }
        catch { /* best effort */ }
    }

