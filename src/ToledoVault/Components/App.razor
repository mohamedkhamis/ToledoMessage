<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <base href="/" />
    <script>
        // Cache busting: check version and force refresh if changed
        (async function() {
            try {
                var resp = await fetch('/version.json?_=' + Date.now(), { cache: 'no-store' });
                if (resp.ok) {
                    var data = await resp.json();
                    var stored = localStorage.getItem('app.version');
                    if (stored && stored !== data.version) {
                        // Version changed - clear caches and reload
                        if ('caches' in window) {
                            var keys = await caches.keys();
                            await Promise.all(keys.map(function(k) { return caches.delete(k); }));
                        }
                        localStorage.setItem('app.version', data.version);
                        window.location.reload(true);
                        return;
                    }
                    localStorage.setItem('app.version', data.version);
                }
            } catch (e) { /* ignore */ }
        })();
    </script>
    <script>
        (function () {
            function getDesiredTheme() {
                var t = localStorage.getItem('app.theme');
                if (!t) {
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                        return 'default-dark';
                    }
                    return null;
                }
                return t === 'default' ? null : t;
            }
            function applyTheme() {
                var theme = getDesiredTheme();
                if (theme) {
                    document.documentElement.setAttribute('data-theme', theme);
                } else {
                    document.documentElement.removeAttribute('data-theme');
                }
            }
            function applyFontSize() {
                var fs = localStorage.getItem('app.fontSize');
                // Legacy migration: convert old string values to px
                if (fs === 'small') fs = '13';
                else if (fs === 'large') fs = '17';
                else if (fs === 'medium' || !fs) fs = '15';
                document.documentElement.style.setProperty('--app-font-size', fs + 'px');
            }
            function applyCulture() {
                var c = localStorage.getItem('app.culture') || 'en';
                var desiredDir = c.startsWith('ar') ? 'rtl' : 'ltr';
                if (document.documentElement.lang !== c) document.documentElement.lang = c;
                if (document.documentElement.dir !== desiredDir) document.documentElement.dir = desiredDir;
            }
            applyTheme();
            applyFontSize();
            applyCulture();
            // Re-apply after Blazor enhanced navigation
// ReSharper disable  Html.EventNotResolved
            document.addEventListener('blazor:enhancedload', function () {
                applyTheme();
                applyFontSize();
                applyCulture();
                // Also re-apply after a frame in case Blazor patches DOM after the event
                requestAnimationFrame(function () { applyTheme(); applyFontSize(); applyCulture(); });
            });
            // MutationObserver: catch Blazor stripping data-theme/data-font-size/lang/dir during DOM patching
            var applying = false;
            new MutationObserver(function () {
                if (applying) return;
                applying = true;
                var theme = getDesiredTheme();
                var current = document.documentElement.getAttribute('data-theme');
                if (theme && current !== theme) {
                    document.documentElement.setAttribute('data-theme', theme);
                }
                applyFontSize();
                applyCulture();
                applying = false;
            }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme', 'lang', 'dir', 'style'] });

            // Loading spinner: handled by inline script right after the spinner div.
            // See comment there for the full strategy.

            // Global language toggle (used by NavMenu and Home page switchers)
            window.__toggleLang = function() {
                var current = localStorage.getItem('app.culture') || 'en';
                var next = current.startsWith('ar') ? 'en' : 'ar';
                localStorage.setItem('app.culture', next);
                document.cookie = '.AspNetCore.Culture=c=' + next + '|uic=' + next + ';path=/;max-age=31536000;samesite=lax';
                location.reload();
            };
        })();
    </script>
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["themes.css"]" />
    <link rel="stylesheet" href="@Assets["ToledoVault.styles.css"]" />

    <!-- PWA: Web App Manifest -->
    @* ReSharper disable once Html.PathError *@
    <link rel="manifest" href="/manifest.json" />

    <!-- PWA: Theme color for browser chrome (Android status bar, desktop title bar) -->
    <meta name="theme-color" content="#1976d2" />

    <!-- PWA: Standalone mode meta tags -->
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Toledo Vault" />

    <!-- PWA: iOS touch icon (iOS ignores manifest icons) -->
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <ImportMap />
    <HeadOutlet />
</head>

<body>
    <div id="app-loading" style="position:fixed;top:0;left:0;right:0;bottom:0;display:none;flex-direction:column;align-items:center;justify-content:center;background:var(--bg-primary, #0f172a);color:var(--text-primary, #e2e8f0);font-family:system-ui,-apple-system,sans-serif;z-index:9999;">
        <div style="width:40px;height:40px;border:3px solid rgba(255,255,255,0.1);border-top-color:var(--accent, #3b82f6);border-radius:50%;animation:app-spin 0.8s linear infinite;"></div>
        <div style="margin-top:16px;font-size:1.1em;font-weight:500;letter-spacing:0.5px;">ToledoVault</div>
    </div>
    <script>
        // Show spinner ONLY on first page load. window.__blazorLoaded is set
        // after blazor.web.js loads and persists across enhanced navigations
        // (JS state survives DOM patching). On enhanced nav, Blazor restores
        // display:none from server HTML and this script runs again — but
        // __blazorLoaded is already true so the spinner stays hidden.
        if (!window.__blazorLoaded) {
            document.getElementById('app-loading').style.display = 'flex';
        }
    </script>
    <style>
        @@keyframes app-spin {
            to { transform: rotate(360deg); }
        }
    </style>
    <Routes />
    @* ReSharper disable  Html.PathError *@
    <script src="@Assets["storage.js"]"></script>
    <script src="@Assets["media-helpers.js"]"></script>
    <script src="@Assets["voice-recorder.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script>
        // Hide spinner after blazor.web.js loads and set flag.
        // On enhanced navigation, Blazor patches DOM from server HTML
        // (display:none) and re-runs inline scripts — but __blazorLoaded
        // is already true so the spinner script above won't show it.
        window.__blazorLoaded = true;
        var el = document.getElementById('app-loading');
        if (el) el.style.display = 'none';
    </script>

    <!-- PWA: Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/service-worker.js')
                .then(function(registration) {
                    console.log('SW registered: ', registration.scope);
                })
                .catch(function(error) {
                    console.log('SW registration failed: ', error);
                });
        }
    </script>

    <!-- PWA: HTTP Warning Banner (FR-015) -->
    <script>
        (function () {
            var loc = window.location;
            if (loc.protocol === 'http:' && loc.hostname !== 'localhost' && loc.hostname !== '127.0.0.1') {
                var dismissed = false;
                try { dismissed = localStorage.getItem('http-warning.dismissed') === '1'; } catch (e) { }
                if (dismissed) return;
                var culture = 'en';
                try { culture = localStorage.getItem('app.culture') || 'en'; } catch (e) { }
                var isAr = culture.startsWith('ar');
                var msg = isAr
                    ? 'أنت تستخدم اتصال HTTP غير آمن. ميزات PWA مثل التثبيت والإشعارات لن تعمل. يرجى استخدام HTTPS.'
                    : 'You are using an insecure HTTP connection. PWA features like install and notifications will not work. Please use HTTPS.';
                var banner = document.createElement('div');
                banner.id = 'http-warning-banner';
                banner.setAttribute('role', 'alert');
                banner.setAttribute('dir', isAr ? 'rtl' : 'ltr');
                banner.style.cssText = 'position:fixed;top:0;left:0;right:0;z-index:10000;padding:10px 40px 10px 16px;background:#fff3cd;border-bottom:1px solid #ffc107;color:#856404;font:14px/1.4 system-ui,-apple-system,sans-serif;text-align:center;';
                banner.textContent = msg;
                var btn = document.createElement('button');
                btn.textContent = '\u00d7';
                btn.setAttribute('aria-label', isAr ? 'إغلاق' : 'Close');
                btn.style.cssText = 'position:absolute;top:6px;right:12px;background:none;border:none;font-size:20px;cursor:pointer;color:#856404;padding:4px;';
                btn.onclick = function () {
                    banner.remove();
                    try { localStorage.setItem('http-warning.dismissed', '1'); } catch (e) { }
                };
                banner.appendChild(btn);
                document.body.insertBefore(banner, document.body.firstChild);
            }
        })();
    </script>
</body>

</html>
